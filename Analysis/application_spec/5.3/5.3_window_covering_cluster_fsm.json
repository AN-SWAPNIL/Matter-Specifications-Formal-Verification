        "access_required": "O",
        "timed_required": false,
        "timing_constraint": null,
        "error_responses": [],
        "spec_reference": "Section 5.3.6.13.2 'CalibrationMode Bit'; Section 5.3.7.1 'UpOrOpen Command'"
