        "cluster_id": [
          {
            "id": "0x0003",
            "name": "Identify",
            "summary": "Facilitates the identification of a device or endpoint, typically through visual or audible means, to help users locate or confirm a specific device."
          }
        ],
        "classification": [
          {
            "hierarchy": "Base",
            "role": "Utility",
            "scope": "Endpoint",
            "pics_code": "I",
            "summary": "A fundamental utility cluster operating at the endpoint level, providing basic identification functionality for a specific part of a device."
          }
        ],
        "data_types": [
          {
            "name": "IdentifyTypeEnum",
            "base_type": "enum8",
            "constraint": null,
            "values": [
              {
                "value": "0x00",
                "name": "None",
                "summary": "No presentation.",
                "conformance": "M"
              },
              {
                "value": "0x01",
                "name": "LightOutput",
                "summary": "Light output of a lighting product.",
                "conformance": "M"
              },
              {
                "value": "0x02",
                "name": "VisibleIndicator",
                "summary": "Typically a small LED.",
                "conformance": "M"
              },
              {
                "value": "0x03",
                "name": "AudibleBeep",
                "summary": "",
                "conformance": "M"
              },
              {
                "value": "0x04",
                "name": "Display",
                "summary": "Presentation will be visible on display screen.",
                "conformance": "M"
              },
              {
                "value": "0x05",
                "name": "Actuator",
                "summary": "Presentation will be conveyed by actuator functionality such as through a window blind operation or in-wall relay.",
                "conformance": "M"
              }
            ]
          },
          {
            "name": "EffectIdentifierEnum",
            "base_type": "enum8",
            "constraint": null,
            "values": [
              {
                "value": "0x00",
                "name": "Blink",
                "summary": "e.g., Light is turned on/off once.",
                "conformance": "M"
              },
              {
                "value": "0x01",
                "name": "Breathe",
                "summary": "e.g., Light is turned on/off over 1 second and repeated 15 times.",
                "conformance": "M"
              },
              {
                "value": "0x02",
                "name": "Okay",
                "summary": "e.g., Colored light turns green for 1 second; non-colored light flashes twice.",
                "conformance": "M"
              },
              {
                "value": "0x0B",
                "name": "ChannelChange",
                "summary": "e.g., Colored light turns orange for 8 seconds; non-colored light switches to the maximum brightness for 0.5s and then minimum brightness for 7.5s.",
                "conformance": "M"
              },
              {
                "value": "0xFE",
                "name": "FinishEffect",
                "summary": "Complete the current effect sequence before terminating. e.g., if in the middle of a breathe effect (as above), first complete the current 1s breathe effect and then terminate the effect.",
                "conformance": "M"
              },
              {
                "value": "0xFF",
                "name": "StopEffect",
                "summary": "Terminate the effect as soon as possible.",
                "conformance": "M"
              }
            ]
          },
          {
            "name": "EffectVariantEnum",
            "base_type": "enum8",
            "constraint": null,
            "values": [
              {
                "value": "0x00",
                "name": "Default",
                "summary": "Indicates the default effect is used",
                "conformance": "M"
              }
            ]
          }
        ],
        "attributes": [
          {
            "id": "0x0000",
            "name": "IdentifyTime",
            "type": "uint16",
            "constraint": "all",
            "quality": "",
            "default": "0",
            "access": "RW VO",
            "conformance": "M",
            "summary": "Remaining time (seconds) an endpoint identifies itself. Setting >0 starts identification (e.g., flashing light, 0.5s period); decrements every second. Reaching or setting to 0 terminates identification.\n\nIF IdentifyTime > 0 THEN\n    StartIdentification()\n    IdentifyTime-- // per second\nELSE IF IdentifyTime == 0 THEN\n    StopIdentification()\nEND IF\n",
            "fabric_sensitive": false,
            "scene_capable": false
          },
          {
            "id": "0x0001",
            "name": "IdentifyType",
            "type": "IdentifyTypeEnum",
            "constraint": "desc",
            "quality": "",
            "default": "MS",
            "access": "R V",
            "conformance": "M",
            "summary": "Indicates how the identification state is presented to the user. Contains values from IdentifyTypeEnum. 'None' SHALL NOT be used if other methods are available.",
            "fabric_sensitive": false,
            "scene_capable": false
          }
        ],
        "commands": [
          {
            "id": "0x00",
            "name": "Identify",
            "direction": "client ⇒ server",
            "response": "Y",
            "access": "M",
            "conformance": "M",
            "summary": "This command starts or stops the receiving device identifying itself.",
            "timing": null,
            "fields": [
              {
                "id": "0",
                "name": "IdentifyTime",
                "type": "uint16",
                "constraint": "all",
                "quality": null,
                "default": null,
                "conformance": "M",
                "summary": "The value to set the IdentifyTime attribute to, controlling the identification state duration."
              }
            ],
            "effect_on_receipt": "set IdentifyTime attribute := IdentifyTime field value\n// Device identification state starts, continues, or stops based on IdentifyTime attribute value (as detailed in IdentifyTime attribute section)"
          },
          {
            "id": "0x40",
            "name": "TriggerEffect",
            "direction": "client ⇒ server",
            "response": "Y",
            "access": "M",
            "conformance": "O",
            "summary": "This command provides visual feedback to the user via light effects, distinct from the commissioning identify mechanism. Implementers define specific effects for various circumstances, such as indicating successful network connection.",
            "timing": null,
            "fields": [
              {
                "id": "0",
                "name": "EffectIdentifier",
                "type": "EffectIdentifierEnum",
                "constraint": "desc",
                "quality": null,
                "default": null,
                "conformance": "M",
                "summary": "Indicates the identify effect to use, from EffectIdentifierEnum. All enum values must be supported. Implementers may deviate from example effects but should document their handling during testing."
              },
              {
                "id": "1",
                "name": "EffectVariant",
                "type": "EffectVariantEnum",
                "constraint": "desc",
                "quality": null,
                "default": null,
                "conformance": "M",
                "summary": "Indicates the variant of the effect specified by EffectIdentifier. If the device does not support the given variant, it SHALL use the default variant. Values are from EffectVariantEnum."
              }
            ],
            "effect_on_receipt": "if EffectVariant field is not supported by device then\n  execute default variant of effect indicated by EffectIdentifier field\nelse\n  execute trigger effect indicated by EffectIdentifier and EffectVariant fields\nend if"
          }
        ],
        "references": [
