    "states": [
      {
        "name": "Off_Idle",
        "description": "The device is turned off, and no timed 'on' or 'off' periods are active. This is the default 'off' state.",
        "is_initial": true,
        "invariants": [
          "OnOff == FALSE",
          "OnTime == 0",
          "OffWaitTime == 0"
        ],
        "attributes_monitored": [
          "OnOff",
          "OnTime",
          "OffWaitTime"
        ]
      },
      {
        "name": "On_Idle",
        "description": "The device is turned on, and no timed 'on' or 'off' periods are active. This is the default 'on' state.",
        "is_initial": false,
        "invariants": [
          "OnOff == TRUE",
          "OnTime == 0",
          "OffWaitTime == 0"
        ],
        "attributes_monitored": [
          "OnOff",
          "OnTime",
          "OffWaitTime"
        ]
      },
      {
        "name": "On_Timed",
        "description": "The device is turned on for a specified duration (OnTime > 0) as initiated by OnWithTimedOff. OnTime is actively counting down.",
        "is_initial": false,
        "invariants": [
          "OnOff == TRUE",
          "OnTime > 0",
          "OffWaitTime == 0"
        ],
        "attributes_monitored": [
          "OnOff",
          "OnTime",
          "OffWaitTime"
        ]
      },
      {
        "name": "Off_Delayed",
        "description": "The device is turned off, but a guarded 'off' duration (OffWaitTime > 0) is active, preventing immediate re-activation by certain commands. OffWaitTime is actively counting down.",
        "is_initial": false,
        "invariants": [
          "OnOff == FALSE",
          "OnTime == 0",
          "OffWaitTime > 0"
        ],
        "attributes_monitored": [
          "OnOff",
          "OnTime",
          "OffWaitTime"
        ]
      }
    ],
