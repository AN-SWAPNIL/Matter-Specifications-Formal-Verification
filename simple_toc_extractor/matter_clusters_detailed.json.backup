                "constraint": "desc",
                "quality": null,
                "default": "0",
                "conformance": "M",
                "summary": "Options override"
              }
            ],
            "effect_on_receipt": "Create temporary Options bitmap; Stop any ongoing MoveToLevel, Move, or Step command; Set RemainingTime to 0"
          },
          {
            "id": "0x04",
            "name": "MoveToLevelWithOnOff",
            "direction": "client⇒server",
