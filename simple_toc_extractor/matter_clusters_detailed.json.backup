                "default": "0",
                "conformance": "M",
                "summary": "Options override"
              }
            ],
            "effect_on_receipt": "If Rate==0, return INVALID_COMMAND; Create temporary Options bitmap; Move CurrentLevel continuously in MoveMode direction at Rate; Set OnOff attribute accordingly; Stop when Min/MaxLevel reached"
          },
          {
            "id": "0x06",
            "name": "StepWithOnOff",
            "direction": "client⇒server",
            "response": "DefaultResponse",
            "access": "O",
            "conformance": "M",
            "summary": "Step change with On/Off",
            "timing": null,
            "fields": [
              {
                "id": "0",
                "name": "StepMode",
                "type": "StepModeEnum",
                "constraint": "desc",
                "quality": null,
                "default": null,
                "conformance": "M",
