            "name": "OffWaitTime attribute",
            "description": "An attribute of the On/Off cluster, set to 0 when OnOff is TRUE and OnTime is 0 by Level Control commands. Not fully defined here."
          },
          {
            "id": null,
            "name": "INVALID_IN_STATE status code",
            "description": "A standard status code used when a device with DeadFrontBehavior is in an 'Off' state and receives Invoke/Write interactions. Defined in Core Spec."
          },
          {
            "id": null,
