    "proverif_queries": [
      {
        "query_id": "Q001",
        "name": "suppress_requires_operate",
        "query": "query invoker:principal, alarm:alarmMode; event(suppress_alarm(invoker, alarm)) ==> event(has_privilege(invoker, Operate)).",
        "description": "SuppressAlarm command requires Operate privilege"
      },
      {
        "query_id": "Q002",
        "name": "suppressed_implies_active",
        "query": "query device:deviceId, bit:alarmBit; event(suppressed(device, bit)) ==> event(active(device, bit)).",
        "description": "A suppressed alarm must also be active (suppression does not clear active state)"
      },
      {
        "query_id": "Q003",
        "name": "suppress_requires_active_alarm",
        "query": "query device:deviceId, bit:alarmBit; event(suppress_success(device, bit)) ==> event(alarm_active(device, bit)) && event(alarm_enabled(device, bit)).",
        "description": "SuppressAlarm only succeeds if alarm is active and enabled"
      },
      {
        "query_id": "Q004",
        "name": "disable_clears_active",
        "query": "query device:deviceId, bit:alarmBit; event(disable_alarm(device, bit)) ==> event(clear_active(device, bit)) && event(clear_suppressed(device, bit)).",
        "description": "Disabling an alarm clears both active and suppressed states"
      },
      {
        "query_id": "Q005",
        "name": "state_change_generates_event",
        "query": "query device:deviceId; event(alarms_active_changed(device)) || event(alarms_suppressed_changed(device)) ==> event(alarms_state_changed_event(device)).",
        "description": "Any change to AlarmsActive or AlarmsSuppressed generates AlarmsStateChanged event"
      },
      {
        "query_id": "Q006",
        "name": "trigger_clear_clears_suppressed",
        "query": "query device:deviceId; event(sensor_trigger_cleared(device)) ==> event(alarms_suppressed_cleared(device)).",
        "description": "When sensor trigger clears, suppressed state must also clear"
      }
    ]
