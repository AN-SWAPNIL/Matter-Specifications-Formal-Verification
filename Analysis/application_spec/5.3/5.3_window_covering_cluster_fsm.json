      {
        "name": "initiate_self_calibration",
        "parameters": [],
        "return_type": "void",
        "description": "Initiates the device's self-calibration routine before executing the movement command. The exact calibration procedure is vendor-specific. If the device cannot perform self-calibration, this function is not called and FAILURE is returned instead.",
        "usage_in_fsm": "T004, T009"
      },
      {
        "name": "update_current_position",
        "parameters": [
          {"name": "liftPercent100ths", "type": "percent100ths", "description": "New lift position in 0.01% units (0-10000)"},
          {"name": "tiltPercent100ths", "type": "percent100ths", "description": "New tilt position in 0.01% units (0-10000)"}
        ],
        "return_type": "void",
        "description": "Updates the CurrentPositionLiftPercent100ths, CurrentPositionLiftPercentage, CurrentPositionTiltPercent100ths, and CurrentPositionTiltPercentage attributes to reflect the actual physical position of the window covering as movement progresses. Called continuously during motion and upon movement completion.",
        "usage_in_fsm": "T026, T027, T028, T029 (final update on movement completion)"
      }
    ],

