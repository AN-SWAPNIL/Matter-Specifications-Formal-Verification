{
  "cluster_fsm": {
    "cluster_name": "Smoke CO Alarm",
    "cluster_id": "0x005C",
    "pics_code": "SMOKECO",
    "spec_reference": "Matter 1.5 Application Cluster Specification, Section 2.11, Pages 210-220",
    "revision": 1,

    "features": [
      {
        "bit": 0,
        "code": "SMOKE",
        "name": "SmokeAlarm",
        "conformance": "O.a+",
        "description": "Supports Smoke alarm detection and notification",
        "affects_states": [
          "SmokeAlarm_Warning",
          "SmokeAlarm_Critical",
          "InterconnectSmoke_Warning",
          "InterconnectSmoke_Critical"
        ],
        "affects_transitions": [
          "T_SmokeDetected_Warning",
          "T_SmokeDetected_Critical",
          "T_SmokeClear",
          "T_InterconnectSmoke_Warning",
          "T_InterconnectSmoke_Critical"
        ],
        "required_attributes": [
          "SmokeState",
          "ContaminationState",
          "SmokeSensitivityLevel"
        ]
      },
      {
        "bit": 1,
        "code": "CO",
        "name": "COAlarm",
        "conformance": "O.a+",
        "description": "Supports CO (Carbon Monoxide) alarm detection and notification",
        "affects_states": [
          "COAlarm_Warning",
          "COAlarm_Critical",
          "InterconnectCO_Warning",
          "InterconnectCO_Critical"
        ],
        "affects_transitions": [
          "T_CODetected_Warning",
          "T_CODetected_Critical",
          "T_COClear",
          "T_InterconnectCO_Warning",
          "T_InterconnectCO_Critical"
        ],
        "required_attributes": ["COState"]
      }
    ],

    "dependencies": [
      {
        "cluster": "Power Source",
        "relationship": "SHOULD_COEXIST",
        "description": "BatteryAlert state SHALL be reflected in Power Source cluster using appropriate supported attributes and events"
      },
      {
        "cluster": "Boolean State Configuration",
        "relationship": "MAY_COEXIST",
        "description": "For alarm suppress functionality on boolean sensors"
      }
    ],

    "states": [
      {
        "name": "Normal",
        "description": "Nominal state - device is not alarming, no hazards detected",
        "is_initial": true,
        "invariants": [
          "ExpressedState == Normal",
          "SmokeState == Normal OR Feature_SMOKE == false",
          "COState == Normal OR Feature_CO == false",
          "BatteryAlert == Normal",
          "TestInProgress == false",
          "HardwareFaultAlert == false",
          "EndOfServiceAlert == Normal"
        ],
        "state_attributes": {
          "ExpressedState": "Normal",
          "TestInProgress": false
        },
        "feature_requirements": [],
        "safety_implications": "Safe operational state - no immediate hazards"
      },
      {
        "name": "SmokeAlarm_Warning",
        "description": "Smoke detected at Warning level - early detection, may be muted",
        "is_initial": false,
        "invariants": [
          "ExpressedState == SmokeAlarm",
          "SmokeState == Warning",
          "Feature_SMOKE == true"
        ],
        "state_attributes": {
          "ExpressedState": "SmokeAlarm",
          "SmokeState": "Warning"
        },
        "feature_requirements": ["Feature_SMOKE == true"],
        "safety_implications": "MEDIUM - Early smoke detection; user should investigate. Can be muted via physical interaction."
      },
      {
        "name": "SmokeAlarm_Critical",
        "description": "Smoke detected at Critical level - immediate evacuation required",
        "is_initial": false,
        "invariants": [
          "ExpressedState == SmokeAlarm",
          "SmokeState == Critical",
          "Feature_SMOKE == true"
        ],
        "state_attributes": {
          "ExpressedState": "SmokeAlarm",
          "SmokeState": "Critical"
        },
        "feature_requirements": ["Feature_SMOKE == true"],
        "safety_implications": "CRITICAL - Immediate fire danger; evacuation required. SHALL NOT be muted via physical interaction."
      },
      {
        "name": "COAlarm_Warning",
        "description": "Carbon Monoxide detected at Warning level - ventilate area",
        "is_initial": false,
        "invariants": [
          "ExpressedState == COAlarm",
          "COState == Warning",
          "Feature_CO == true"
        ],
        "state_attributes": {
          "ExpressedState": "COAlarm",
          "COState": "Warning"
        },
        "feature_requirements": ["Feature_CO == true"],
        "safety_implications": "MEDIUM - CO detected; ventilate and investigate. Can be muted via physical interaction."
      },
      {
        "name": "COAlarm_Critical",
        "description": "Carbon Monoxide detected at Critical level - immediate evacuation required",
        "is_initial": false,
        "invariants": [
          "ExpressedState == COAlarm",
          "COState == Critical",
          "Feature_CO == true"
        ],
        "state_attributes": {
          "ExpressedState": "COAlarm",
          "COState": "Critical"
        },
        "feature_requirements": ["Feature_CO == true"],
        "safety_implications": "CRITICAL - Lethal CO levels; immediate evacuation required. SHALL NOT be muted via physical interaction."
      },
      {
        "name": "BatteryAlert_Warning",
        "description": "Battery low - replacement needed soon",
        "is_initial": false,
        "invariants": [
          "ExpressedState == BatteryAlert",
          "BatteryAlert == Warning"
        ],
        "state_attributes": {
          "ExpressedState": "BatteryAlert",
          "BatteryAlert": "Warning"
        },
        "feature_requirements": [],
        "safety_implications": "MEDIUM - Device will become non-functional if battery not replaced"
      },
      {
        "name": "BatteryAlert_Critical",
        "description": "Battery critically low - immediate replacement required",
        "is_initial": false,
        "invariants": [
          "ExpressedState == BatteryAlert",
          "BatteryAlert == Critical"
        ],
        "state_attributes": {
          "ExpressedState": "BatteryAlert",
          "BatteryAlert": "Critical"
        },
        "feature_requirements": [],
        "safety_implications": "HIGH - Device may fail imminently. SHALL NOT be muted (life safety). Reflects in Power Source cluster."
      },
      {
        "name": "Testing",
        "description": "Self-test in progress - device testing its sensors",
        "is_initial": false,
        "invariants": ["ExpressedState == Testing", "TestInProgress == true"],
        "state_attributes": {
          "ExpressedState": "Testing",
          "TestInProgress": true
        },
        "feature_requirements": [],
        "safety_implications": "LOW - Device temporarily not monitoring for hazards during test"
      },
      {
        "name": "HardwareFault",
        "description": "Hardware fault detected - device may be unreliable",
        "is_initial": false,
        "invariants": [
          "ExpressedState == HardwareFault",
          "HardwareFaultAlert == true"
        ],
        "state_attributes": {
          "ExpressedState": "HardwareFault",
          "HardwareFaultAlert": true
        },
        "feature_requirements": [],
        "safety_implications": "HIGH - Device unreliable; replace immediately. Critical contamination also reflects as HardwareFault."
      },
      {
        "name": "EndOfService",
        "description": "Device has reached end of service life - replace device",
        "is_initial": false,
        "invariants": [
          "ExpressedState == EndOfService",
          "EndOfServiceAlert == Expired"
        ],
        "state_attributes": {
          "ExpressedState": "EndOfService",
          "EndOfServiceAlert": "Expired"
        },
        "feature_requirements": [],
        "safety_implications": "HIGH - Device past its reliable service life; detection capability may be degraded"
      },
      {
        "name": "InterconnectSmoke_Warning",
        "description": "Smoke alarm received from interconnected device at Warning level",
        "is_initial": false,
        "invariants": [
          "ExpressedState == InterconnectSmoke",
          "InterconnectSmokeAlarm == Warning",
          "Feature_SMOKE == true"
        ],
        "state_attributes": {
          "ExpressedState": "InterconnectSmoke",
          "InterconnectSmokeAlarm": "Warning"
        },
        "feature_requirements": ["Feature_SMOKE == true"],
        "safety_implications": "MEDIUM - Remote smoke detection; investigate source device location"
      },
      {
        "name": "InterconnectSmoke_Critical",
        "description": "Smoke alarm received from interconnected device at Critical level",
        "is_initial": false,
        "invariants": [
          "ExpressedState == InterconnectSmoke",
          "InterconnectSmokeAlarm == Critical",
          "Feature_SMOKE == true"
        ],
        "state_attributes": {
          "ExpressedState": "InterconnectSmoke",
          "InterconnectSmokeAlarm": "Critical"
        },
        "feature_requirements": ["Feature_SMOKE == true"],
        "safety_implications": "CRITICAL - Fire at remote location; whole-home evacuation may be required"
      },
      {
        "name": "InterconnectCO_Warning",
        "description": "CO alarm received from interconnected device at Warning level",
        "is_initial": false,
        "invariants": [
          "ExpressedState == InterconnectCO",
          "InterconnectCOAlarm == Warning",
          "Feature_CO == true"
        ],
        "state_attributes": {
          "ExpressedState": "InterconnectCO",
          "InterconnectCOAlarm": "Warning"
        },
        "feature_requirements": ["Feature_CO == true"],
        "safety_implications": "MEDIUM - Remote CO detection; ventilate and investigate source"
      },
      {
        "name": "InterconnectCO_Critical",
        "description": "CO alarm received from interconnected device at Critical level",
        "is_initial": false,
        "invariants": [
          "ExpressedState == InterconnectCO",
          "InterconnectCOAlarm == Critical",
          "Feature_CO == true"
        ],
        "state_attributes": {
          "ExpressedState": "InterconnectCO",
          "InterconnectCOAlarm": "Critical"
        },
        "feature_requirements": ["Feature_CO == true"],
        "safety_implications": "CRITICAL - Lethal CO at remote location; whole-home evacuation required"
      }
    ],

    "transitions": [
      {
        "id": "T_SmokeDetected_Warning",
        "from_state": "Normal",
        "to_state": "SmokeAlarm_Warning",
        "trigger": {
          "type": "sensor_detection",
          "name": "SmokeWarningDetected",
          "command_id": null
        },
        "guard_condition": "Feature_SMOKE == true && SmokeState_sensor == Warning",
        "actions": [
          "SmokeState := Warning",
          "ExpressedState := SmokeAlarm",
          "generate_event(SmokeAlarm, {AlarmSeverityLevel: Warning})"
        ],
        "access_required": null,
        "timed_required": false,
        "timing_constraint": null,
        "error_responses": [],
        "spec_reference": "Section 2.11.8.1 SmokeAlarm Event"
      },
      {
        "id": "T_SmokeDetected_Critical",
        "from_state": "Normal",
        "to_state": "SmokeAlarm_Critical",
        "trigger": {
          "type": "sensor_detection",
          "name": "SmokeCriticalDetected",
          "command_id": null
        },
        "guard_condition": "Feature_SMOKE == true && SmokeState_sensor == Critical",
        "actions": [
          "SmokeState := Critical",
          "ExpressedState := SmokeAlarm",
          "generate_event(SmokeAlarm, {AlarmSeverityLevel: Critical})"
        ],
        "access_required": null,
        "timed_required": false,
        "timing_constraint": null,
        "error_responses": [],
        "spec_reference": "Section 2.11.8.1 SmokeAlarm Event"
      },
      {
        "id": "T_SmokeEscalate",
        "from_state": "SmokeAlarm_Warning",
        "to_state": "SmokeAlarm_Critical",
        "trigger": {
          "type": "sensor_detection",
          "name": "SmokeCriticalDetected",
          "command_id": null
        },
        "guard_condition": "SmokeState_sensor == Critical",
        "actions": [
          "SmokeState := Critical",
          "generate_event(SmokeAlarm, {AlarmSeverityLevel: Critical})"
        ],
        "access_required": null,
        "timed_required": false,
        "timing_constraint": null,
        "error_responses": [],
        "spec_reference": "Section 2.11.8.1 SmokeAlarm Event - state change to Critical"
      },
      {
        "id": "T_SmokeClear_FromWarning",
        "from_state": "SmokeAlarm_Warning",
        "to_state": "Normal",
        "trigger": {
          "type": "sensor_detection",
          "name": "SmokeCleared",
          "command_id": null
        },
        "guard_condition": "SmokeState_sensor == Normal && no_other_alarms_active",
        "actions": [
          "SmokeState := Normal",
          "ExpressedState := Normal",
          "generate_event(AllClear)"
        ],
        "access_required": null,
        "timed_required": false,
        "timing_constraint": null,
        "error_responses": [],
        "spec_reference": "Section 2.11.8.11 AllClear Event"
      },
      {
        "id": "T_SmokeClear_FromCritical",
        "from_state": "SmokeAlarm_Critical",
        "to_state": "Normal",
        "trigger": {
          "type": "sensor_detection",
          "name": "SmokeCleared",
          "command_id": null
        },
        "guard_condition": "SmokeState_sensor == Normal && no_other_alarms_active",
        "actions": [
          "SmokeState := Normal",
          "ExpressedState := Normal",
          "generate_event(AllClear)"
        ],
        "access_required": null,
        "timed_required": false,
        "timing_constraint": null,
        "error_responses": [],
        "spec_reference": "Section 2.11.8.11 AllClear Event"
      },
      {
        "id": "T_CODetected_Warning",
        "from_state": "Normal",
        "to_state": "COAlarm_Warning",
        "trigger": {
          "type": "sensor_detection",
          "name": "COWarningDetected",
          "command_id": null
        },
        "guard_condition": "Feature_CO == true && COState_sensor == Warning",
        "actions": [
          "COState := Warning",
          "ExpressedState := COAlarm",
          "generate_event(COAlarm, {AlarmSeverityLevel: Warning})"
        ],
        "access_required": null,
        "timed_required": false,
        "timing_constraint": null,
        "error_responses": [],
        "spec_reference": "Section 2.11.8.2 COAlarm Event"
      },
      {
        "id": "T_CODetected_Critical",
        "from_state": "Normal",
        "to_state": "COAlarm_Critical",
        "trigger": {
          "type": "sensor_detection",
          "name": "COCriticalDetected",
          "command_id": null
        },
        "guard_condition": "Feature_CO == true && COState_sensor == Critical",
        "actions": [
          "COState := Critical",
          "ExpressedState := COAlarm",
          "generate_event(COAlarm, {AlarmSeverityLevel: Critical})"
        ],
        "access_required": null,
        "timed_required": false,
        "timing_constraint": null,
        "error_responses": [],
        "spec_reference": "Section 2.11.8.2 COAlarm Event"
      },
      {
        "id": "T_COEscalate",
        "from_state": "COAlarm_Warning",
        "to_state": "COAlarm_Critical",
        "trigger": {
          "type": "sensor_detection",
          "name": "COCriticalDetected",
          "command_id": null
        },
        "guard_condition": "COState_sensor == Critical",
        "actions": [
          "COState := Critical",
          "generate_event(COAlarm, {AlarmSeverityLevel: Critical})"
        ],
        "access_required": null,
        "timed_required": false,
        "timing_constraint": null,
        "error_responses": [],
        "spec_reference": "Section 2.11.8.2 COAlarm Event - state change to Critical"
      },
      {
        "id": "T_COClear_FromWarning",
        "from_state": "COAlarm_Warning",
        "to_state": "Normal",
        "trigger": {
          "type": "sensor_detection",
          "name": "COCleared",
          "command_id": null
        },
        "guard_condition": "COState_sensor == Normal && no_other_alarms_active",
        "actions": [
          "COState := Normal",
          "ExpressedState := Normal",
          "generate_event(AllClear)"
        ],
        "access_required": null,
        "timed_required": false,
        "timing_constraint": null,
        "error_responses": [],
        "spec_reference": "Section 2.11.8.11 AllClear Event"
      },
      {
        "id": "T_COClear_FromCritical",
        "from_state": "COAlarm_Critical",
        "to_state": "Normal",
        "trigger": {
          "type": "sensor_detection",
          "name": "COCleared",
          "command_id": null
        },
        "guard_condition": "COState_sensor == Normal && no_other_alarms_active",
        "actions": [
          "COState := Normal",
          "ExpressedState := Normal",
          "generate_event(AllClear)"
        ],
        "access_required": null,
        "timed_required": false,
        "timing_constraint": null,
        "error_responses": [],
        "spec_reference": "Section 2.11.8.11 AllClear Event"
      },
      {
        "id": "T_BatteryWarning",
        "from_state": "Normal",
        "to_state": "BatteryAlert_Warning",
        "trigger": {
          "type": "internal_detection",
          "name": "BatteryLowDetected",
          "command_id": null
        },
        "guard_condition": "BatteryAlert_sensor == Warning",
        "actions": [
          "BatteryAlert := Warning",
          "ExpressedState := BatteryAlert",
          "generate_event(LowBattery, {AlarmSeverityLevel: Warning})"
        ],
        "access_required": null,
        "timed_required": false,
        "timing_constraint": null,
        "error_responses": [],
        "spec_reference": "Section 2.11.8.3 LowBattery Event"
      },
      {
        "id": "T_BatteryCritical",
        "from_state": "Normal",
        "to_state": "BatteryAlert_Critical",
        "trigger": {
          "type": "internal_detection",
          "name": "BatteryCriticalDetected",
          "command_id": null
        },
        "guard_condition": "BatteryAlert_sensor == Critical",
        "actions": [
          "BatteryAlert := Critical",
          "ExpressedState := BatteryAlert",
          "generate_event(LowBattery, {AlarmSeverityLevel: Critical})"
        ],
        "access_required": null,
        "timed_required": false,
        "timing_constraint": null,
        "error_responses": [],
        "spec_reference": "Section 2.11.8.3 LowBattery Event"
      },
      {
        "id": "T_BatteryEscalate",
        "from_state": "BatteryAlert_Warning",
        "to_state": "BatteryAlert_Critical",
        "trigger": {
          "type": "internal_detection",
          "name": "BatteryCriticalDetected",
          "command_id": null
        },
        "guard_condition": "BatteryAlert_sensor == Critical",
        "actions": [
          "BatteryAlert := Critical",
          "generate_event(LowBattery, {AlarmSeverityLevel: Critical})"
        ],
        "access_required": null,
        "timed_required": false,
        "timing_constraint": null,
        "error_responses": [],
        "spec_reference": "Section 2.11.8.3 LowBattery Event - escalation"
      },
      {
        "id": "T_SelfTestRequest_Success",
        "from_state": "Normal",
        "to_state": "Testing",
        "trigger": {
          "type": "command",
          "name": "SelfTestRequest",
          "command_id": "0x00"
        },
        "guard_condition": "ExpressedState == Normal",
        "actions": ["TestInProgress := true", "ExpressedState := Testing"],
        "access_required": "O",
        "timed_required": false,
        "timing_constraint": null,
        "error_responses": [
          {
            "condition": "ExpressedState IN [SmokeAlarm, COAlarm, Testing, InterconnectSmoke, InterconnectCO]",
            "status_code": "BUSY",
            "description": "Device already in alarm or testing state, self-test not allowed"
          }
        ],
        "spec_reference": "Section 2.11.7.1 SelfTestRequest Command"
      },
      {
        "id": "T_SelfTestRequest_Busy",
        "from_state": "*",
        "to_state": "*",
        "trigger": {
          "type": "command",
          "name": "SelfTestRequest",
          "command_id": "0x00"
        },
        "guard_condition": "ExpressedState IN [SmokeAlarm, COAlarm, Testing, InterconnectSmoke, InterconnectCO]",
        "actions": ["return BUSY"],
        "access_required": "O",
        "timed_required": false,
        "timing_constraint": null,
        "error_responses": [
          {
            "condition": "Device in alarm or already testing",
            "status_code": "BUSY",
            "description": "SelfTestRequest rejected when ExpressedState is any of: SmokeAlarm, COAlarm, Testing, InterconnectSmoke, InterconnectCO"
          }
        ],
        "spec_reference": "Section 2.11.7.1 SelfTestRequest Command - SHALL return status code BUSY"
      },
      {
        "id": "T_SelfTestComplete_NoFault",
        "from_state": "Testing",
        "to_state": "Normal",
        "trigger": {
          "type": "internal_completion",
          "name": "SelfTestCompleted",
          "command_id": null
        },
        "guard_condition": "no_faults_detected && no_alarms_active",
        "actions": [
          "TestInProgress := false",
          "ExpressedState := Normal",
          "generate_event(SelfTestComplete)"
        ],
        "access_required": null,
        "timed_required": false,
        "timing_constraint": null,
        "error_responses": [],
        "spec_reference": "Section 2.11.7.1/2.11.8.6 SelfTestComplete Event"
      },
      {
        "id": "T_SelfTestComplete_FaultDetected",
        "from_state": "Testing",
        "to_state": "HardwareFault",
        "trigger": {
          "type": "internal_completion",
          "name": "SelfTestCompletedWithFault",
          "command_id": null
        },
        "guard_condition": "hardware_fault_detected",
        "actions": [
          "TestInProgress := false",
          "HardwareFaultAlert := true",
          "ExpressedState := HardwareFault",
          "generate_event(SelfTestComplete)",
          "generate_event(HardwareFault)"
        ],
        "access_required": null,
        "timed_required": false,
        "timing_constraint": null,
        "error_responses": [],
        "spec_reference": "Section 2.11.7.1 - faults identified during test SHALL be reflected in appropriate attributes and events"
      },
      {
        "id": "T_HardwareFaultDetected",
        "from_state": "Normal",
        "to_state": "HardwareFault",
        "trigger": {
          "type": "internal_detection",
          "name": "HardwareFaultDetected",
          "command_id": null
        },
        "guard_condition": "hardware_fault_condition == true",
        "actions": [
          "HardwareFaultAlert := true",
          "ExpressedState := HardwareFault",
          "generate_event(HardwareFault)"
        ],
        "access_required": null,
        "timed_required": false,
        "timing_constraint": null,
        "error_responses": [],
        "spec_reference": "Section 2.11.8.4 HardwareFault Event"
      },
      {
        "id": "T_CriticalContamination",
        "from_state": "Normal",
        "to_state": "HardwareFault",
        "trigger": {
          "type": "internal_detection",
          "name": "CriticalContaminationDetected",
          "command_id": null
        },
        "guard_condition": "ContaminationState_sensor == Critical && Feature_SMOKE == true",
        "actions": [
          "ContaminationState := Critical",
          "HardwareFaultAlert := true",
          "ExpressedState := HardwareFault",
          "generate_event(HardwareFault)"
        ],
        "access_required": null,
        "timed_required": false,
        "timing_constraint": null,
        "error_responses": [],
        "spec_reference": "Section 2.11.5.6.4 Critical contamination SHALL also be reflected as a HardwareFault"
      },
      {
        "id": "T_ExpiryDateReached",
        "from_state": "Normal",
        "to_state": "EndOfService",
        "trigger": {
          "type": "timer",
          "name": "ExpiryDateTimer",
          "command_id": null
        },
        "guard_condition": "current_time >= ExpiryDate",
        "actions": [
          "EndOfServiceAlert := Expired",
          "ExpressedState := EndOfService",
          "generate_event(EndOfService)"
        ],
        "access_required": null,
        "timed_required": false,
        "timing_constraint": "MAY be delayed by up to 24 hours for timezone alignment",
        "error_responses": [],
        "spec_reference": "Section 2.11.6.13/2.11.8.5 ExpiryDate and EndOfService Event"
      },
      {
        "id": "T_InterconnectSmoke_Warning",
        "from_state": "Normal",
        "to_state": "InterconnectSmoke_Warning",
        "trigger": {
          "type": "interconnect_signal",
          "name": "InterconnectSmokeAlarmReceived",
          "command_id": null
        },
        "guard_condition": "Feature_SMOKE == true && interconnect_smoke_severity == Warning",
        "actions": [
          "InterconnectSmokeAlarm := Warning",
          "ExpressedState := InterconnectSmoke",
          "generate_event(InterconnectSmokeAlarm, {AlarmSeverityLevel: Warning})"
        ],
        "access_required": null,
        "timed_required": false,
        "timing_constraint": null,
        "error_responses": [],
        "spec_reference": "Section 2.11.8.9 InterconnectSmokeAlarm Event"
      },
      {
        "id": "T_InterconnectSmoke_Critical",
        "from_state": "Normal",
