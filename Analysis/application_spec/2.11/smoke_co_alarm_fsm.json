        "location": "Section 2.11.6.5",
        "gap_type": "missing_constraint",
        "description": "No maximum mute duration defined - device could remain muted indefinitely",
        "security_impact": "User could mute Warning alarm and never be alerted if condition escalates after mute"
      },
      {
        "location": "Section 2.11.7.1",
        "gap_type": "missing_constraint",
        "description": "No maximum self-test duration or timeout defined",
        "security_impact": "Device could remain stuck in Testing state, unable to detect hazards"
      },
      {
        "location": "Section 2.11.7.1",
        "gap_type": "missing_constraint",
        "description": "No rate limiting on SelfTestRequest command",
        "security_impact": "Attacker with Operate privilege could drain battery via repeated self-tests"
      },
