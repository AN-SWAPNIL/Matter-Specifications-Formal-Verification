theory Test_Simple
begin

builtins: hashing

functions: SUCCESS/0

// Initialization
rule Server_Init:
    [ Fr(~endpoint_id) ]
    --[ ServerInit(~endpoint_id) ]->
    [
        !Server(~endpoint_id),
        ServerState(~endpoint_id, 'BaseOff'),
        Out(~endpoint_id)
    ]

// Transition: BaseOff -> BaseOn
rule On_BaseOff_to_BaseOn:
    [
        ServerState(endpoint, 'BaseOff'),
        In(<'On_Request', endpoint>),
        In(caller),
        !Server(endpoint)
    ]
    --[
        OnCommand(endpoint),
        StateTransition(endpoint, 'BaseOff', 'BaseOn')
    ]->
    [
        ServerState(endpoint, 'BaseOn'),
        Out(<'On_Response', SUCCESS>),
        !Server(endpoint)
    ]

// Transition: BaseOn -> BaseOff
rule Off_BaseOn_to_BaseOff:
    [
        ServerState(endpoint, 'BaseOn'),
        In(<'Off_Request', endpoint>),
        In(caller),
        !Server(endpoint)
    ]
    --[
        OffCommand(endpoint),
        StateTransition(endpoint, 'BaseOn', 'BaseOff')
    ]->
    [
        ServerState(endpoint, 'BaseOff'),
        Out(<'Off_Response', SUCCESS>),
        !Server(endpoint)
    ]

// Lemmas
lemma server_init_reachable:
    exists-trace
    "Ex endpoint #i. ServerInit(endpoint)@i"

lemma state_BaseOn_reachable:
    exists-trace
    "Ex endpoint from_state #i. StateTransition(endpoint, from_state, 'BaseOn')@i"

lemma state_BaseOff_reachable:
    exists-trace
    "Ex endpoint from_state #i. StateTransition(endpoint, from_state, 'BaseOff')@i"

end
