{
  "cluster_fsm": {
    "cluster_name": "Boolean State Configuration",
    "cluster_id": "0x0080",
    "pics_code": "BOOLCFG",
    "spec_reference": "Matter 1.5 Application Cluster Specification, Section 1.8, Pages 90-96",
    "revision": 1,

    "features": [
      {
        "bit": 0,
        "code": "VIS",
        "name": "Visual",
        "conformance": "O",
        "description": "Supports visual alarms (e.g., blinking light)",
        "affects_states": [
          "Alarm_Visual_Active",
          "Alarm_Visual_Suppressed",
          "Alarm_Visual_Disabled"
        ],
        "affects_transitions": [
          "T_Trigger_Visual",
          "T_Clear_Visual",
          "T_Suppress_Visual",
          "T_Enable_Visual",
          "T_Disable_Visual"
        ]
      },
      {
        "bit": 1,
        "code": "AUD",
        "name": "Audible",
        "conformance": "O",
        "description": "Supports audible alarms (e.g., buzzer, speaker)",
        "affects_states": [
          "Alarm_Audible_Active",
          "Alarm_Audible_Suppressed",
          "Alarm_Audible_Disabled"
        ],
        "affects_transitions": [
          "T_Trigger_Audible",
          "T_Clear_Audible",
          "T_Suppress_Audible",
          "T_Enable_Audible",
          "T_Disable_Audible"
        ]
      },
      {
        "bit": 2,
        "code": "SPRS",
        "name": "AlarmSuppress",
        "conformance": "[VIS | AUD]",
        "description": "Supports ability to suppress or acknowledge alarms. Requires at least one of VIS or AUD.",
        "affects_states": [
          "Alarm_Visual_Suppressed",
          "Alarm_Audible_Suppressed"
        ],
        "affects_transitions": [
          "T_SuppressAlarm_Success",
          "T_SuppressAlarm_Fail_NotActive",
          "T_SuppressAlarm_Fail_Unsupported"
        ]
      },
      {
        "bit": 3,
        "code": "SENSLVL",
        "name": "SensitivityLevel",
        "conformance": "O",
        "description": "Supports ability to set sensor sensitivity level",
        "affects_states": [],
        "affects_transitions": [
          "T_SetSensitivity_Success",
          "T_SetSensitivity_Fail_Constraint"
        ]
      }
    ],

    "dependencies": [
      {
        "cluster": "Boolean State (0x0045)",
        "relationship": "SHOULD_COEXIST",
        "description": "This configuration cluster is used to configure a boolean sensor. The Boolean State cluster provides the StateValue attribute that represents the actual sensor state."
      }
    ],

    "data_types": [
      {
        "name": "AlarmModeBitmap",
        "base_type": "map8",
        "bits": [
          { "bit": 0, "name": "Visual", "conformance": "VIS" },
          { "bit": 1, "name": "Audible", "conformance": "AUD" }
        ]
      },
      {
        "name": "SensorFaultBitmap",
        "base_type": "map16",
        "bits": [{ "bit": 0, "name": "GeneralFault", "conformance": "M" }]
      }
    ],

    "attributes": [
      {
        "id": "0x0000",
        "name": "CurrentSensitivityLevel",
        "type": "uint8",
        "constraint": "max (SupportedSensitivityLevels - 1)",
        "quality": "N",
        "access": "RW VO",
        "conformance": "SENSLVL",
        "state_defining": false,
        "description": "Currently selected sensitivity level. 0 = lowest sensitivity."
      },
      {
        "id": "0x0001",
        "name": "SupportedSensitivityLevels",
        "type": "uint8",
        "constraint": "2 to 10",
        "quality": "F",
        "access": "R V",
        "conformance": "SENSLVL",
        "state_defining": false,
        "description": "Number of supported sensitivity levels (2-10)."
      },
      {
        "id": "0x0002",
        "name": "DefaultSensitivityLevel",
        "type": "uint8",
        "constraint": "max (SupportedSensitivityLevels - 1)",
        "quality": "F",
        "access": "R V",
        "conformance": "[SENSLVL]",
        "state_defining": false,
        "description": "Default sensitivity level selected by manufacturer."
      },
      {
        "id": "0x0003",
        "name": "AlarmsActive",
        "type": "AlarmModeBitmap",
        "constraint": "all",
        "quality": "",
        "access": "R V",
        "conformance": "VIS | AUD",
        "state_defining": true,
        "description": "Which alarm modes are currently active (triggered)."
      },
      {
        "id": "0x0004",
        "name": "AlarmsSuppressed",
        "type": "AlarmModeBitmap",
        "constraint": "all",
        "quality": "",
        "access": "R V",
        "conformance": "SPRS",
        "state_defining": true,
        "description": "Which alarm modes are currently suppressed."
      },
      {
        "id": "0x0005",
        "name": "AlarmsEnabled",
        "type": "AlarmModeBitmap",
        "constraint": "all",
        "quality": "N",
        "access": "R V",
        "conformance": "[VIS | AUD]",
        "state_defining": true,
        "description": "Which alarm modes are enabled (will emit if triggered)."
      },
      {
        "id": "0x0006",
        "name": "AlarmsSupported",
        "type": "AlarmModeBitmap",
        "constraint": "all",
        "quality": "F",
        "access": "R V",
        "conformance": "VIS | AUD",
        "state_defining": false,
        "description": "Which alarm modes are supported by the device."
      },
      {
        "id": "0x0007",
        "name": "SensorFault",
        "type": "SensorFaultBitmap",
        "constraint": "all",
        "quality": "",
        "fallback": "0",
        "access": "R V",
        "conformance": "O",
        "state_defining": true,
        "description": "Any faults registered by the device."
      }
    ],

    "states": [
      {
        "name": "Idle_NoAlarm",
        "description": "Sensor not triggered, no alarms active, system in idle state",
        "is_initial": true,
        "invariants": [
          "AlarmsActive == 0x00",
          "AlarmsSuppressed == 0x00",
          "SensorFault == 0x00"
        ],
        "state_attributes": {
          "AlarmsActive": "0x00",
          "AlarmsSuppressed": "0x00",
          "SensorFault": "0x00"
        },
        "feature_requirements": ["VIS == true || AUD == true"],
        "safety_implications": "None - sensor idle and monitoring"
      },
      {
        "name": "Alarm_Visual_Active",
        "description": "Sensor triggered, visual alarm is actively alerting (blinking/flashing)",
        "is_initial": false,
        "invariants": [
          "AlarmsActive.Visual == 1",
          "AlarmsEnabled.Visual == 1",
          "AlarmsSuppressed.Visual == 0",
          "AlarmsSupported.Visual == 1"
        ],
        "state_attributes": {
          "AlarmsActive": "0x01 (Visual bit set)",
          "AlarmsSuppressed": "0x00",
          "AlarmsEnabled": "0x01"
        },
        "feature_requirements": ["VIS == true"],
        "safety_implications": "Physical visual indication active - user should be aware of sensor trigger"
      },
      {
        "name": "Alarm_Audible_Active",
        "description": "Sensor triggered, audible alarm is actively alerting (buzzer/speaker)",
        "is_initial": false,
        "invariants": [
          "AlarmsActive.Audible == 1",
          "AlarmsEnabled.Audible == 1",
          "AlarmsSuppressed.Audible == 0",
          "AlarmsSupported.Audible == 1"
        ],
        "state_attributes": {
          "AlarmsActive": "0x02 (Audible bit set)",
          "AlarmsSuppressed": "0x00",
          "AlarmsEnabled": "0x02"
        },
        "feature_requirements": ["AUD == true"],
        "safety_implications": "Physical audible indication active - user should hear alarm"
      },
      {
        "name": "Alarm_Both_Active",
        "description": "Sensor triggered, both visual and audible alarms active",
        "is_initial": false,
        "invariants": [
          "AlarmsActive == 0x03",
          "AlarmsEnabled.Visual == 1 && AlarmsEnabled.Audible == 1",
          "AlarmsSuppressed == 0x00"
        ],
        "state_attributes": {
          "AlarmsActive": "0x03 (Both bits set)",
          "AlarmsSuppressed": "0x00",
          "AlarmsEnabled": "0x03"
        },
        "feature_requirements": ["VIS == true && AUD == true"],
        "safety_implications": "Maximum alerting - both visual and audible physical output"
      },
      {
        "name": "Alarm_Visual_Suppressed",
        "description": "Sensor still triggered, visual alarm suppressed (no physical output but logically active)",
        "is_initial": false,
        "invariants": [
          "AlarmsActive.Visual == 1",
          "AlarmsSuppressed.Visual == 1",
          "AlarmsEnabled.Visual == 1"
        ],
        "state_attributes": {
          "AlarmsActive": "0x01",
          "AlarmsSuppressed": "0x01",
          "AlarmsEnabled": "0x01"
        },
        "feature_requirements": ["VIS == true && SPRS == true"],
        "safety_implications": "Visual alarm silenced - user acknowledged but hazard may persist"
      },
      {
        "name": "Alarm_Audible_Suppressed",
        "description": "Sensor still triggered, audible alarm suppressed (no sound but logically active)",
        "is_initial": false,
        "invariants": [
          "AlarmsActive.Audible == 1",
          "AlarmsSuppressed.Audible == 1",
          "AlarmsEnabled.Audible == 1"
        ],
        "state_attributes": {
          "AlarmsActive": "0x02",
          "AlarmsSuppressed": "0x02",
          "AlarmsEnabled": "0x02"
        },
        "feature_requirements": ["AUD == true && SPRS == true"],
        "safety_implications": "Audible alarm silenced - user acknowledged but hazard may persist"
      },
      {
        "name": "Alarm_Both_Suppressed",
        "description": "Sensor still triggered, both alarms suppressed",
        "is_initial": false,
        "invariants": ["AlarmsActive == 0x03", "AlarmsSuppressed == 0x03"],
        "state_attributes": {
          "AlarmsActive": "0x03",
          "AlarmsSuppressed": "0x03",
          "AlarmsEnabled": "0x03"
        },
        "feature_requirements": ["VIS == true && AUD == true && SPRS == true"],
        "safety_implications": "All alarms silenced but hazard still present"
      },
      {
        "name": "Alarm_Visual_Disabled",
        "description": "Visual alarm mode is disabled - will not trigger even if sensor triggered",
        "is_initial": false,
        "invariants": [
          "AlarmsEnabled.Visual == 0",
          "AlarmsActive.Visual == 0",
          "AlarmsSuppressed.Visual == 0"
        ],
        "state_attributes": {
          "AlarmsEnabled": "Visual bit cleared"
        },
        "feature_requirements": ["VIS == true"],
        "safety_implications": "User will NOT receive visual alert for sensor triggers"
      },
      {
        "name": "Alarm_Audible_Disabled",
        "description": "Audible alarm mode is disabled - will not trigger even if sensor triggered",
        "is_initial": false,
        "invariants": [
          "AlarmsEnabled.Audible == 0",
          "AlarmsActive.Audible == 0",
          "AlarmsSuppressed.Audible == 0"
        ],
        "state_attributes": {
          "AlarmsEnabled": "Audible bit cleared"
        },
        "feature_requirements": ["AUD == true"],
        "safety_implications": "User will NOT receive audible alert for sensor triggers"
      },
      {
        "name": "All_Alarms_Disabled",
        "description": "All alarm modes disabled - no alerts even if sensor triggered",
        "is_initial": false,
        "invariants": [
          "AlarmsEnabled == 0x00",
          "AlarmsActive == 0x00",
          "AlarmsSuppressed == 0x00"
        ],
        "state_attributes": {
          "AlarmsEnabled": "0x00",
          "AlarmsActive": "0x00",
          "AlarmsSuppressed": "0x00"
        },
        "feature_requirements": ["VIS == true || AUD == true"],
        "safety_implications": "CRITICAL: No physical alerts will occur regardless of sensor state"
      },
      {
        "name": "Sensor_Fault",
        "description": "Sensor has detected a hardware or operational fault",
        "is_initial": false,
        "invariants": ["SensorFault != 0x0000"],
        "state_attributes": {
          "SensorFault": "Non-zero (GeneralFault bit set)"
        },
        "feature_requirements": [],
        "safety_implications": "Sensor may not be functioning correctly - false negatives possible"
      }
    ],

    "transitions": [
      {
        "id": "T001_Trigger_Visual",
        "from_state": "Idle_NoAlarm",
        "to_state": "Alarm_Visual_Active",
        "trigger": {
          "type": "attribute_change",
          "name": "Sensor_Trigger",
          "description": "Boolean State sensor triggers (StateValue changes to triggered condition)"
        },
        "guard_condition": "Feature_VIS == true && AlarmsEnabled.Visual == 1 && AlarmsSupported.Visual == 1",
        "actions": [
          "AlarmsActive.Visual := 1",
          "generate_event(AlarmsStateChanged, {AlarmsActive: current, AlarmsSuppressed: current})"
        ],
        "access_required": "N/A (internal)",
        "timed_required": false,
        "spec_reference": "Section 1.8.6.4 'When the sensor is no longer triggered, this attribute SHALL be set to the inactive state'"
      },
      {
        "id": "T002_Trigger_Audible",
        "from_state": "Idle_NoAlarm",
        "to_state": "Alarm_Audible_Active",
        "trigger": {
          "type": "attribute_change",
          "name": "Sensor_Trigger",
          "description": "Boolean State sensor triggers"
        },
        "guard_condition": "Feature_AUD == true && AlarmsEnabled.Audible == 1 && AlarmsSupported.Audible == 1",
        "actions": [
          "AlarmsActive.Audible := 1",
          "generate_event(AlarmsStateChanged, {AlarmsActive: current, AlarmsSuppressed: current})"
        ],
        "access_required": "N/A (internal)",
        "timed_required": false,
        "spec_reference": "Section 1.8.6.4"
      },
      {
        "id": "T003_Trigger_Both",
        "from_state": "Idle_NoAlarm",
        "to_state": "Alarm_Both_Active",
        "trigger": {
          "type": "attribute_change",
          "name": "Sensor_Trigger",
          "description": "Boolean State sensor triggers with both alarm modes enabled"
        },
        "guard_condition": "Feature_VIS == true && Feature_AUD == true && AlarmsEnabled == 0x03",
        "actions": [
          "AlarmsActive := 0x03",
          "generate_event(AlarmsStateChanged, {AlarmsActive: 0x03, AlarmsSuppressed: 0x00})"
        ],
        "access_required": "N/A (internal)",
        "timed_required": false,
        "spec_reference": "Section 1.8.6.4"
      },
      {
        "id": "T004_Clear_Visual",
        "from_state": "Alarm_Visual_Active",
        "to_state": "Idle_NoAlarm",
        "trigger": {
          "type": "attribute_change",
          "name": "Sensor_Clear",
          "description": "Boolean State sensor no longer triggered"
        },
        "guard_condition": "true",
        "actions": [
          "AlarmsActive.Visual := 0",
          "AlarmsSuppressed.Visual := 0",
          "generate_event(AlarmsStateChanged, {AlarmsActive: 0x00, AlarmsSuppressed: 0x00})"
        ],
        "access_required": "N/A (internal)",
        "timed_required": false,
        "spec_reference": "Section 1.8.6.4 'When sensor is no longer triggered, this attribute SHALL be set to the inactive state' and Section 1.8.6.5 same for suppressed"
      },
      {
        "id": "T005_Clear_Audible",
        "from_state": "Alarm_Audible_Active",
        "to_state": "Idle_NoAlarm",
        "trigger": {
          "type": "attribute_change",
          "name": "Sensor_Clear",
          "description": "Boolean State sensor no longer triggered"
        },
        "guard_condition": "true",
        "actions": [
          "AlarmsActive.Audible := 0",
          "AlarmsSuppressed.Audible := 0",
          "generate_event(AlarmsStateChanged, {AlarmsActive: 0x00, AlarmsSuppressed: 0x00})"
        ],
        "access_required": "N/A (internal)",
        "timed_required": false,
        "spec_reference": "Section 1.8.6.4, 1.8.6.5"
      },
      {
        "id": "T006_Clear_Both",
        "from_state": "Alarm_Both_Active",
        "to_state": "Idle_NoAlarm",
        "trigger": {
          "type": "attribute_change",
          "name": "Sensor_Clear",
          "description": "Boolean State sensor no longer triggered"
        },
        "guard_condition": "true",
        "actions": [
          "AlarmsActive := 0x00",
          "AlarmsSuppressed := 0x00",
          "generate_event(AlarmsStateChanged, {AlarmsActive: 0x00, AlarmsSuppressed: 0x00})"
        ],
        "access_required": "N/A (internal)",
        "timed_required": false,
        "spec_reference": "Section 1.8.6.4, 1.8.6.5"
      },
      {
        "id": "T007_Clear_Suppressed_Visual",
        "from_state": "Alarm_Visual_Suppressed",
        "to_state": "Idle_NoAlarm",
        "trigger": {
          "type": "attribute_change",
          "name": "Sensor_Clear",
          "description": "Boolean State sensor no longer triggered"
        },
        "guard_condition": "true",
        "actions": [
          "AlarmsActive.Visual := 0",
          "AlarmsSuppressed.Visual := 0",
          "generate_event(AlarmsStateChanged, {AlarmsActive: 0x00, AlarmsSuppressed: 0x00})"
        ],
        "access_required": "N/A (internal)",
        "timed_required": false,
        "spec_reference": "Section 1.8.6.5 'When sensor is no longer triggered, this attribute SHALL be set to the unsuppressed state'"
      },
      {
        "id": "T008_Clear_Suppressed_Audible",
        "from_state": "Alarm_Audible_Suppressed",
        "to_state": "Idle_NoAlarm",
        "trigger": {
          "type": "attribute_change",
          "name": "Sensor_Clear",
          "description": "Boolean State sensor no longer triggered"
        },
        "guard_condition": "true",
        "actions": [
          "AlarmsActive.Audible := 0",
          "AlarmsSuppressed.Audible := 0",
          "generate_event(AlarmsStateChanged, {AlarmsActive: 0x00, AlarmsSuppressed: 0x00})"
        ],
        "access_required": "N/A (internal)",
        "timed_required": false,
        "spec_reference": "Section 1.8.6.5"
      },
      {
        "id": "T009_Clear_Suppressed_Both",
        "from_state": "Alarm_Both_Suppressed",
        "to_state": "Idle_NoAlarm",
        "trigger": {
          "type": "attribute_change",
          "name": "Sensor_Clear",
          "description": "Boolean State sensor no longer triggered"
        },
        "guard_condition": "true",
        "actions": [
          "AlarmsActive := 0x00",
          "AlarmsSuppressed := 0x00",
          "generate_event(AlarmsStateChanged, {AlarmsActive: 0x00, AlarmsSuppressed: 0x00})"
        ],
        "access_required": "N/A (internal)",
        "timed_required": false,
        "spec_reference": "Section 1.8.6.5"
      },
      {
        "id": "T010_SuppressAlarm_Visual_Success",
        "from_state": "Alarm_Visual_Active",
        "to_state": "Alarm_Visual_Suppressed",
        "trigger": {
          "type": "command",
          "name": "SuppressAlarm",
          "command_id": "0x00"
        },
        "guard_condition": "Feature_SPRS == true && AlarmsToSuppress.Visual == 1 && AlarmsActive.Visual == 1 && AlarmsSupported.Visual == 1 && AlarmsEnabled.Visual == 1",
        "actions": [
          "AlarmsSuppressed.Visual := 1",
          "generate_event(AlarmsStateChanged, {AlarmsActive: current, AlarmsSuppressed: current})",
          "return SUCCESS"
        ],
        "access_required": "O",
        "timed_required": false,
        "timing_constraint": null,
        "error_responses": [],
        "spec_reference": "Section 1.8.7.1.2 'For the valid bits in the AlarmsToSuppress field, the device SHALL suppress the specified alarm modes'"
      },
      {
        "id": "T011_SuppressAlarm_Audible_Success",
        "from_state": "Alarm_Audible_Active",
        "to_state": "Alarm_Audible_Suppressed",
        "trigger": {
          "type": "command",
          "name": "SuppressAlarm",
          "command_id": "0x00"
        },
        "guard_condition": "Feature_SPRS == true && AlarmsToSuppress.Audible == 1 && AlarmsActive.Audible == 1 && AlarmsSupported.Audible == 1 && AlarmsEnabled.Audible == 1",
        "actions": [
          "AlarmsSuppressed.Audible := 1",
          "generate_event(AlarmsStateChanged, {AlarmsActive: current, AlarmsSuppressed: current})",
          "return SUCCESS"
        ],
        "access_required": "O",
        "timed_required": false,
        "timing_constraint": null,
        "error_responses": [],
        "spec_reference": "Section 1.8.7.1.2"
      },
      {
        "id": "T012_SuppressAlarm_Both_Success",
        "from_state": "Alarm_Both_Active",
        "to_state": "Alarm_Both_Suppressed",
        "trigger": {
          "type": "command",
          "name": "SuppressAlarm",
          "command_id": "0x00"
        },
        "guard_condition": "Feature_SPRS == true && AlarmsToSuppress == 0x03 && AlarmsActive == 0x03 && AlarmsSupported == 0x03",
        "actions": [
          "AlarmsSuppressed := 0x03",
          "generate_event(AlarmsStateChanged, {AlarmsActive: 0x03, AlarmsSuppressed: 0x03})",
          "return SUCCESS"
        ],
        "access_required": "O",
        "timed_required": false,
        "timing_constraint": null,
        "error_responses": [],
        "spec_reference": "Section 1.8.7.1.2"
      },
      {
        "id": "T013_SuppressAlarm_Fail_Unsupported",
        "from_state": "*",
        "to_state": "*",
        "trigger": {
          "type": "command",
          "name": "SuppressAlarm",
          "command_id": "0x00"
        },
        "guard_condition": "(AlarmsToSuppress & ~AlarmsSupported) != 0",
        "actions": ["return CONSTRAINT_ERROR"],
        "access_required": "O",
        "timed_required": false,
        "timing_constraint": null,
        "error_responses": [
          {
            "condition": "Any requested alarm mode is not supported",
            "status_code": "CONSTRAINT_ERROR",
            "description": "AlarmsToSuppress contains bits for unsupported alarm modes"
          }
        ],
        "spec_reference": "Section 1.8.7.1.2 'If any of the requested alarm modes are not supported this command SHALL be ignored and the server SHALL return an CONSTRAINT_ERROR status code'"
      },
      {
        "id": "T014_SuppressAlarm_Fail_NotActive",
        "from_state": "*",
        "to_state": "*",
        "trigger": {
          "type": "command",
          "name": "SuppressAlarm",
          "command_id": "0x00"
        },
        "guard_condition": "(AlarmsToSuppress & AlarmsSupported) != 0 && (AlarmsToSuppress & AlarmsActive & AlarmsEnabled) != AlarmsToSuppress",
        "actions": ["return INVALID_IN_STATE"],
        "access_required": "O",
        "timed_required": false,
        "timing_constraint": null,
        "error_responses": [
          {
            "condition": "Any requested alarm mode is not active (sensor not triggered or alarm disabled)",
            "status_code": "INVALID_IN_STATE",
            "description": "Cannot suppress inactive alarm"
          }
        ],
        "spec_reference": "Section 1.8.7.1.2 'If any of the requested alarm modes are not active, in case the sensor is not triggered or the alarm mode is disabled/not supported, this command SHALL be ignored and the server SHALL return an INVALID_IN_STATE status code'"
      },
      {
        "id": "T015_SuppressAlarm_AlreadySuppressed_Ignored",
        "from_state": "Alarm_Visual_Suppressed",
        "to_state": "Alarm_Visual_Suppressed",
        "trigger": {
          "type": "command",
          "name": "SuppressAlarm",
          "command_id": "0x00"
        },
        "guard_condition": "AlarmsToSuppress.Visual == 1 && AlarmsSuppressed.Visual == 1",
        "actions": ["return SUCCESS"],
        "access_required": "O",
        "timed_required": false,
        "timing_constraint": null,
        "error_responses": [],
        "spec_reference": "Section 1.8.7.1.2 'In the case an alarm is already suppressed and the specific bit is set in the AlarmsSuppressed attribute, the bit SHALL be ignored'"
      },
      {
        "id": "T016_EnableDisableAlarm_Enable_Visual",
        "from_state": "Alarm_Visual_Disabled",
        "to_state": "Idle_NoAlarm",
        "trigger": {
          "type": "command",
          "name": "EnableDisableAlarm",
          "command_id": "0x01"
        },
        "guard_condition": "AlarmsToEnableDisable.Visual == 1 && AlarmsSupported.Visual == 1 && !sensor_triggered",
        "actions": ["AlarmsEnabled.Visual := 1", "return SUCCESS"],
        "access_required": "O",
        "timed_required": false,
        "timing_constraint": null,
        "error_responses": [],
        "spec_reference": "Section 1.8.7.2.2 'If all the bits are valid, the value of the AlarmsEnabled attribute SHALL be set to the value of the AlarmsToEnableDisable field'"
      },
      {
        "id": "T017_EnableDisableAlarm_Enable_Visual_Triggered",
        "from_state": "Alarm_Visual_Disabled",
        "to_state": "Alarm_Visual_Active",
