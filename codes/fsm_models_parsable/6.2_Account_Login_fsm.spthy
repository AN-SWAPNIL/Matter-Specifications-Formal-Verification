    State(CurrentState, 'NoActiveAccount'),
    State(active_account, vnull),
    State(exists_node_binding, 'false')
  ]

rule Logout_ActiveAccount_WithNodeBindings_to_NoActiveAccount_35:
  [
    State(CurrentState, 'ActiveAccount_WithNodeBindings'),
    State(node_present, 'true'),
    State(logout_clears_all_nodes_for_account, 'true')
  ]
  --[ Logout() ]->
  [
    State(CurrentState, 'NoActiveAccount'),
    State(active_account, vnull),
    State(exists_node_binding, 'false')
  ]

rule Login_RateLimitExceeded_to_RateLimitExceeded_36:
  [
    State(CurrentState, 'RateLimitExceeded'),
    State(rate_limiter_too_many_unique_requests, 'true')
  ]
  --[ Login() ]->
  [
    State(CurrentState, 'RateLimitExceeded')
  ]

lemma init_reachable:
  exists-trace
  "Ex #i. State(CurrentState, 'NoActiveAccount') @i"

lemma state_exclusivity:
  "All s1 s2 #i #j. State(CurrentState, s1) @i & State(CurrentState, s2) @j & #i = #j ==> s1 = s2"


// Cluster-specific security properties
// NOTE: These lemmas reference predicates from the security model.
// They require corresponding action facts to be added to rules for verification.
// Uncomment and adapt after adding required action facts.

/*
lemma getsetuppin_rate_limit_enforced:
  // A GetSetupPIN request that is accepted must not violate the 10 unique requests per 10 minutes rate limit.
  "All scope #i. GetSetupPINAccepted(scope)@i ==> Ex #j. RateLimitWindowStarted(scope)@j & #j < #i"
*/

/*
lemma login_rate_limit_enforced:
  // A Login request that is accepted must not violate the 10 unique requests per 10 minutes rate limit.
  "All scope #i. LoginAccepted(scope)@i ==> Ex #j. RateLimitWindowStarted(scope)@j & #j < #i"
*/

/*
lemma temp_identifier_expiry_enforced_getsetuppin:
  // GetSetupPIN responses with non-empty SetupPIN require that the Temporary Account Identifier was not expired.
  "All temp_id setup_pin #i. GetSetupPINResponseSent(temp_id, setup_pin)@i & IsNonEmptySetupPIN(setup_pin) ==> TempIdNotExpired(temp_id)"
*/

/*
lemma temp_identifier_expiry_enforced_login:
  // Login success requires that the Temporary Account Identifier used was not expired.
  "All temp_id account #i. LoginSuccess(temp_id, account)@i ==> Ex #j. TempIdValidAtUse(temp_id)@j & #j < #i"
*/

/*
lemma login_requires_valid_setup_pin:
  // Any successful Login must be preceded by validation of a current active Setup PIN for that account.
  "All account #i. LoginSuccess(account)@i ==> Ex #j. SetupPINValidated(account)@j & #j < #i"
*/

/*
lemma getsetuppin_requires_account_match_for_non_empty_pin:
  // A non-empty SetupPIN in GetSetupPINResponse implies the requested and active accounts match and identifier is valid.
  "All temp_id setup_pin #i. GetSetupPINResponseSent(temp_id, setup_pin)@i & IsNonEmptySetupPIN(setup_pin) ==> AccountsMatchForTempId(temp_id)"
*/

/*
lemma getsetuppin_empty_pin_on_mismatch_or_invalid:
  // If accounts do not match or temp identifier is invalid, GetSetupPINResponse carries an empty SetupPIN.
  "All temp_id setup_pin #i. GetSetupPINResponseSent(temp_id, setup_pin)@i & AccountMismatchOrTempIdInvalid(temp_id) ==> IsEmptySetupPIN(setup_pin)"
*/

/*
lemma loggedout_triggers_access_revocation:
  // A LoggedOut event must cause the Fabric Admin to revoke access for the Node or all non-Admin Nodes to the Content App.
  "All node #i. LoggedOutEmitted(node)@i & TRUE ==> AccessRevokedForNodeOrAll(node)"
*/


end