theory LevelControl_0x0008_Matter_FSM
begin

/* 
 * Level Control Cluster (0x0008)
 * Auto-generated from FSM
 */

//========================================
// SECTION 1: Declarations
//========================================
builtins: hashing

functions:
  // Boolean values
  b_true/0, b_false/0,

  // State enumerations
  st_IdleOff/0,
  st_IdleOn/0,
  st_LevelTransitionOff/0,
  st_LevelTransitionOnBase/0,
  st_LevelTransitionOnWithOnOff/0,

  // Abstract RemainingTime values
  tv_zero/0,   // RemainingTime == 0
  tv_pos/0,    // RemainingTime > 0 (abstracted)

  // Feature flags (only Frequency modeled explicitly)
  f_FQ/0,

  // Abstract attribute values
  lvl_null/0,   // CurrentLevel == null (off cases allowed by FSM)
  lvl_min/0,
  lvl_mid/0,
  lvl_max/0,

  // Frequency values (abstract)
  fq_min/0,
  fq_mid/0,
  fq_max/0

//========================================
// SECTION 2: State Fact and Config
//========================================
// St(tid, State, OnOff, RemainingTime, CurrentLevel, CurrentFrequency, FeatureFQ)

//========================================
// SECTION 3: Initialization
//========================================
rule Init_LevelControl_FQ_Enabled:
  [ Fr(~tid) ]
--[ ClusterInit_LevelControl(~tid) ]->
  [ St(~tid, st_IdleOff, b_false, tv_zero, lvl_null, fq_mid, f_FQ),
    !Config_LevelControl(~tid, f_FQ) ]

//========================================
// SECTION 4: Environment Rules for Inputs
//========================================

// Environment can non-deterministically generate command and timer inputs
// for any existing LevelControl instance identified by tid.

rule Env_MoveToLevel:
  [ !Config_LevelControl(tid, f_FQ) ]
--[ ]->
  [ In_MoveToLevel(tid) ]

rule Env_MoveToLevel_ExecIfOffTrue:
  [ !Config_LevelControl(tid, f_FQ) ]
--[ ]->
  [ In_MoveToLevel_ExecIfOffTrue(tid) ]

rule Env_InternalTimerTick:
  [ !Config_LevelControl(tid, f_FQ) ]
--[ ]->
  [ In_InternalTimerTick(tid) ]

rule Env_InternalTimerTick_Final:
  [ !Config_LevelControl(tid, f_FQ) ]
--[ ]->
  [ In_InternalTimerTick_Final(tid) ]

rule Env_Move_RateZero:
  [ !Config_LevelControl(tid, f_FQ) ]
--[ ]->
  [ In_Move_RateZero(tid) ]

rule Env_Move_RatePos_ExecIfOffTrue:
  [ !Config_LevelControl(tid, f_FQ) ]
--[ ]->
  [ In_Move_RatePos_ExecIfOffTrue(tid) ]

rule Env_Move_RatePos:
  [ !Config_LevelControl(tid, f_FQ) ]
--[ ]->
