// ============================================================================
// Verification Lemmas
// ============================================================================

// Basic reachability - server can initialize
lemma server_init_reachable:
    exists-trace
    "Ex endpoint #i. ServerInit(endpoint)@i"


// Reachability: Content app has no active account associated
lemma state_NoActiveAccount_reachable:
    exists-trace
    "Ex endpoint from_state #i. StateTransition(endpoint, from_state, 'NoActiveAccount')@i"


// Reachability: Content app has an active account set
lemma state_ActiveAccount_reachable:
    exists-trace
    "Ex endpoint from_state #i. StateTransition(endpoint, from_state, 'ActiveAccount')@i"


// Reachability: Rate limit currently exceeded for some scope on this endpoint
lemma state_RateLimited_reachable:
    exists-trace
    "Ex endpoint from_state #i. StateTransition(endpoint, from_state, 'RateLimited')@i"


// ============================================================================
// Security Properties
// ============================================================================

// rate_limit_enforced_on_get_setup_pin: Any accepted GetSetupPIN request must be within an active rate limit window
// Source: timing: ≤10 unique GetSetupPIN requests per 10 minutes
// Type: safety
lemma rate_limit_enforced_on_get_setup_pin:
    "All endpoint scope #i. RateLimitOK(endpoint, scope)@i ==> Ex #j. RateLimitWindowActive(endpoint)@j & #j < #i"

// setup_pin_requires_valid_temp_id: Non-empty SetupPIN can only be returned if the Temporary Account Identifier was validated as not expired
// Source: GetSetupPIN effect_on_receipt: temp_id_not_expired check
// Type: authentication
lemma setup_pin_requires_valid_temp_id:
    "All endpoint setup_pin temp_id #i. SetupPINReturned(endpoint, temp_id, setup_pin)@i ==> TempIdValidated(temp_id)@i"

// login_requires_valid_credentials: LoginSuccess requires that temp_id is validated, account lookup succeeded, and SetupPIN is valid for that account
// Source: Login effect_on_receipt: temp_id_expired, lookup_account_by_temp_id, has_current_active_setup_pin
// Type: authentication
lemma login_requires_valid_credentials:
    "All account endpoint node temp_id #i. LoginSuccess(endpoint, temp_id, account, node)@i ==> LoginTempIdValidated(temp_id)@i & LoginAccountLookupSuccess(temp_id, account)@i & (Ex provided_pin. SetupPINValidated(account, provided_pin)@i)"

// logout_triggers_access_revocation: Any LoggedOutEvent for a node eventually leads to NodeAccessRevoked for that node and account
// Source: LoggedOut event summary: Fabric Admin SHALL remove access for the specified Node
// Type: authorization
lemma logout_triggers_access_revocation:
    "All account endpoint node #i. LoggedOutEvent(endpoint, node, account)@i ==> Ex #j. NodeAccessRevoked(endpoint, account, node)@j & #i < #j"

// account_activation_requires_policy: AccountActivated must only occur when PolicyAllowAutoLogin holds for that account
// Source: Login effect_on_receipt: if policy_allow_auto_login(acct) then set_active_account_for_content_app(acct)
// Type: authorization
lemma account_activation_requires_policy:
    "All account endpoint #i. AccountActivated(endpoint, account)@i ==> PolicyAllowAutoLogin(account)@i"

// node_access_granted_only_after_activation: NodeAccessGranted must only occur for accounts that are active on the endpoint
// Source: Login effect_on_receipt: grant_content_app_access_to_node(acct, Node) occurs only after set_active_account_for_content_app(acct)
// Type: authorization
lemma node_access_granted_only_after_activation:
    "All account endpoint node #i. NodeAccessGranted(endpoint, account, node)@i ==> Ex #j. AccountActivated(endpoint, account)@j & #j < #i"


end