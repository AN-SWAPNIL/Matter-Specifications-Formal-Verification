    StateTransition(~tid, st_TransitionActive, st_TransitionActive) ]->
  [ St(~tid, st_TransitionActive, fo, fl, b_false,
        cl_set, cl, rt,
        op, oo,
        cf_set, cf) ]

rule Cmd_SceneStore_Idle:
  [ St(~tid, st_Idle, fo, fl, fq,
        cl_set, cl, rt,
        op, oo,
        cf_set, cf) ]
--[ Command(~tid, 'SceneStore'),
    StateTransition(~tid, st_Idle, st_Idle) ]->
  [ St(~tid, st_Idle, fo, fl, fq,
        cl_set, cl, rt,
        op, oo,
        cf_set, cf) ]

