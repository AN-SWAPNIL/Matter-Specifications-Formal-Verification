// OnWithTimedOff discarded because AcceptOnlyWhenOn bit set and device is off
// Guard: onoff_control.AcceptOnlyWhenOn == 1 and OnOff == FALSE
// Guard: OnOff == FALSE
rule OnWithTimedOff_BaseOff_to_BaseOff_T21:
    [
        ServerState(endpoint, 'BaseOff'),
        !FeatureConfig(endpoint, 'LT', 'true'),
        In(<'OnWithTimedOff_Request', endpoint, onoff_control, on_time_field, off_wait_time_field>),
