    State(CurrentState, 'ActiveAccount_NoNodeBindings'),
    State(active_account, vaccount_from_temp_id),
    State(exists_node_binding, 'false')
  ]

rule Logout_NoActiveAccount_to_NoActiveAccount_31:
  [
    State(CurrentState, 'NoActiveAccount')
  ]
  --[ Logout() ]->
  [
    State(CurrentState, 'NoActiveAccount')
  ]

rule Logout_ActiveAccount_NoNodeBindings_to_NoActiveAccount_32:
  [
    State(CurrentState, 'ActiveAccount_NoNodeBindings')
  ]
  --[ Logout() ]->
  [
    State(CurrentState, 'NoActiveAccount'),
    State(active_account, vnull),
    State(exists_node_binding, 'false')
  ]

rule Logout_ActiveAccount_WithNodeBindings_to_ActiveAccount_WithNodeBindings_33:
  [
    State(CurrentState, 'ActiveAccount_WithNodeBindings'),
    State(node_present, 'true'),
    State(logout_clears_only_one_node, 'true'),
    State(other_nodes_remain, 'true')
  ]
  --[ Logout() ]->
  [
    State(CurrentState, 'ActiveAccount_WithNodeBindings'),
    State(exists_node_binding, 'true')
  ]

rule Logout_ActiveAccount_WithNodeBindings_to_NoActiveAccount_34:
