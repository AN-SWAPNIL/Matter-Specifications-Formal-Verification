          {
            "id": "0x01",
            "name": "Move",
            "direction": "client⇒server",
            "response": "DefaultResponse",
            "access": "O",
            "conformance": "M",
            "summary": "Continuous move",
            "timing": null,
            "fields": [
              {
                "id": "0",
