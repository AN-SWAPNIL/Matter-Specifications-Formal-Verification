// MoveToClosestFrequency selects the closest supported frequency and updates CurrentFrequency
// Guard: closest_supported_frequency_exists == TRUE
rule MoveToClosestFrequency_OnState_to_OnState_T_MoveToClosestFrequency_Success:
    [
        ServerState(endpoint, 'OnState'),
        !FeatureConfig(endpoint, 'FQ', 'true'),
        In(<'MoveToClosestFrequency_Request', endpoint, frequency>),
        In(selected_frequency),
        !Server(endpoint)
    ]
    --[
        MoveToClosestFrequency(endpoint),
        StateTransition(endpoint, 'OnState', 'OnState'),
        MoveToClosestFrequencyReceived(endpoint, frequency),
        ClosestFrequencySelected(endpoint, frequency, selected_frequency)
    ]->
    [
        ServerState(endpoint, 'OnState'),
        !FeatureConfig(endpoint, 'FQ', 'true'),
        Out(<'MoveToClosestFrequency_Response', SUCCESS>),
        !Server(endpoint)
    ]

// MoveToClosestFrequency responds with CONSTRAINT_ERROR when no suitable frequency can be approximated
// Guard: closest_supported_frequency_exists == FALSE
rule MoveToClosestFrequency_OnState_to_OnState_T_MoveToClosestFrequency_ConstraintError:
    [
        ServerState(endpoint, 'OnState'),
        !FeatureConfig(endpoint, 'FQ', 'true'),
        In(<'MoveToClosestFrequency_Request', endpoint, frequency>),
        !Server(endpoint)
    ]
    --[
        MoveToClosestFrequency(endpoint),
        StateTransition(endpoint, 'OnState', 'OnState'),
        MoveToClosestFrequencyReceived(endpoint, frequency),
        MoveToClosestFrequencyConstraintError(endpoint, frequency)
    ]->
    [
        ServerState(endpoint, 'OnState'),
        !FeatureConfig(endpoint, 'FQ', 'true'),
        Out(<'MoveToClosestFrequency_Response', SUCCESS>),
        !Server(endpoint)
    ]


// ============================================================================
// Verification Lemmas
// ============================================================================

// Basic reachability - server can initialize
lemma server_init_reachable:
    exists-trace
    "Ex endpoint #i. ServerInit(endpoint)@i"


// Startup reachability - power cycle can trigger startup behavior
lemma startup_reachable:
    exists-trace
    "Ex endpoint #i. Startup(endpoint)@i"


// Reachability: OnOff cluster off; CurrentLevel may be at any allowed level; physical device output off
lemma state_OffState_reachable:
    exists-trace
    "Ex endpoint from_state #i. StateTransition(endpoint, from_state, 'OffState')@i"


// Reachability: OnOff cluster on; physical device output on at CurrentLevel
lemma state_OnState_reachable:
    exists-trace
    "Ex endpoint from_state #i. StateTransition(endpoint, from_state, 'OnState')@i"


// ============================================================================
// CVE-2023-45956 Safety Properties (Level Control Cluster)
// Source: properties.json
// ============================================================================

/*
 * CVE-2023-45956: Move commands crash when rate=0 at boundary CurrentLevel
 * 
 * Affected Commands (from properties.json):
 *   - Move_up(rate=0) when CurrentLevel=1 (minimum)
 *   - Move_down(rate=0) when CurrentLevel=254 (maximum)
 *   - Move_up_OnOff(rate=0) when CurrentLevel=1
 *   - Move_down_OnOff(rate=0) when CurrentLevel=254
 *
 * Expected Behavior (per Matter spec):
 *   "If rate = 0, the command should be rejected as invalid."
 *   The spec rule Move_InvalidRateZero handles this correctly.
 *
 * Buggy Behavior (CVE):
 *   Devices crash instead of rejecting the command.
 *
 * Verification Strategy:
 *   These lemmas verify that the SPECIFICATION correctly prevents
 *   the vulnerability by ensuring rate=0 is always rejected.
 */

/*
 * LEMMA 1: Rate=0 is always detected and flagged
 * Verifies: The spec model has a path where MoveInvalidRateZero is triggered
 * Result: Should find a trace (reachability check)
 */
lemma cve_2023_45956_rate_zero_detected:
    exists-trace
    "Ex endpoint #i. MoveInvalidRateZero(endpoint)@i"

/*
 * LEMMA 2: Rate=0 rejection prevents further state changes
 * Verifies: After MoveInvalidRateZero, no state transition occurs
 * Result: Should VERIFY (spec correctly rejects invalid input)
 */
lemma cve_2023_45956_rate_zero_no_progression:
    "All endpoint #i. MoveInvalidRateZero(endpoint)@i
     ==> (Ex from_state #j. StateTransition(endpoint, from_state, from_state)@j & #j = #i)"

/*
 * LEMMA 3: Move command with rate=0 cannot change device state
 * Verifies: When rate=0 is sent, the OnOff state remains unchanged
 * Result: Should VERIFY if spec handles rate=0 correctly
 */
lemma cve_2023_45956_move_rate_zero_state_preserved:
    "All endpoint #i #j s1 s2. 
        MoveInvalidRateZero(endpoint)@i & StateTransition(endpoint, s1, s2)@j & #i < #j
     ==> s1 = s2"

/*
 * LEMMA 4: Step command with size=0 is also rejected (related property)
 * Verifies: StepInvalidSizeZero prevents invalid step commands
 * Result: Should find a trace (reachability check)
 */
lemma cve_2023_45956_step_size_zero_detected:
    exists-trace
    "Ex endpoint #i. StepInvalidSizeZero(endpoint)@i"

/*
 * LEMMA 5: No invalid Move command can reach a successful state transition
 * Verifies: MoveStarted only occurs when rate != 0 (implicitly)
 * This is the key safety property - crashes happen when invalid 
 * commands are NOT rejected and execution continues
 */
lemma cve_2023_45956_move_requires_valid_rate:
    "All endpoint current_level mode eff_rate #i #j. 
        MoveStarted(endpoint, current_level, mode, eff_rate)@i & MoveInvalidRateZero(endpoint)@j
     ==> #i < #j"


end