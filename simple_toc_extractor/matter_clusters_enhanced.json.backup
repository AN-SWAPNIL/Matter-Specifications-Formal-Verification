    {
      "cluster_info": {
        "cluster_name": "On/Off Cluster",
        "cluster_id": [
          {
            "id": "0x0006",
            "name": "On/Off",
            "summary": "Manages device on/off state. Supports Lighting (LT), DeadFrontBehavior (DF), and OffOnly features. Interacts with Level Control commands: `IF OnOff=FALSE THEN OnTime=0;` `IF OnOff=TRUE AND OnTime=0 THEN OffWaitTime=0;`"
          }
        ],
        "classification": [
          {
            "hierarchy": "Base",
            "role": "Application",
            "scope": "Endpoint",
            "pics_code": "OO",
            "summary": "Provides fundamental application-level control at the endpoint scope, managing the basic on/off state of a device. It's a base cluster for simple state management."
          }
        ],
        "revision_history": [
          {
            "revision": "1",
            "description": "Mandatory global ClusterRevision attribute added; CCB 1555",
            "date": null
          },
          {
            "revision": "2",
            "description": "ZLO 1.0: StartUpOnOff",
            "date": null
          },
          {
            "revision": "3",
            "description": "FeatureMap global attribute support with Level Control and Lighting feature",
            "date": null
          },
          {
            "revision": "4",
            "description": "New data model format and notation",
            "date": null
          },
          {
            "revision": "5",
            "description": "Addition of Dead Front behavior and associated FeatureMap entry",
            "date": null
          },
          {
            "revision": "6",
            "description": "Addition of OffOnly feature and associated FeatureMap entry",
            "date": null
          }
        ],
        "features": [
          {
            "bit": "0",
            "code": "LT",
            "name": "Lighting",
            "summary": "Behavior that supports lighting applications. On receipt of a Level Control cluster command that causes the OnOff attribute to be set to FALSE, the OnTime attribute SHALL be set to 0. On receipt of a Level Control cluster command that causes the OnOff attribute to be set to TRUE, if OnTime is 0, server SHALL set OffWaitTime to 0.",
            "conformance": "[!OFFONLY]",
            "dependencies": "NOT OFFONLY"
          },
          {
            "bit": "1",
            "code": "DF",
            "name": "DeadFrontBehavior",
            "summary": "Device has Dead Front behavior. When supported, device exhibits 'dead front' behavior when OnOff attribute is FALSE. Other clusters MAY respond with INVALID_IN_STATE, change attributes to best-effort values. Report Transactions continue. Starts on OnOff TRUE to FALSE, stops on FALSE to TRUE. Attribute changes due to dead front SHALL NOT be skipped.",
            "conformance": "[!OFFONLY]",
            "dependencies": "NOT OFFONLY"
          },
          {
            "bit": "2",
            "code": "OFFONLY",
            "name": "OffOnly",
            "summary": "Device supports the OffOnly feature. When supported, the Off command SHALL be supported and the On and Toggle commands SHALL NOT be supported. Useful for devices which can only be turned off via commands due to regulatory requirements.",
            "conformance": "[!(LT | DF)]",
            "dependencies": "NOT (LT OR DF)"
          }
        ],
        "data_types": [
          {
            "name": "OnOffControlBitmap",
            "base_type": "map8",
            "constraint": null,
            "values": [
              {
                "value": "0",
                "name": "AcceptOnlyWhenOn",
                "summary": "Indicates a command is only accepted when in On state.",
                "conformance": "M"
              }
            ]
          },
          {
            "name": "StartUpOnOffEnum",
            "base_type": "enum8",
            "constraint": null,
            "values": [
              {
                "value": "0",
                "name": "Off",
                "summary": "Set the OnOff attribute to FALSE",
                "conformance": "M"
              },
              {
                "value": "1",
                "name": "On",
                "summary": "Set the OnOff attribute to TRUE",
                "conformance": "M"
              },
              {
                "value": "2",
                "name": "Toggle",
                "summary": "If the previous value of the OnOff attribute is equal to FALSE, set the OnOff attribute to TRUE. If the previous value of the OnOff attribute is equal to TRUE, set the OnOff attribute to FALSE (toggle).",
                "conformance": "M"
              }
            ]
          },
          {
            "name": "EffectIdentifierEnum",
            "base_type": "enum8",
            "constraint": null,
            "values": [
              {
                "value": "0x00",
                "name": "DelayedAllOff",
                "summary": "Delayed All Off",
                "conformance": "M"
              },
              {
                "value": "0x01",
                "name": "DyingLight",
                "summary": "Dying Light",
                "conformance": "M"
              }
            ]
          },
          {
            "name": "DelayedAllOffEffectVariantEnum",
            "base_type": "enum8",
            "constraint": null,
            "values": [
              {
                "value": "0x00",
                "name": "DelayedOffFastFade",
                "summary": "Fade to off in 0.8 seconds",
                "conformance": "M"
              },
              {
                "value": "0x01",
                "name": "NoFade",
                "summary": "No fade",
                "conformance": "M"
              },
              {
                "value": "0x02",
                "name": "DelayedOffSlowFade",
                "summary": "50% dim down in 0.8 seconds then fade to off in 12 seconds",
                "conformance": "M"
              }
            ]
          },
          {
            "name": "DyingLightEffectVariantEnum",
            "base_type": "enum8",
            "constraint": null,
            "values": [
              {
                "value": "0x00",
                "name": "DyingLightFadeOff",
                "summary": "20% dim up in 0.5s then fade to off in 1 second",
                "conformance": "M"
              }
            ]
          }
        ],
        "attributes": [
          {
            "id": "0x0000",
            "name": "OnOff",
            "type": "bool",
            "constraint": "all",
            "quality": "SN",
            "default": "FALSE",
            "access": "R V",
            "conformance": "M",
            "summary": "Indicates whether the device is turned off (FALSE) or turned on (TRUE).",
            "fabric_sensitive": false,
            "scene_capable": true
          },
          {
            "id": "0x4000",
            "name": "GlobalSceneControl",
            "type": "bool",
            "constraint": "all",
            "quality": "P",
            "default": "TRUE",
            "access": "R V",
            "conformance": "LT",
            "summary": "Prevents storing an 'all-devices-off' situation as a global scene or destroying current settings by recalling a global scene. Set to TRUE after commands causing OnOff to be TRUE (e.g., On, MoveToLevel(WithOnOff), RecallScene, OnWithRecallGlobalScene). Set to FALSE after OffWithEffect.",
            "fabric_sensitive": false,
            "scene_capable": true
          },
          {
            "id": "0x4001",
            "name": "OnTime",
            "type": "uint16",
            "constraint": "all",
            "quality": "P",
            "default": "0",
            "access": "RW VO",
            "conformance": "LT",
            "summary": "Specifies the length of time (in 1/10ths second) the On state is maintained before automatically transitioning to Off when using OnWithTimedOff. Writing only affects when in Timed On state.",
            "fabric_sensitive": false,
            "scene_capable": false
          },
          {
            "id": "0x4002",
            "name": "OffWaitTime",
            "type": "uint16",
            "constraint": "all",
            "quality": "P",
            "default": "0",
            "access": "RW VO",
            "conformance": "LT",
            "summary": "Specifies the length of time (in 1/10ths second) the Off state is guarded to prevent another OnWithTimedOff command. Writing only affects when in Timed On state followed by Delayed Off, or in Delayed Off state.",
            "fabric_sensitive": false,
            "scene_capable": false
          },
          {
            "id": "0x4003",
            "name": "StartUpOnOff",
            "type": "StartUpOnOffEnum",
            "constraint": "desc",
            "quality": "XN",
            "default": "MS",
            "access": "RW VM",
            "conformance": "LT",
            "summary": "Defines the desired startup behavior of a device when powered, reflected in the OnOff attribute. If null, OnOff is set to its previous value. Otherwise, behavior is defined by StartUpOnOffEnum. Does not apply to OTA reboots. Pseudocode: IF StartUpOnOff == null THEN OnOff = previous_OnOff_value ELSE OnOff = value_defined_by_StartUpOnOffEnum.",
            "fabric_sensitive": false,
            "scene_capable": false
          }
        ],
        "commands": [
          {
            "id": "0x00",
            "name": "Off",
            "direction": "client ⇒ server",
            "response": "Y",
            "access": "O",
            "conformance": "M",
            "summary": "Turns the device off. If the OnTime attribute is supported, it is reset to 0.",
            "timing": null,
            "fields": [],
            "effect_on_receipt": "set OnOff attribute := FALSE\nif OnTime attribute is supported then\n    set OnTime attribute := 0\nend if"
          },
          {
            "id": "0x01",
            "name": "On",
            "direction": "client ⇒ server",
            "response": "Y",
            "access": "O",
            "conformance": "!OFFONLY",
            "summary": "Turns the device on. If the OffOnly feature is supported, the command is rejected. If OnTime and OffWaitTime are supported and OnTime is 0, OffWaitTime is also set to 0.",
            "timing": null,
            "fields": [],
            "effect_on_receipt": "if OffOnly feature is supported then\n    send_response(UNSUPPORTED_COMMAND)\nelse\n    set OnOff attribute := TRUE\n    if OnTime attribute is supported AND OffWaitTime attribute is supported then\n        if OnTime attribute == 0 then\n            set OffWaitTime attribute := 0\n        end if\n    end if\nend if"
          },
          {
            "id": "0x02",
            "name": "Toggle",
            "direction": "client ⇒ server",
            "response": "Y",
            "access": "O",
            "conformance": "!OFFONLY",
            "summary": "Toggles the device's on/off state. If the OffOnly feature is supported, the command is rejected. Adjusts OnTime or OffWaitTime based on the new OnOff state.",
            "timing": null,
            "fields": [],
            "effect_on_receipt": "if OffOnly feature is supported then\n    send_response(UNSUPPORTED_COMMAND)\nelse\n    if OnOff attribute == FALSE then\n        set OnOff attribute := TRUE\n    else\n        set OnOff attribute := FALSE\n    end if\n\n    if OnTime attribute is supported AND OffWaitTime attribute is supported then\n        if OnOff attribute == FALSE AND OnTime attribute == 0 then\n            set OffWaitTime attribute := 0\n        end if\n        if OnOff attribute == TRUE then\n            set OnTime attribute := 0\n        end if\n    end if\nend if"
          },
          {
            "id": "0x40",
            "name": "OffWithEffect",
            "direction": "client ⇒ server",
            "response": "Y",
            "access": "O",
            "conformance": "LT",
            "summary": "Allows devices to be turned off using enhanced fading effects. Interacts with the GlobalSceneControl attribute to manage global scene storage.",
            "timing": null,
            "fields": [
              {
                "id": "0",
                "name": "EffectIdentifier",
                "type": "EffectIdentifierEnum",
                "constraint": "desc",
                "quality": null,
                "default": null,
                "conformance": "M",
                "summary": "Specifies the fading effect to use when turning the device off. SHALL contain one of the non-reserved values listed in EffectIdentifierEnum."
              },
              {
                "id": "1",
                "name": "EffectVariant",
                "type": "enum8",
                "constraint": "desc",
                "quality": null,
                "default": "0",
                "conformance": "M",
                "summary": "Indicates which variant of the effect, specified in EffectIdentifier, SHOULD be triggered. If not supported, the default variant is used. Dependent on EffectIdentifier, values from DelayedAllOffEffectVariantEnum or DyingLightEffectVariantEnum."
              }
            ],
            "effect_on_receipt": "check GlobalSceneControl attribute\nif GlobalSceneControl attribute == TRUE then\n    store current settings in global scene\n    set GlobalSceneControl attribute := FALSE\n    set OnOff attribute := FALSE\n    if OnTime attribute is supported then\n        set OnTime attribute := 0\n    end if\nelse if GlobalSceneControl attribute == FALSE then\n    set OnOff attribute := FALSE\nend if"
          },
          {
            "id": "0x41",
            "name": "OnWithRecallGlobalScene",
            "direction": "client ⇒ server",
            "response": "Y",
            "access": "O",
            "conformance": "LT",
            "summary": "Recalls the settings stored when the device was last turned off. If GlobalSceneControl is TRUE, the command is discarded. Otherwise, the Scenes Management cluster recalls its global scene.",
            "timing": null,
            "fields": [],
            "effect_on_receipt": "if GlobalSceneControl attribute == TRUE then\n    discard_command()\nelse if GlobalSceneControl attribute == FALSE then\n    call Scenes_Management_cluster.recall_global_scene()\n    update OnOff attribute based on recalled scene\n    set GlobalSceneControl attribute := TRUE\n    if OnTime attribute is supported AND OffWaitTime attribute is supported then\n        if OnTime attribute == 0 then\n            set OffWaitTime attribute := 0\n        end if\n    end if\nend if"
          },
          {
            "id": "0x42",
            "name": "OnWithTimedOff",
            "direction": "client ⇒ server",
            "response": "Y",
            "access": "O",
            "conformance": "LT",
            "summary": "Turns devices on for a specific duration with a guarded off duration. Subsequent commands update the period. Includes logic for conditional processing and periodic attribute updates.",
            "timing": "Attributes are updated every 1/10th second until OnTime and OffWaitTime are 0.",
            "fields": [
              {
                "id": "0",
                "name": "OnOffControl",
                "type": "OnOffControlBitmap",
                "constraint": "0 to 1",
                "quality": null,
                "default": null,
                "conformance": "M",
                "summary": "Contains information on how the server is to be operated. The 'AcceptOnlyWhenOn' bit specifies if the command is processed unconditionally or only when the OnOff attribute is TRUE."
              },
              {
                "id": "1",
                "name": "OnTime",
                "type": "uint16",
                "constraint": "max 0xFFFE",
                "quality": null,
                "default": null,
                "conformance": "M",
                "summary": "Used to adjust the value of the OnTime attribute, specifying the duration the device should remain on."
              },
              {
                "id": "2",
                "name": "OffWaitTime",
                "type": "uint16",
                "constraint": "max 0xFFFE",
                "quality": null,
                "default": null,
                "conformance": "M",
                "summary": "Used to adjust the value of the OffWaitTime attribute, specifying a guarded off duration."
              }
            ],
            "effect_on_receipt": "if OnOffControl.AcceptOnlyWhenOn == 1 AND OnOff attribute == FALSE then\n    discard_command()\nelse if OffWaitTime attribute > 0 AND OnOff attribute == FALSE then\n    set OffWaitTime attribute := MIN(OffWaitTime attribute, OffWaitTime field)\nelse\n    set OnTime attribute := MAX(OnTime attribute, OnTime field)\n    set OffWaitTime attribute := OffWaitTime field\n    set OnOff attribute := TRUE\nend if\n\nif OnTime attribute != 0xFFFF AND OffWaitTime attribute != 0xFFFF then\n    // Start periodic update\n    loop every 1/10 second until (OnTime attribute == 0 AND OffWaitTime attribute == 0)\n        if OnOff attribute == TRUE AND OnTime attribute > 0 then\n            decrement OnTime attribute\n            if OnTime attribute == 0 then\n                set OffWaitTime attribute := 0\n                set OnOff attribute := FALSE\n            end if\n        else if OnOff attribute == FALSE AND OffWaitTime attribute > 0 then\n            decrement OffWaitTime attribute\n            if OffWaitTime attribute == 0 then\n                break // terminate the update loop\n            end if\n        end if\n    end loop\nend if"
          }
        ],
        "State Description": [
          {
            "state": "Timed On",
            "related_command": "OnWithTimedOff",
            "attributes": [
              "OnTime"
            ],
            "behavior": "OnTime attribute is decremented every 1/10th second, unless its value equals 0xFFFF.",
            "pseudocode": "if OnTime != 0xFFFF then every 100ms: OnTime := OnTime - 1"
          },
          {
            "state": "Delayed Off",
            "related_command": "OnWithTimedOff",
            "attributes": [
              "OffWaitTime"
            ],
            "behavior": "OffWaitTime attribute is decremented every 1/10th second, unless its value equals 0xFFFF.",
            "pseudocode": "if OffWaitTime != 0xFFFF then every 100ms: OffWaitTime := OffWaitTime - 1"
          }
        ],
        "references": [
          {
