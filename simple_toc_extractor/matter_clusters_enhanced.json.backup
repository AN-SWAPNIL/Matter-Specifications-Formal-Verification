            "id": null,
            "name": "GlobalSceneControl attribute",
            "description": "An attribute within the On/Off cluster that dictates whether global scene storage and recall are active, influencing the behavior of OffWithEffect and OnWithRecallGlobalScene commands."
          },
          {
            "id": "0x0005",
            "name": "Scenes Management cluster",
            "description": "A separate Matter application cluster responsible for managing and recalling scenes. It is interacted with by the OffWithEffect and OnWithRecallGlobalScene commands for global scene operations."
          },
          {
            "id": null,
            "name": "OnOffControlBitmap",
            "description": "A bitmap data type used in the OnWithTimedOff command's OnOffControl field to convey operational parameters, including the 'AcceptOnlyWhenOn' bit."
          }
