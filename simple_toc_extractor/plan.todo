                "conformance": "M",
                "summary": "This field is set to the GroupID field of the received AddGroup command."
              }
            ],
            "effect_on_receipt": null
          },
          {
            "id": "0x01",
            "name": "ViewGroupResponse",
            "direction": "client ⇐ server",
