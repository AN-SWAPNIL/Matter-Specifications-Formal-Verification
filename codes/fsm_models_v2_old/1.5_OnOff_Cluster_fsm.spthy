        StateTransition(endpoint, 'BaseOff', 'BaseOff'),
        OnWithTimedOffReceived(endpoint, onoff_control, on_time_field, off_wait_time_field),
        OnWithTimedOffDiscardedAcceptOnlyWhenOn(endpoint)
    ]->
    [
        ServerState(endpoint, 'BaseOff'),
        !FeatureConfig(endpoint, 'LT', 'true'),
        Out(<'OnWithTimedOff_Response', SUCCESS>),
        !Server(endpoint)
    ]

// OnWithTimedOff while OnOff TRUE enters or updates TimedOn with new OnTime and OffWaitTime
// Guard: not (onoff_control.AcceptOnlyWhenOn == 1 and OnOff == FALSE)
// Guard: OnOff == TRUE
rule OnWithTimedOff_BaseOn_to_TimedOn_T22:
    [
        ServerState(endpoint, 'BaseOn'),
        !FeatureConfig(endpoint, 'LT', 'true'),
        In(<'OnWithTimedOff_Request', endpoint, onoff_control, on_time_field, off_wait_time_field>),
        In(off_wait_time),
        In(on_time),
        !Server(endpoint)
    ]
    --[
        OnWithTimedOff(endpoint),
        StateTransition(endpoint, 'BaseOn', 'TimedOn'),
        OnWithTimedOffReceived(endpoint, onoff_control, on_time_field, off_wait_time_field),
        OnWithTimedOffAcceptedTimedOn(endpoint, on_time, off_wait_time)
    ]->
    [
        ServerState(endpoint, 'TimedOn'),
        !FeatureConfig(endpoint, 'LT', 'true'),
        Out(<'OnWithTimedOff_Response', SUCCESS>),
        !Server(endpoint)
    ]

// OnWithTimedOff while already in TimedOn updates timers
// Guard: not (onoff_control.AcceptOnlyWhenOn == 1 and OnOff == FALSE)
// Guard: OnOff == TRUE
rule OnWithTimedOff_TimedOn_to_TimedOn_T23:
    [
        ServerState(endpoint, 'TimedOn'),
        !FeatureConfig(endpoint, 'LT', 'true'),
        In(<'OnWithTimedOff_Request', endpoint, onoff_control, on_time_field, off_wait_time_field>),
