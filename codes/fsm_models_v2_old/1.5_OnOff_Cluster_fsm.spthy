// OffWithEffect stores global scene then turns device off and clears OnTime
// Guard: GlobalSceneControl == TRUE
// Guard: GlobalSceneControl == TRUE
rule OffWithEffect_BaseOn_to_BaseOff_T13:
    [
        ServerState(endpoint, 'BaseOn'),
        !FeatureConfig(endpoint, 'LT', 'true'),
