//========================================
// TimerTick rules (abstracted RemainingTime)
//========================================

rule TimerTick_Progress_Base:
  [ St(~tid, st_TransitionActive, fo, f_LT, fq,
        cl_set, cl, tv_pos,
        op, oo,
        cf_set, cf) ]
--[ InternalEvt(~tid, 'TimerTick'),
    StateTransition(~tid, st_TransitionActive, st_TransitionActive) ]->
  [ St(~tid, st_TransitionActive, fo, f_LT, fq,
        cl_set, cl, tv_pos,
        op, oo,
        cf_set, cf) ]

rule TimerTick_Complete_Base:
  [ St(~tid, st_TransitionActive, fo, f_LT, fq,
        cl_set, cl, tv_pos,
        op, oo,
        cf_set, cf) ]
--[ InternalEvt(~tid, 'TimerTick'),
    StateTransition(~tid, st_TransitionActive, st_Idle) ]->
  [ St(~tid, st_Idle, fo, f_LT, fq,
        cl_set, cl, tv_zero,
        op, oo,
        cf_set, cf) ]

//========================================
// Restrictions
//========================================

restriction unique_init:
  "All tid #i #j. ClusterInit(tid)@i & ClusterInit(tid)@j ==> #i = #j"

//========================================
// Sources lemma
//========================================

lemma sources [sources]:
  "All tid s1 s2 #i. StateTransition(tid, s1, s2)@i ==> Ex #j. ClusterInit(tid)@j & #j < #i"

lemma dummy:
  exists-trace
  "Ex tid #i. ClusterInit(tid)@i"

end