            ],
            "effect_on_receipt": "Create temporary Options bitmap; Set CurrentLevel to Level over TransitionTime; Set OnOff attribute accordingly; Update GlobalSceneControl if OnOff attribute changes"
          },
          {
            "id": "0x05",
