rule Env_Step_StepPos_ExecIfOffTrue:
  [ !Config_LevelControl(tid, f_FQ) ]
--[ ]->
  [ In_Step_StepPos_ExecIfOffTrue(tid) ]

rule Env_Step_StepPos:
  [ !Config_LevelControl(tid, f_FQ) ]
--[ ]->
  [ In_Step_StepPos(tid) ]

rule Env_Stop:
  [ !Config_LevelControl(tid, f_FQ) ]
--[ ]->
  [ In_Stop(tid) ]

rule Env_MoveToLevelWithOnOff:
  [ !Config_LevelControl(tid, f_FQ) ]
--[ ]->
  [ In_MoveToLevelWithOnOff(tid) ]

rule Env_MoveWithOnOff_RateZero:
  [ !Config_LevelControl(tid, f_FQ) ]
--[ ]->
  [ In_MoveWithOnOff_RateZero(tid) ]

rule Env_MoveWithOnOff_RatePos_Up:
  [ !Config_LevelControl(tid, f_FQ) ]
--[ ]->
  [ In_MoveWithOnOff_RatePos_Up(tid) ]

rule Env_MoveWithOnOff_RatePos_Down:
  [ !Config_LevelControl(tid, f_FQ) ]
--[ ]->
