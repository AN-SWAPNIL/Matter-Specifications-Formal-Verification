        ],
        "cluster_id": [
          {
            "id": "0x0004",
            "name": "Groups",
            "summary": "Manages, per endpoint, the node-wide Group Table content. Supports discovering, adding, and removing endpoint membership from groups scoped to the accessing fabric. Can store group names."
          }
        ],
        "classification": [
          {
            "hierarchy": "Base",
            "role": "Utility",
            "scope": "Endpoint",
            "pics_code": "G",
            "summary": "A Base Utility cluster scoped to the Endpoint, managing group membership and names within a fabric. Commands only affect groups scoped to the accessing fabric."
          }
        ],
        "features": [
          {
            "bit": "0",
            "code": "GN",
            "name": "GroupNames",
            "summary": "The ability to store a name for a group when a group is added.",
            "conformance": "M",
            "dependencies": null
          }
        ],
        "data_types": [
          {
            "name": "NameSupportBitmap",
            "base_type": "map8",
            "constraint": null,
            "values": [
              {
                "value": "7",
                "name": "GroupNames",
                "summary": "The ability to store a name for a group.",
                "conformance": "M"
              }
            ]
          }
        ],
        "attributes": [
          {
            "id": "0x0000",
            "name": "NameSupport",
            "type": "NameSupportBitmap",
            "constraint": "desc",
            "quality": "F",
            "default": "0",
            "access": "R V",
            "conformance": "M",
            "summary": "This attribute provides legacy, read-only access to whether the Group Names feature is supported. The most significant bit, bit 7 (GroupNames), SHALL be equal to bit 0 of the FeatureMap attribute (GN Feature). All other bits SHALL be 0.",
            "fabric_sensitive": false,
            "scene_capable": false
          }
        ],
        "commands": [
          {
            "id": "0x00",
            "name": "AddGroup",
            "direction": "client ⇒ server",
            "response": "AddGroupResponse",
            "access": "M F",
            "conformance": "M",
            "summary": "Allows a client to add group membership in a particular group for the server endpoint.",
            "timing": null,
            "fields": [
              {
                "id": "0",
                "name": "GroupID",
                "type": "group-id",
                "constraint": "min 1",
                "quality": null,
                "default": null,
                "conformance": "M",
                "summary": "Identifies the group and any associated key material to which the server endpoint is to be added."
              },
              {
                "id": "1",
                "name": "GroupName",
                "type": "string",
                "constraint": "max 16",
                "quality": null,
                "default": null,
                "conformance": "M",
                "summary": "MAY be a human-readable name for the group. If no name, SHALL be empty string. Support is optional, indicated by FeatureMap and NameSupport attribute."
              }
            ],
            "effect_on_receipt": "SET status := SUCCESS\nIF NOT server.supports_group_names THEN ignore GroupName field END IF\n\nIF NOT command_fields.are_within_constraints THEN status := CONSTRAINT_ERROR\nELSE IF node.requires_security_material(GroupID) AND NOT security_material.exists(GroupID) THEN status := UNSUPPORTED_ACCESS\nELSE IF server_endpoint.is_member_of_group(GroupID) THEN\n    IF server.supports_group_names THEN update group_table[GroupID].name := GroupName END IF\nELSE IF NOT server.has_available_resources_for_membership THEN status := RESOURCE_EXHAUSTED\nELSE\n    add server_endpoint as member of GroupID\n    IF server.supports_group_names THEN update group_table[GroupID].name := GroupName END IF\nEND IF\n\nIF GroupID.exists_in_group_table_from_previous_command AND GroupName.is_provided AND server.supports_group_name_storage THEN\n    update group_table[GroupID].name := GroupName\nEND IF\n\nIF command.was_unicast THEN generate AddGroupResponse(Status := status)\nELSE IF command.was_groupcast THEN DO NOT generate AddGroupResponse\nEND IF"
          },
          {
            "id": "0x01",
            "name": "ViewGroup",
            "direction": "client ⇒ server",
            "response": "ViewGroupResponse",
            "access": "O F",
            "conformance": "M",
            "summary": "Allows a client to request the server to respond with a ViewGroupResponse command containing the name string for a particular group.",
            "timing": null,
            "fields": [
              {
                "id": "0",
                "name": "GroupID",
                "type": "group-id",
                "constraint": "min 1",
                "quality": null,
                "default": null,
                "conformance": "M",
                "summary": "Identifies the group for which the name is requested."
              }
            ],
            "effect_on_receipt": "SET status := SUCCESS\nIF NOT command_fields.are_within_constraints THEN\n    SET status := CONSTRAINT_ERROR\nELSE IF NOT server_endpoint.is_member_of_group(GroupID) THEN\n    SET status := NOT_FOUND\nEND IF\n\nIF command.was_unicast THEN\n    generate ViewGroupResponse(Status := status)\nELSE IF command.was_groupcast THEN\n    DO NOT generate ViewGroupResponse\nEND IF"
          },
          {
            "id": "0x02",
            "name": "GetGroupMembership",
            "direction": "client ⇒ server",
            "response": "GetGroupMembershipResponse",
            "access": "O F",
            "conformance": "M",
            "summary": "Allows a client to inquire about the group membership of the server endpoint in various ways.",
            "timing": null,
            "fields": [
              {
                "id": "0",
                "name": "GroupList",
                "type": "list[group-id]",
                "constraint": "all[min 1]",
                "quality": null,
                "default": null,
                "conformance": "M",
                "summary": "A list of GroupIDs to query. If empty, all group memberships are requested."
              }
            ],
            "effect_on_receipt": "SET response_group_list := empty_list\nIF GroupList.is_empty THEN\n    SET response_group_list := server_endpoint.all_member_group_ids\nELSE\n    FOR each group_id IN GroupList DO\n        IF server_endpoint.is_member_of_group(group_id) THEN\n            add group_id to response_group_list\n        END IF\n    END FOR\nEND IF\n\nIF NOT response_group_list.is_empty OR command.was_unicast THEN\n    generate GetGroupMembershipResponse(GroupList := response_group_list)\nEND IF"
          },
          {
            "id": "0x03",
            "name": "RemoveGroup",
            "direction": "client ⇒ server",
            "response": "RemoveGroupResponse",
            "access": "M F",
            "conformance": "M",
            "summary": "Allows a client to request that the server removes the membership for the server endpoint in a particular group.",
            "timing": null,
            "fields": [
              {
                "id": "0",
                "name": "GroupID",
                "type": "group-id",
                "constraint": "min 1",
                "quality": null,
                "default": null,
                "conformance": "M",
                "summary": "Identifies the group from which the server endpoint's membership is to be removed."
              }
            ],
            "effect_on_receipt": "SET status := SUCCESS\nIF NOT command_fields.are_within_constraints THEN\n    SET status := CONSTRAINT_ERROR\nELSE IF server_endpoint.is_member_of_group(GroupID) THEN\n    remove server_endpoint membership from GroupID\nELSE\n    SET status := NOT_FOUND\nEND IF\n\nIF command.was_unicast THEN\n    generate RemoveGroupResponse(Status := status)\nELSE IF command.was_groupcast THEN\n    DO NOT generate RemoveGroupResponse\nEND IF\n\nIF Scenes_Management_cluster.is_supported_on_endpoint THEN\n    remove scenes associated with GroupID on endpoint\nEND IF"
          },
          {
            "id": "0x04",
            "name": "RemoveAllGroups",
            "direction": "client ⇒ server",
            "response": "Y",
            "access": "M F",
            "conformance": "M",
            "summary": "Allows a client to direct the server to remove all group associations for the server endpoint.",
            "timing": null,
            "fields": [],
            "effect_on_receipt": "remove all group_memberships for server_endpoint from Group_Table\n\nIF command.was_unicast AND NOT response.is_suppressed THEN\n    generate response(Status := SUCCESS)\nEND IF\n\nIF Scenes_Management_cluster.is_supported_on_endpoint THEN\n    remove all scenes on endpoint EXCEPT scenes associated with group_id 0\nEND IF"
          },
          {
            "id": "0x05",
            "name": "AddGroupIfIdentifying",
            "direction": "client ⇒ server",
            "response": "Y",
            "access": "M F",
            "conformance": "M",
            "summary": "Allows a client to add group membership for the server endpoint, conditioned on the endpoint currently identifying itself.",
            "timing": "Any endpoint supporting the Groups server cluster SHALL also support the Identify server cluster.",
            "fields": [
              {
                "id": "0",
                "name": "GroupID",
                "type": "group-id",
                "constraint": "min 1",
                "quality": null,
                "default": null,
                "conformance": "M",
                "summary": "Identifies the group and any associated key material to which the server endpoint is to be added."
              },
              {
                "id": "1",
                "name": "GroupName",
                "type": "string",
                "constraint": "max 16",
                "quality": null,
                "default": null,
                "conformance": "M",
                "summary": "MAY be a human-readable name for the group. If no name, SHALL be empty string. Support is optional, indicated by FeatureMap and NameSupport attribute."
              }
            ],
            "effect_on_receipt": "SET status := SUCCESS\nIF NOT server.supports_group_names THEN ignore GroupName field END IF\n\nIF NOT server.is_identifying_itself THEN\n    // status remains SUCCESS\nELSE IF NOT command_fields.are_within_constraints THEN status := CONSTRAINT_ERROR\nELSE IF node.requires_security_material(GroupID) AND NOT security_material.exists(GroupID) THEN status := UNSUPPORTED_ACCESS\nELSE IF server_endpoint.is_member_of_group(GroupID) THEN\n    // status remains SUCCESS\nELSE IF NOT server.has_available_resources_for_membership THEN status := RESOURCE_EXHAUSTED\nELSE\n    add server_endpoint as member of GroupID\n    IF server.supports_group_names THEN update group_table[GroupID].name := GroupName END IF\nEND IF\n\nIF GroupID.exists_in_group_table_from_previous_command AND GroupName.is_provided AND server.supports_group_name_storage THEN\n    update group_table[GroupID].name := GroupName\nEND IF\n\nIF command.was_unicast AND (status != SUCCESS OR NOT response.is_suppressed) THEN\n    generate response(Status := status)\nEND IF"
          },
          {
            "id": "0x00",
            "name": "AddGroupResponse",
            "direction": "client ⇐ server",
            "response": "N",
            "access": null,
            "conformance": "M",
            "summary": "Sent by the Groups cluster server in response to an AddGroup command, indicating the status of the operation and the GroupID.",
            "timing": null,
            "fields": [
              {
                "id": "0",
                "name": "Status",
                "type": "enum8",
                "constraint": "desc",
                "quality": null,
                "default": null,
                "conformance": "M",
                "summary": "Set according to the Effect on Receipt section of the AddGroup command."
              },
              {
                "id": "1",
                "name": "GroupID",
                "type": "group-id",
                "constraint": "min 1",
                "quality": null,
                "default": null,
                "conformance": "M",
                "summary": "Set to the GroupID field of the received AddGroup command."
              }
            ],
            "effect_on_receipt": null
          },
          {
            "id": "0x01",
            "name": "ViewGroupResponse",
            "direction": "client ⇐ server",
            "response": "N",
            "access": null,
            "conformance": "M",
            "summary": "Sent by the Groups cluster server in response to a ViewGroup command, providing the group's name.",
            "timing": null,
            "fields": [
              {
                "id": "0",
                "name": "Status",
                "type": "enum8",
                "constraint": "desc",
                "quality": null,
                "default": null,
                "conformance": "M",
                "summary": "Set according to the Effect on Receipt section of the ViewGroup command."
              },
              {
                "id": "1",
                "name": "GroupID",
                "type": "group-id",
                "constraint": "min 1",
                "quality": null,
                "default": null,
                "conformance": "M",
                "summary": "Set to the GroupID field of the received ViewGroup command."
              },
              {
                "id": "2",
                "name": "GroupName",
                "type": "string",
                "constraint": "max 16",
                "quality": null,
                "default": null,
                "conformance": "M",
                "summary": "If status is SUCCESS and group names are supported, set to the group name from the Group Table; otherwise, set to the empty string."
              }
            ],
            "effect_on_receipt": null
          },
          {
            "id": "0x02",
            "name": "GetGroupMembershipResponse",
            "direction": "client ⇐ server",
            "response": "N",
            "access": null,
            "conformance": "M",
            "summary": "Sent by the Groups cluster server in response to a GetGroupMembership command, providing group membership information.",
            "timing": null,
            "fields": [
              {
                "id": "0",
                "name": "Capacity",
                "type": "uint8",
                "constraint": "all",
                "quality": "X",
                "default": null,
                "conformance": "M",
                "summary": "Remaining capacity of the Group Table. 0: No further groups. 0 < Capacity < 0xFE: Number of groups that MAY be added. 0xFE: At least 1 further group. null: Unknown capacity."
              },
              {
                "id": "1",
                "name": "GroupList",
                "type": "list[group-id]",
                "constraint": "all[min 1]",
                "quality": null,
                "default": null,
                "conformance": "M",
                "summary": "Contains group IDs of which the server endpoint is a member, filtered by the request's GroupList if provided, or all if the request's GroupList was empty. May be truncated for Zigbee payload limits."
              }
            ],
            "effect_on_receipt": null
          },
          {
            "id": "0x03",
            "name": "RemoveGroupResponse",
            "direction": "client ⇐ server",
            "response": "N",
            "access": null,
            "conformance": "M",
            "summary": "Generated by the server in response to the receipt of a RemoveGroup command, indicating the status of the removal operation.",
            "timing": null,
            "fields": [
              {
                "id": "0",
                "name": "Status",
                "type": "enum8",
                "constraint": "desc",
                "quality": null,
                "default": null,
                "conformance": "M",
                "summary": "Set according to the Effect on Receipt section of the RemoveGroup command."
              },
              {
                "id": "1",
                "name": "GroupID",
                "type": "group-id",
                "constraint": "min 1",
                "quality": null,
                "default": null,
                "conformance": "M",
                "summary": "Set to the GroupID field of the received RemoveGroup command."
              }
            ],
            "effect_on_receipt": null
          }
        ],
        "references": [
          {
            "id": "0xFFFC",
