        !FeatureConfig(endpoint, 'LT', 'true'),
        Out(<'OnWithTimedOff_Response', SUCCESS>),
        !Server(endpoint)
    ]

// OnWithTimedOff while Off and not guarded enters or updates DelayedOff with new OffWaitTime
// Guard: not (onoff_control.AcceptOnlyWhenOn == 1 and OnOff == FALSE)
