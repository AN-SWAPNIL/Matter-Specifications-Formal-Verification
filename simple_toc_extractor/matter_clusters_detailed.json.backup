            "effect_on_receipt": "If StepSize==0, return INVALID_COMMAND; Create temporary Options bitmap; Change CurrentLevel by StepSize in StepMode direction; Adjust TransitionTime proportionally if Min/MaxLevel reached"
          },
          {
            "id": "0x03",
            "name": "Stop",
            "direction": "client⇒server",
            "response": "DefaultResponse",
            "access": "O",
            "conformance": "M",
            "summary": "Stop ongoing command",
            "timing": null,
            "fields": [
              {
                "id": "0",
                "name": "OptionsMask",
