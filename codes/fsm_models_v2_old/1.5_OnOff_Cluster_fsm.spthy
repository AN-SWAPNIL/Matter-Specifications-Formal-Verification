theory On_Off_Cluster
begin

/*
 * Tamarin Protocol Security Model for On/Off Cluster
 * Generated from Enhanced FSM JSON (v2.0)
 * Generated: 2025-12-16T21:17:21.266316
 * 
 * Cluster ID: 0x0006
 * Revision: 6
 * 
 * Model Statistics:
 * - States: 4
 * - Transitions: 29
 * - Action Facts: 23
 * - Security Properties: 0
 * 
 * This model supports security analysis with:
 * - Parameterized action facts for precise tracing
 * - Message passing (In/Out) for protocol modeling
 * - Fresh value generation for cryptographic material
 * - Verifiable security lemmas
 */

builtins: hashing, symmetric-encryption

// ============================================================================
// Functions
// ============================================================================

// Boolean and null constants
functions: true/0, false/0, null/0

// Empty value marker
functions: empty/0

// Response status
functions: SUCCESS/0, FAILURE/0

// ============================================================================
// Restrictions
// ============================================================================

// Equality check
restriction Equality:
    "All x y #i. Eq(x, y)@i ==> x = y"

// Inequality check  
restriction Inequality:
    "All x y #i. Neq(x, y)@i ==> not(x = y)"

// Once restriction for unique events
restriction Once:
    "All x #i #j. Once(x)@i & Once(x)@j ==> #i = #j"


// ============================================================================
// Initialization
// ============================================================================

// Feature flags (feature_X) are abstract terms that represent true/false configuration
rule Server_Init:
    [ Fr(~endpoint_id) ]
    --[ ServerInit(~endpoint_id), Once(<'server_init', ~endpoint_id>) ]->
    [
        !Server(~endpoint_id),
        ServerState(~endpoint_id, 'BaseOff'),
        RateLimitCounter(~endpoint_id, 'zero'),
        Out(~endpoint_id),
        !FeatureConfig(~endpoint_id, 'DF', feature_df),
        !FeatureConfig(~endpoint_id, 'LT', feature_lt),
        !FeatureConfig(~endpoint_id, 'OFFONLY', feature_offonly)  // Endpoint is public - adversary can address server
    ]


// ============================================================================
// Fresh Value Generation
// ============================================================================

rule Create_TempAccountIdentifier:
    let temp_id = h(<~account, ~nonce>)
    in
    [ Fr(~account), Fr(~nonce), Fr(~setup_pin), Fr(~validity) ]
    --[ 
        TempIdCreated(temp_id, ~account),
        AccountRegistered(~account, temp_id, ~setup_pin)
    ]->
    [
        !AccountMapping(temp_id, ~account, ~setup_pin, ~validity),
        Out(temp_id)  // Attacker can observe temp_id
    ]

rule TempId_Expires:
    [ !AccountMapping(temp_id, account, setup_pin, validity) ]
    --[ TempIdExpired(temp_id) ]->
    [ !AccountMapping_Expired(temp_id, account, setup_pin) ]


// ============================================================================

// Protocol Transitions

// ============================================================================

// Off command turns device off and clears OnTime if supported
rule Off_BaseOn_to_BaseOff_T1:
    [
        ServerState(endpoint, 'BaseOn'),
        In(<'Off_Request', endpoint>),
        !Server(endpoint)
    ]
    --[
        Off(endpoint),
        StateTransition(endpoint, 'BaseOn', 'BaseOff'),
        OffReceived(endpoint),
        OffAccepted(endpoint)
    ]->
    [
        ServerState(endpoint, 'BaseOff'),
        Out(<'Off_Response', SUCCESS>),
        !Server(endpoint)
    ]

// Off command while TimedOn forces off and clears timers
rule Off_TimedOn_to_BaseOff_T2:
    [
        ServerState(endpoint, 'TimedOn'),
        In(<'Off_Request', endpoint>),
        !Server(endpoint)
    ]
    --[
        Off(endpoint),
        StateTransition(endpoint, 'TimedOn', 'BaseOff'),
        OffReceived(endpoint),
        OffAccepted(endpoint)
    ]->
    [
        ServerState(endpoint, 'BaseOff'),
        Out(<'Off_Response', SUCCESS>),
        !Server(endpoint)
    ]

// On command rejected because OffOnly feature is enabled
// Guard: feature_OFFONLY == TRUE
rule On_BaseOff_to_BaseOff_T3:
    [
        ServerState(endpoint, 'BaseOff'),
        !FeatureConfig(endpoint, 'OFFONLY', 'true'),
        In(<'On_Request', endpoint>),
        !Server(endpoint)
    ]
    --[
        On(endpoint),
        StateTransition(endpoint, 'BaseOff', 'BaseOff'),
        OnReceived(endpoint),
        OnNotSupportedOffOnly(endpoint)
    ]->
    [
        ServerState(endpoint, 'BaseOff'),
        !FeatureConfig(endpoint, 'OFFONLY', 'true'),
        Out(<'On_Response', 'UNSUPPORTED_COMMAND'>),
        !Server(endpoint)
    ]

// On command turns device on from BaseOff, clears OffWaitTime if OnTime == 0 (simplified as clear)
// Guard: feature_OFFONLY == FALSE
rule On_BaseOff_to_BaseOn_T4:
    [
        ServerState(endpoint, 'BaseOff'),
        !FeatureConfig(endpoint, 'OFFONLY', 'false'),
        In(<'On_Request', endpoint>),
        !Server(endpoint)
    ]
    --[
        On(endpoint),
        StateTransition(endpoint, 'BaseOff', 'BaseOn'),
        OnReceived(endpoint),
        OnAccepted(endpoint)
    ]->
    [
        ServerState(endpoint, 'BaseOn'),
        !FeatureConfig(endpoint, 'OFFONLY', 'false'),
        Out(<'On_Response', SUCCESS>),
        !Server(endpoint)
    ]

// On command from DelayedOff turns device on and clears OffWaitTime if OnTime == 0 (simplified as clear)
// Guard: feature_OFFONLY == FALSE
rule On_DelayedOff_to_BaseOn_T5:
    [
        ServerState(endpoint, 'DelayedOff'),
        !FeatureConfig(endpoint, 'OFFONLY', 'false'),
