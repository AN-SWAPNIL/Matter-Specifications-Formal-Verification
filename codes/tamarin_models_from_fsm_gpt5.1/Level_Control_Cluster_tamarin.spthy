  [ St(~tid, st_IdleOn, b_true, lv_def, tv_zero, L7),
    !RateKind(~tid, rt_pos) ]
--[ Command(~tid, c_MoveWithOnOff), StateTransition(~tid, st_IdleOn, st_MovingContinuouslyUp) ]->
  [ St(~tid, st_MovingContinuouslyUp, b_true, lv_def, tv_indet, dir_up),
    !LastCmdLink(~tid, lc_link) ]

// IdleOn, Down, Rate != 0 -> MovingContinuouslyDown, linkage
rule Cmd_MoveWithOnOff_IdleOn_Down_RatePos:
  [ St(~tid, st_IdleOn, b_true, lv_def, tv_zero, L8),
    !RateKind(~tid, rt_pos) ]
--[ Command(~tid, c_MoveWithOnOff), StateTransition(~tid, st_IdleOn, st_MovingContinuouslyDown) ]->
  [ St(~tid, st_MovingContinuouslyDown, b_true, lv_def, tv_indet, dir_down),
    !LastCmdLink(~tid, lc_link) ]

// IdleOffLevelDefined, Rate == 0 -> INVALID_COMMAND
rule Cmd_MoveWithOnOff_IdleOffDef_RateZero:
  [ St(~tid, st_IdleOffLevelDefined, b_false, lv_def, tv_zero, D),
    !RateKind(~tid, rt_zero) ]
--[ Command(~tid, c_MoveWithOnOff), StateTransition(~tid, st_IdleOffLevelDefined, st_IdleOffLevelDefined) ]->
  [ St(~tid, st_IdleOffLevelDefined, b_false, lv_def, tv_zero, D) ]

// IdleOn, Rate == 0 -> INVALID_COMMAND
rule Cmd_MoveWithOnOff_IdleOn_RateZero:
  [ St(~tid, st_IdleOn, b_true, lv_def, tv_zero, D),
    !RateKind(~tid, rt_zero) ]
--[ Command(~tid, c_MoveWithOnOff), StateTransition(~tid, st_IdleOn, st_IdleOn) ]->
  [ St(~tid, st_IdleOn, b_true, lv_def, tv_zero, D) ]

//========================================
// SECTION 11: Stop / StopWithOnOff Transitions
//========================================

// From MovingToLevel, Stop, On -> IdleOn
rule Cmd_Stop_MovingToLevel_On:
  [ St(~tid, st_MovingToLevel, b_true, lv_def, tv_pos, D) ]
--[ Command(~tid, c_Stop), StateTransition(~tid, st_MovingToLevel, st_IdleOn) ]->
  [ St(~tid, st_IdleOn, b_true, lv_def, tv_zero, D) ]

// From MovingToLevel, Stop, Off -> IdleOffLevelDefined
rule Cmd_Stop_MovingToLevel_Off:
  [ St(~tid, st_MovingToLevel, b_false, lv_def, tv_pos, D) ]
--[ Command(~tid, c_Stop), StateTransition(~tid, st_MovingToLevel, st_IdleOffLevelDefined) ]->
  [ St(~tid, st_IdleOffLevelDefined, b_false, lv_def, tv_zero, D) ]

// MovingContinuouslyUp, Stop, On -> IdleOn
rule Cmd_Stop_MovingContUp_On:
  [ St(~tid, st_MovingContinuouslyUp, b_true, lv_def, tv_indet, dir_up) ]
--[ Command(~tid, c_Stop), StateTransition(~tid, st_MovingContinuouslyUp, st_IdleOn) ]->
  [ St(~tid, st_IdleOn, b_true, lv_def, tv_zero, dir_up) ]

// MovingContinuouslyUp, Stop, Off -> IdleOffLevelDefined
rule Cmd_Stop_MovingContUp_Off:
  [ St(~tid, st_MovingContinuouslyUp, b_false, lv_def, tv_indet, dir_up) ]
--[ Command(~tid, c_Stop), StateTransition(~tid, st_MovingContinuouslyUp, st_IdleOffLevelDefined) ]->
  [ St(~tid, st_IdleOffLevelDefined, b_false, lv_def, tv_zero, dir_up) ]

// MovingContinuouslyDown, Stop, On -> IdleOn
rule Cmd_Stop_MovingContDown_On:
  [ St(~tid, st_MovingContinuouslyDown, b_true, lv_def, tv_indet, dir_down) ]
--[ Command(~tid, c_Stop), StateTransition(~tid, st_MovingContinuouslyDown, st_IdleOn) ]->
  [ St(~tid, st_IdleOn, b_true, lv_def, tv_zero, dir_down) ]

// MovingContinuouslyDown, Stop, Off -> IdleOffLevelDefined
rule Cmd_Stop_MovingContDown_Off:
  [ St(~tid, st_MovingContinuouslyDown, b_false, lv_def, tv_indet, dir_down) ]
--[ Command(~tid, c_Stop), StateTransition(~tid, st_MovingContinuouslyDown, st_IdleOffLevelDefined) ]->
  [ St(~tid, st_IdleOffLevelDefined, b_false, lv_def, tv_zero, dir_down) ]

// StopWithOnOff variants: identical state effects to Stop

rule Cmd_StopWithOnOff_MovingToLevel_On:
  [ St(~tid, st_MovingToLevel, b_true, lv_def, tv_pos, D) ]
--[ Command(~tid, c_StopWithOnOff), StateTransition(~tid, st_MovingToLevel, st_IdleOn) ]->
  [ St(~tid, st_IdleOn, b_true, lv_def, tv_zero, D) ]

rule Cmd_StopWithOnOff_MovingToLevel_Off:
  [ St(~tid, st_MovingToLevel, b_false, lv_def, tv_pos, D) ]
--[ Command(~tid, c_StopWithOnOff), StateTransition(~tid, st_MovingToLevel, st_IdleOffLevelDefined) ]->
  [ St(~tid, st_IdleOffLevelDefined, b_false, lv_def, tv_zero, D) ]

rule Cmd_StopWithOnOff_MovingContUp_On:
  [ St(~tid, st_MovingContinuouslyUp, b_true, lv_def, tv_indet, dir_up) ]
--[ Command(~tid, c_StopWithOnOff), StateTransition(~tid, st_MovingContinuouslyUp, st_IdleOn) ]->
  [ St(~tid, st_IdleOn, b_true, lv_def, tv_zero, dir_up) ]

rule Cmd_StopWithOnOff_MovingContUp_Off:
  [ St(~tid, st_MovingContinuouslyUp, b_false, lv_def, tv_indet, dir_up) ]
--[ Command(~tid, c_StopWithOnOff), StateTransition(~tid, st_MovingContinuouslyUp, st_IdleOffLevelDefined) ]->
  [ St(~tid, st_IdleOffLevelDefined, b_false, lv_def, tv_zero, dir_up) ]

rule Cmd_StopWithOnOff_MovingContDown_On:
  [ St(~tid, st_MovingContinuouslyDown, b_true, lv_def, tv_indet, dir_down) ]
--[ Command(~tid, c_StopWithOnOff), StateTransition(~tid, st_MovingContinuouslyDown, st_IdleOn) ]->
  [ St(~tid, st_IdleOn, b_true, lv_def, tv_zero, dir_down) ]

rule Cmd_StopWithOnOff_MovingContDown_Off:
  [ St(~tid, st_MovingContinuouslyDown, b_false, lv_def, tv_indet, dir_down) ]
--[ Command(~tid, c_StopWithOnOff), StateTransition(~tid, st_MovingContinuouslyDown, st_IdleOffLevelDefined) ]->
  [ St(~tid, st_IdleOffLevelDefined, b_false, lv_def, tv_zero, dir_down) ]

//========================================
// SECTION 12: Timer Transitions
//========================================

// MovingToLevel, RemainingTime > 1 -> Timer Tick 0.1s: stay MovingToLevel, tv_pos
rule Ev_TimerTick_MovingToLevel:
  [ St(~tid, st_MovingToLevel, B, lv_def, tv_pos, Dir) ]
--[ Command(~tid, c_TimerTick), StateTransition(~tid, st_MovingToLevel, st_MovingToLevel) ]->
  [ St(~tid, st_MovingToLevel, B, lv_def, tv_pos, Dir) ]

// MovingToLevel, RemainingTime == 1, final level above min -> IdleOn
rule Ev_TimerExpiry_MovingToLevel_FinalAboveMin:
  [ St(~tid, st_MovingToLevel, B, lv_def, tv_pos, Dir),
    !ResultLevelKind(~tid, res_above_min) ]
--[ Command(~tid, c_TimerExpiry), StateTransition(~tid, st_MovingToLevel, st_IdleOn) ]->
  [ St(~tid, st_IdleOn, b_true, lv_def, tv_zero, Dir) ]

// MovingToLevel, RemainingTime == 1, final level at min -> IdleOffLevelDefined
rule Ev_TimerExpiry_MovingToLevel_FinalAtMin:
  [ St(~tid, st_MovingToLevel, B, lv_def, tv_pos, Dir),
    !ResultLevelKind(~tid, res_at_min) ]
--[ Command(~tid, c_TimerExpiry), StateTransition(~tid, st_MovingToLevel, st_IdleOffLevelDefined) ]->
  [ St(~tid, st_IdleOffLevelDefined, b_false, lv_def, tv_zero, Dir) ]

//========================================
// SECTION 13: ReachedMaxLevel / ReachedMinLevel
//========================================

// MovingContinuouslyUp, ReachedMaxLevel, On -> IdleOn at MaxLevel
rule Ev_ReachedMaxLevel_MovingContUp_On:
  [ St(~tid, st_MovingContinuouslyUp, b_true, lv_def, tv_indet, dir_up) ]
--[ Command(~tid, c_ReachedMaxLevel), StateTransition(~tid, st_MovingContinuouslyUp, st_IdleOn) ]->
  [ St(~tid, st_IdleOn, b_true, lv_def, tv_zero, dir_up) ]

// MovingContinuouslyUp, ReachedMaxLevel, Off -> IdleOffLevelDefined
rule Ev_ReachedMaxLevel_MovingContUp_Off:
  [ St(~tid, st_MovingContinuouslyUp, b_false, lv_def, tv_indet, dir_up) ]
--[ Command(~tid, c_ReachedMaxLevel), StateTransition(~tid, st_MovingContinuouslyUp, st_IdleOffLevelDefined) ]->
  [ St(~tid, st_IdleOffLevelDefined, b_false, lv_def, tv_zero, dir_up) ]

// MovingContinuouslyDown, ReachedMinLevel, last command without OnOff linkage -> IdleOn
rule Ev_ReachedMinLevel_MovingContDown_NoLink:
  [ St(~tid, st_MovingContinuouslyDown, b_true, lv_def, tv_indet, dir_down),
    !LastCmdLink(~tid, lc_nolink) ]
--[ Command(~tid, c_ReachedMinLevel), StateTransition(~tid, st_MovingContinuouslyDown, st_IdleOn) ]->
  [ St(~tid, st_IdleOn, b_true, lv_def, tv_zero, dir_down) ]

// MovingContinuouslyDown, ReachedMinLevel, last command with OnOff linkage -> IdleOffLevelDefined, Off
rule Ev_ReachedMinLevel_MovingContDown_Link:
  [ St(~tid, st_MovingContinuouslyDown, B, lv_def, tv_indet, dir_down),
    !LastCmdLink(~tid, lc_link) ]
--[ Command(~tid, c_ReachedMinLevel), StateTransition(~tid, st_MovingContinuouslyDown, st_IdleOffLevelDefined) ]->
  [ St(~tid, st_IdleOffLevelDefined, b_false, lv_def, tv_zero, dir_down) ]

//========================================
// SECTION 14: Frequency Control Transitions
//========================================

// FrequencyControlIdle, FQ feature, supported frequency -> success
rule Cmd_MoveToClosestFrequency_Supported:
  [ St(~tid, st_FrequencyControlIdle, B, L, tv_zero, f_FQ),
    !FreqSupport(~tid, fq_supported) ]
--[ Command(~tid, c_MoveToClosestFrequency), StateTransition(~tid, st_FrequencyControlIdle, st_FrequencyControlIdle) ]->
  [ St(~tid, st_FrequencyControlIdle, B, L, tv_zero, f_FQ) ]

// FrequencyControlIdle, FQ feature, unsupported frequency -> CONSTRAINT_ERROR
rule Cmd_MoveToClosestFrequency_NotSupported:
  [ St(~tid, st_FrequencyControlIdle, B, L, tv_zero, f_FQ),
    !FreqSupport(~tid, fq_notsupported) ]
--[ Command(~tid, c_MoveToClosestFrequency), StateTransition(~tid, st_FrequencyControlIdle, st_FrequencyControlIdle) ]->
  [ St(~tid, st_FrequencyControlIdle, B, L, tv_zero, f_FQ) ]

//========================================
// SECTION 15: Restrictions
//========================================

restriction unique_init:
  "All tid #i #j. ClusterInit(tid)@i & ClusterInit(tid)@j ==> #i = #j"

//========================================
// SECTION 16: Source Lemmas (REQUIRED)
//========================================

lemma sources [sources]:
  "All tid s1 s2 #i.
     StateTransition(tid, s1, s2)@i ==>
       Ex #j. ClusterInit(tid)@j & #j < #i"

//========================================
// SECTION 17: Simple Reachability Lemmas
//========================================

lemma exec_MoveToLevel:
  exists-trace
  "Ex tid #i. Command(tid, c_MoveToLevel)@i"

lemma exec_Move:
  exists-trace
  "Ex tid #i. Command(tid, c_Move)@i"

lemma exec_StepWithOnOff:
  exists-trace
  "Ex tid #i. Command(tid, c_StepWithOnOff)@i"

end