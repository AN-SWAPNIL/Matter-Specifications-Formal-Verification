    State(CurrentState, 'ActiveAccount_NoNodeBindings')
  ]

rule Login_ActiveAccount_NoNodeBindings_to_ActiveAccount_NoNodeBindings_20:
  [
    State(CurrentState, 'ActiveAccount_NoNodeBindings'),
    State(rate_limiter_too_many_unique_requests, 'false'),
    State(temp_id_expired, 'false'),
    State(lookup_account_success, 'true'),
    State(setup_pin_valid, 'false')
  ]
  --[ Login() ]->
  [
    State(CurrentState, 'ActiveAccount_NoNodeBindings')
  ]

rule Login_ActiveAccount_NoNodeBindings_to_ActiveAccount_NoNodeBindings_21:
  [
