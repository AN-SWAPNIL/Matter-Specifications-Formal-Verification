                "default": null,
                "conformance": "M",
                "summary": "Transition time"
              },
              {
                "id": "3",
                "name": "OptionsMask",
                "type": "OptionsBitmap",
                "constraint": "desc",
                "quality": null,
                "default": "0",
                "conformance": "M",
                "summary": "Options mask"
              },
              {
                "id": "4",
                "name": "OptionsOverride",
                "type": "OptionsBitmap",
                "constraint": "desc",
                "quality": null,
                "default": "0",
                "conformance": "M",
                "summary": "Options override"
              }
            ],
            "effect_on_receipt": "If StepSize==0, return INVALID_COMMAND; Create temporary Options bitmap; Change CurrentLevel by StepSize in StepMode direction; Set OnOff attribute accordingly; Adjust TransitionTime proportionally if Min/MaxLevel reached"
          },
          {
            "id": "0x07",
            "name": "StopWithOnOff",
            "direction": "client⇒server",
            "response": "DefaultResponse",
            "access": "O",
            "conformance": "M",
