theory Account_Login
begin

/*
 * Tamarin Protocol Model for Account Login
 * Generated from FSM JSON
 * Generated: 2025-12-16T15:28:49.856210
 * 
 * Cluster ID: 0x050E
 * States: 4
 * Transitions: 37
 */

builtins: diffie-hellman, signing, hashing

// Attribute value functions
functions: true/0, false/0, null/0

rule Init:
  [ Fr(~id) ]
  -->
  [
    State(active_account, vactive_account),
    State(null, vnull),
    State(CurrentState, 'NoActiveAccount')
  ]

rule GetSetupPIN_NoActiveAccount_to_RateLimitExceeded_0:
  [
    State(CurrentState, 'NoActiveAccount'),
    State(rate_limiter_too_many_unique_requests, 'true')
  ]
  --[ GetSetupPIN() ]->
  [
    State(CurrentState, 'RateLimitExceeded'),
    State(rate_limit_block_active, 'true')
  ]

rule GetSetupPIN_NoActiveAccount_to_NoActiveAccount_1:
  [
    State(CurrentState, 'NoActiveAccount'),
    State(rate_limiter_too_many_unique_requests, 'false')
  ]
  --[ GetSetupPIN() ]->
  [
    State(CurrentState, 'NoActiveAccount')
  ]

rule GetSetupPIN_ActiveAccount_NoNodeBindings_to_RateLimitExceeded_2:
  [
    State(CurrentState, 'ActiveAccount_NoNodeBindings'),
    State(rate_limiter_too_many_unique_requests, 'true')
  ]
  --[ GetSetupPIN() ]->
  [
    State(CurrentState, 'RateLimitExceeded'),
    State(rate_limit_block_active, 'true')
  ]

rule GetSetupPIN_ActiveAccount_NoNodeBindings_to_ActiveAccount_NoNodeBindings_3:
