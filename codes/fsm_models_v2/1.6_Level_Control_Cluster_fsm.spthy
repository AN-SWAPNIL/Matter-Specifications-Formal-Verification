theory Level_Control_Cluster
begin

/*
 * Tamarin Protocol Security Model for Level Control Cluster
 * Generated from Enhanced FSM JSON (v2.0)
 * Generated: 2025-12-24T22:20:03.145808
 * 
 * Cluster ID: 0x0008
 * Revision: 6
 * 
 * Model Statistics:
 * - States: 2
 * - Transitions: 23
 * - Action Facts: 28
 * - Security Properties: 0
 * 
 * This model supports security analysis with:
 * - Parameterized action facts for precise tracing
 * - Message passing (In/Out) for protocol modeling
 * - Fresh value generation for cryptographic material
 * - Verifiable security lemmas
 */

builtins: hashing, symmetric-encryption

// ============================================================================
// Functions
// ============================================================================

// Boolean and null constants
functions: true/0, false/0, null/0

// Empty value marker
functions: empty/0

// Response status
functions: SUCCESS/0, FAILURE/0

// ============================================================================
// Restrictions
// ============================================================================

// Once restriction for unique events
restriction Once:
    "All x #i #j. Once(x)@i & Once(x)@j ==> #i = #j"


// ============================================================================
// Initialization
// ============================================================================

// Feature flags (~feature_X) are fresh values representing configuration
// They can be constrained to specific values ('true'/'false') in guards
// This cluster has Startup transitions - PowerCycle fact enables them
rule Server_Init:
    [ Fr(~endpoint_id), Fr(~feature_fq), Fr(~feature_lt), Fr(~feature_oo) ]
    --[ ServerInit(~endpoint_id), Once(<'server_init', ~endpoint_id>) ]->
    [
        !Server(~endpoint_id),
        ServerState(~endpoint_id, 'OffState'),
        RateLimitCounter(~endpoint_id, 'zero'),
        Out(~endpoint_id),
        !FeatureConfig(~endpoint_id, 'FQ', ~feature_fq),
        !FeatureConfig(~endpoint_id, 'LT', ~feature_lt),
        !FeatureConfig(~endpoint_id, 'OO', ~feature_oo)  // Endpoint is public - adversary can address server
    ]


// ============================================================================
// Power Cycle Event (Triggers Startup Transitions)
// ============================================================================

// Power cycle can occur anytime - generates PowerCycle fact that startup rules consume
rule Power_Cycle:
    [
        !Server(endpoint),
        ServerState(endpoint, current_state),
        Fr(~attr_startupcurrentlevel)
    ]
    --[
        PowerCycleEvent(endpoint),
        Once(<'power_cycle', endpoint>)
    ]->
    [
        !Server(endpoint),
        ServerState(endpoint, current_state),
        PowerCycle(endpoint),
        !AttrState(endpoint, 'StartUpCurrentLevel', ~attr_startupcurrentlevel)
    ]

// Alternative: Initial power-on (first boot scenario)
rule Initial_Power_On:
    [
        !Server(endpoint),
        ServerState(endpoint, state)
    ]
    --[
        InitialPowerOn(endpoint)
    ]->
    [
        !Server(endpoint),
        ServerState(endpoint, state),
        PowerCycle(endpoint)
    ]


// ============================================================================
// Fresh Value Generation
// ============================================================================

rule Create_TempAccountIdentifier:
    let temp_id = h(<~account, ~nonce>)
    in
    [ Fr(~account), Fr(~nonce), Fr(~setup_pin), Fr(~validity) ]
    --[ 
        TempIdCreated(temp_id, ~account),
        AccountRegistered(~account, temp_id, ~setup_pin)
    ]->
    [
        !AccountMapping(temp_id, ~account, ~setup_pin, ~validity),
        Out(temp_id)  // Attacker can observe temp_id
    ]

rule TempId_Expires:
    [ !AccountMapping(temp_id, account, setup_pin, validity) ]
    --[ TempIdExpired(temp_id) ]->
    [ !AccountMapping_Expired(temp_id, account, setup_pin) ]


