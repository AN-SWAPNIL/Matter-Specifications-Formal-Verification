  ]
  --[ GetSetupPIN() ]->
  [
    State(CurrentState, 'RateLimitExceeded'),
    State(rate_limit_block_active, 'true')
  ]

rule GetSetupPIN_ActiveAccount_WithNodeBindings_to_ActiveAccount_WithNodeBindings_5:
  [
    State(CurrentState, 'ActiveAccount_WithNodeBindings'),
    State(rate_limiter_too_many_unique_requests, 'false')
  ]
  --[ GetSetupPIN() ]->
  [
    State(CurrentState, 'ActiveAccount_WithNodeBindings')
  ]

rule GetSetupPIN_RateLimitExceeded_to_RateLimitExceeded_6:
  [
    State(CurrentState, 'RateLimitExceeded'),
    State(rate_limiter_too_many_unique_requests, 'true')
  ]
  --[ GetSetupPIN() ]->
  [
    State(CurrentState, 'RateLimitExceeded')
  ]

rule RateLimitWindowReset_RateLimitExceeded_to_NoActiveAccount_7:
  [
    State(CurrentState, 'RateLimitExceeded'),
    State(active_account, vactive_account),
    State(null, vnull)
  ]
  --[ RateLimitWindowReset() ]->
  [
    State(CurrentState, 'NoActiveAccount'),
    State(rate_limit_block_active, 'false')
  ]

rule RateLimitWindowReset_RateLimitExceeded_to_ActiveAccount_NoNodeBindings_8:
  [
    State(CurrentState, 'RateLimitExceeded'),
    State(active_account, vactive_account),
    State(null, vnull),
    State(exists_node_binding, 'false')
  ]
  --[ RateLimitWindowReset() ]->
  [
    State(CurrentState, 'ActiveAccount_NoNodeBindings'),
    State(rate_limit_block_active, 'false')
  ]

rule RateLimitWindowReset_RateLimitExceeded_to_ActiveAccount_WithNodeBindings_9:
  [
    State(CurrentState, 'RateLimitExceeded'),
    State(active_account, vactive_account),
    State(null, vnull),
    State(exists_node_binding, 'true')
  ]
  --[ RateLimitWindowReset() ]->
  [
    State(CurrentState, 'ActiveAccount_WithNodeBindings'),
    State(rate_limit_block_active, 'false')
  ]

rule Login_NoActiveAccount_to_RateLimitExceeded_10:
  [
    State(CurrentState, 'NoActiveAccount'),
    State(rate_limiter_too_many_unique_requests, 'true')
  ]
  --[ Login() ]->
  [
    State(CurrentState, 'RateLimitExceeded'),
    State(rate_limit_block_active, 'true')
  ]

rule Login_NoActiveAccount_to_NoActiveAccount_11:
  [
    State(CurrentState, 'NoActiveAccount'),
    State(rate_limiter_too_many_unique_requests, 'false'),
    State(temp_id_expired, 'true')
  ]
  --[ Login() ]->
  [
    State(CurrentState, 'NoActiveAccount')
  ]

rule Login_NoActiveAccount_to_NoActiveAccount_12:
  [
    State(CurrentState, 'NoActiveAccount'),
    State(rate_limiter_too_many_unique_requests, 'false'),
    State(temp_id_expired, 'false'),
    State(lookup_account_success, 'false')
  ]
  --[ Login() ]->
  [
    State(CurrentState, 'NoActiveAccount')
  ]

rule Login_NoActiveAccount_to_NoActiveAccount_13:
  [
    State(CurrentState, 'NoActiveAccount'),
    State(rate_limiter_too_many_unique_requests, 'false'),
    State(temp_id_expired, 'false'),
    State(lookup_account_success, 'true'),
    State(setup_pin_valid, 'false')
  ]
  --[ Login() ]->
  [
    State(CurrentState, 'NoActiveAccount')
  ]

