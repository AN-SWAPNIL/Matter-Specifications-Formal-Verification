                "quality": null,
                "default": null,
                "conformance": "M",
                "summary": "Indicates the scene identifier in the Scene Table."
              }
            ],
            "effect_on_receipt": "set status := SUCCESS\nif GroupID != 0 then\n    if not endpoint.GroupTable.has_entry(GroupID) then\n        set status := INVALID_COMMAND\n        goto generate_response\nif status == SUCCESS then\n    if not SceneTable.has_scene(GroupID, SceneID) then\n        set status := NOT_FOUND\n        goto generate_response\nif status == SUCCESS then\n    SceneTable.remove_scene(GroupID, SceneID)\ngenerate_response:\nif command_received_as_unicast then\n    call generate_RemoveSceneResponse(status, GroupID, SceneID)"
          },
