    },
    {
      "cluster_info": {
        "cluster_name": "Scenes Management Cluster",
        "revision_history": [
          {
            "revision": "1",
            "description": "Initial version based on ZCL Scenes Cluster. Cluster ID updated to 0x0062, name to Scenes Management. Removed provisional status. Removed attributes (SceneCount, CurrentScene, CurrentGroup, SceneValid, NameSupport), features (Explicit, TableSize, FabricScenes), and commands (EnhancedAddScene, EnhancedAddSceneResponse, EnhancedViewScene, EnhancedViewSceneResponse). TransitionTime field in AddScene, ViewSceneResponse, RecallScene changed to milliseconds.",
            "date": null
          }
        ],
        "cluster_id": [
          {
            "id": "0x0062",
            "name": "Scenes Management",
            "summary": "Manages scenes, allowing devices to store and recall specific states. Updated from ZCL Scenes Cluster, with ID 0x0062. Supports scene naming."
          }
        ],
        "classification": [
          {
            "hierarchy": "Base",
            "role": "Application",
            "scope": "Endpoint",
            "pics_code": "S",
            "summary": "This cluster is a fundamental application-level component, operating at the endpoint scope, indicating its direct interaction with a specific device function."
          }
        ],
        "features": [
          {
            "bit": "0",
            "code": "SN",
            "name": "SceneNames",
            "summary": "The ability to store a name for a scene when a scene is added. Pseudocode: IF SceneNames THEN Scene.Name = provided_name",
            "conformance": "O",
            "dependencies": null
          }
        ],
        "Dependencies": [
          {
            "id": "1.4.5",
            "title": "Mandatory co-implementation of Scenes Management and Groups",
            "clusters_involved": [
              "Scenes Management (0x0005)",
              "Groups (0x0004)"
            ],
            "trigger_condition": "IF endpoint implements Scenes Management server cluster",
            "effect": "Endpoint SHALL also implement Groups server cluster.",
            "summary": "Pseudocode: IF (Implements(ScenesManagement.Server)) THEN Implement(Groups.Server)"
          },
          {
            "id": "1.4.5",
            "title": "Groups cluster commands affecting Scenes Management",
            "clusters_involved": [
              "Groups (0x0004)",
              "Scenes Management (0x0005)"
            ],
            "trigger_condition": "IF Groups.RemoveGroup command OR Groups.RemoveAllGroups command is invoked",
            "effect": "Corresponding scenes in Scenes Management cluster SHALL be removed.",
            "summary": "Pseudocode: IF (Groups.RemoveGroup() OR Groups.RemoveAllGroups()) THEN ScenesManagement.RemoveScenesAssociatedWithGroup()"
          },
          {
            "id": "1.4.6",
            "title": "Fabric removal impacting Scenes Management data",
            "clusters_involved": [
              "Operational Credentials (0x003E)",
              "Scenes Management (0x0005)"
            ],
            "trigger_condition": "IF Operational Credentials.RemoveFabric command is invoked",
            "effect": "All scenes data for the associated fabric SHALL be removed from the Scenes Management cluster's Scene Table.",
            "summary": "Pseudocode: IF (OperationalCredentials.RemoveFabric(fabricId)) THEN ScenesManagement.RemoveAllScenesForFabric(fabricId)"
          }
        ],
        "Handling of fabric-scoping": [
          {
            "rule": "Attributes and commands are scoped to accessing fabric only",
            "exception": "SceneValid field of FabricSceneInfo attribute",
            "pseudocode": "pseudocode representation if applicable"
          },
          {
            "rule": "Operations without an accessing fabric SHALL fail",
            "status_code": "UNSUPPORTED_ACCESS",
            "pseudocode": "if accessing_fabric == null then return UNSUPPORTED_ACCESS"
          },
          {
            "rule": "Scenes with same Group ID + Scene ID across fabrics are fabric-isolated",
            "pseudocode": "lookup_scene := scene_table[accessing_fabric][group_id][scene_id]"
          },
          {
            "rule": "Removing a fabric clears associated scenes",
            "trigger": "RemoveFabric command (Operational Credentials Cluster)",
            "pseudocode": "on RemoveFabric(fabric): delete scene_table[fabric]"
          },
          {
            "rule": "Scene Table capacity per fabric < half of SceneTableSize (max 253)",
            "pseudocode": "if scene_table[fabric].count >= floor(SceneTableSize/2) or > 253 then apply resource_exhaustion_behavior()"
          }
        ],
        "data_types": [
          {
            "name": "CopyModeBitmap",
            "base_type": "map8",
            "constraint": null,
            "values": [
              {
                "value": "0",
                "name": "CopyAllScenes",
                "summary": "Copy all scenes in the scene table",
                "conformance": "M"
              }
            ]
          },
          {
            "name": "SceneInfoStruct",
            "base_type": "struct",
            "constraint": null,
            "values": [
              {
                "value": "0",
                "name": "SceneCount",
                "summary": "This field SHALL indicate the number of scenes currently used in the server’s Scene Table on the endpoint where the Scenes Management cluster appears. This only includes the count for the associated fabric.",
                "conformance": "M"
              },
              {
                "value": "1",
                "name": "CurrentScene",
                "summary": "This field SHALL indicate the scene identifier of the scene last invoked on the associated fabric. If no scene has been invoked, the value of this field SHALL be 0xFF, the undefined scene identifier.",
                "conformance": "M"
              },
              {
                "value": "2",
                "name": "CurrentGroup",
                "summary": "This field SHALL indicate the group identifier of the scene last invoked on the associated fabric, or 0 if the scene last invoked is not associated with a group.",
                "conformance": "M"
              },
              {
                "value": "3",
                "name": "SceneValid",
                "summary": "Indicates if server state corresponds to CurrentScene/CurrentGroup. TRUE if valid, FALSE otherwise. Set to FALSE if a Scenes ('S') designated attribute in another cluster is modified, or if current scene is modified by RecallScene/StoreScene commands. If FALSE, CurrentScene/CurrentGroup hold last invoked scene/group for that fabric, or default values if none invoked.",
                "conformance": "M"
              },
              {
                "value": "4",
                "name": "RemainingCapacity",
                "summary": "This field SHALL indicate the remaining capacity of the Scene Table on this endpoint for the accessing fabric. Note that this value may change between reads, even if no entries are added or deleted on the accessing fabric, due to other clients associated with other fabrics adding or deleting entries that impact the resource usage on the device.",
                "conformance": "M"
              }
            ]
          },
          {
            "name": "AttributeValuePairStruct",
            "base_type": "struct",
            "constraint": null,
            "values": [
              {
                "value": "0",
                "name": "AttributeID",
                "summary": "Present in ExtensionFieldSetStruct. Determines which Value* field is used based on attribute data type. SHALL NOT refer to attributes without the Scenes (\"S\") designation in their cluster specification's Quality column.",
                "conformance": "M"
              },
              {
                "value": "1",
                "name": "ValueUnsigned8",
                "summary": "Indicates attribute value in an extension field set for a given AttributeID under ExtensionFieldSetStruct’s ClusterID. Used when AttributeID's data type is bool, map8, or uint8.",
                "conformance": "O.a"
              },
              {
                "value": "2",
                "name": "ValueSigned8",
                "summary": "Indicates attribute value in an extension field set for a given AttributeID under ExtensionFieldSetStruct’s ClusterID. Used when AttributeID's data type is int8.",
                "conformance": "O.a"
              },
              {
                "value": "3",
                "name": "ValueUnsigned16",
                "summary": "Indicates attribute value in an extension field set for a given AttributeID under ExtensionFieldSetStruct’s ClusterID. Used when AttributeID's data type is map16 or uint16.",
                "conformance": "O.a"
              },
              {
                "value": "4",
                "name": "ValueSigned16",
                "summary": "Indicates attribute value in an extension field set for a given AttributeID under ExtensionFieldSetStruct’s ClusterID. Used when AttributeID's data type is int16.",
                "conformance": "O.a"
              },
              {
                "value": "5",
                "name": "ValueUnsigned32",
                "summary": "Indicates attribute value in an extension field set for a given AttributeID under ExtensionFieldSetStruct’s ClusterID. Used when AttributeID's data type is map32, uint24, or uint32.",
                "conformance": "O.a"
              },
              {
                "value": "6",
                "name": "ValueSigned32",
                "summary": "Indicates attribute value in an extension field set for a given AttributeID under ExtensionFieldSetStruct’s ClusterID. Used when AttributeID's data type is int24 or int32.",
                "conformance": "O.a"
              },
              {
                "value": "7",
                "name": "ValueUnsigned64",
                "summary": "Indicates attribute value in an extension field set for a given AttributeID under ExtensionFieldSetStruct’s ClusterID. Used when AttributeID's data type is map64, uint40, uint48, uint56, or uint64.",
                "conformance": "O.a"
              },
              {
                "value": "8",
                "name": "ValueSigned64",
                "summary": "Indicates attribute value in an extension field set for a given AttributeID under ExtensionFieldSetStruct’s ClusterID. Used when AttributeID's data type is int40, int48, int56, or int64.",
                "conformance": "O.a"
              }
            ]
          },
          {
            "name": "ExtensionFieldSetStruct",
            "base_type": "struct",
            "constraint": null,
            "values": [
              {
                "value": "0",
                "name": "ClusterID",
                "summary": "This field SHALL indicate the cluster-id of the cluster whose attributes are in the AttributeValueList field.",
                "conformance": "M"
              },
              {
                "value": "1",
                "name": "AttributeValueList",
                "summary": "This field SHALL indicate a set of attributes and their values which are stored as part of a scene. Attributes which do not have the Scenes (\"S\") designation in the Quality column of their cluster specification SHALL NOT be used in the AttributeValueList field.",
                "conformance": "M"
              }
            ]
          },
          {
            "name": "LogicalSceneTableEntryStruct",
            "base_type": "struct",
            "constraint": null,
            "values": [
              {
                "value": "0",
                "name": "SceneGroupID",
                "summary": "This field is the group identifier for which this scene applies, or 0 if the scene is not associated with a group.",
                "conformance": "M"
              },
              {
                "value": "1",
                "name": "SceneID",
                "summary": "This field is unique within this group, which is used to identify this scene.",
                "conformance": "M"
              },
              {
                "value": "2",
                "name": "SceneName",
                "summary": "The field is the name of the scene. If scene names are not supported, any commands that write a scene name SHALL simply discard the name, and any command that returns a scene name SHALL return an empty string.",
                "conformance": "SN"
              },
              {
                "value": "3",
                "name": "SceneTransitionTime",
                "summary": "This field is the amount of time, in milliseconds, it will take for a cluster to change from its current state to the requested state.",
                "conformance": "M"
              },
              {
                "value": "4",
                "name": "ExtensionFields",
                "summary": "Holds a list of ExtensionFieldSetStructs, each containing attribute values for a Scenes-supporting cluster on the endpoint. Only attributes with 'S' quality are used. A scene aggregates these fields across all clusters.",
                "conformance": "M"
              }
            ]
          }
        ],
        "attributes": [
          {
            "id": "0x0000",
            "name": "LastConfiguredBy",
            "type": "node-id",
            "constraint": "all",
            "quality": "X",
            "default": "null",
            "access": "R V",
            "conformance": "O",
            "summary": "Indicates the Node ID of the node that last configured the Scene Table. Null if not configured or unknown. Node ID is scoped to the accessing fabric.",
