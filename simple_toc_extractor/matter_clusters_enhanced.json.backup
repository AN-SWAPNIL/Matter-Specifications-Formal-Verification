            "fabric_sensitive": true,
            "scene_capable": false
          }
        ],
        "commands": [
          {
            "id": "0x00",
            "name": "AddScene",
            "direction": "client ⇒ server",
            "response": "AddSceneResponse",
            "access": "F M",
            "conformance": "M",
            "summary": "Allows a client to add a new scene or replace an existing one in the server's Scene Table. It includes scene details like group ID, scene ID, transition time, name, and extension field sets for other clusters.",
            "timing": null,
            "fields": [
              {
                "id": "0",
                "name": "GroupID",
                "type": "group-id",
                "constraint": "all",
                "quality": null,
                "default": null,
                "conformance": "M",
                "summary": "Indicates the group identifier in the Group Table."
              },
              {
                "id": "1",
                "name": "SceneID",
                "type": "uint8",
                "constraint": "max 254",
                "quality": null,
                "default": null,
                "conformance": "M",
                "summary": "Indicates the scene identifier in the Scene Table."
              },
              {
                "id": "2",
                "name": "TransitionTime",
                "type": "uint32",
                "constraint": "max 60000000",
                "quality": null,
                "default": null,
                "conformance": "M",
                "summary": "Indicates the transition time of the scene, measured in milliseconds."
              },
              {
                "id": "3",
                "name": "SceneName",
                "type": "string",
                "constraint": "max 16",
                "quality": null,
                "default": null,
                "conformance": "M",
                "summary": "Indicates the name of the scene."
              },
              {
                "id": "4",
                "name": "ExtensionFieldSetStructs",
                "type": "list[ExtensionFieldSetStruct]",
                "constraint": "desc",
                "quality": null,
                "default": null,
                "conformance": "M",
                "summary": "Contains the list of extension fields. It is not mandatory for an extension field set to be included for every cluster on that endpoint that has a defined extension field set. Extension field sets MAY be omitted, including the case of no extension field sets at all."
              }
            ],
            "effect_on_receipt": "set status := SUCCESS\nif GroupID != 0 then\n    if not endpoint.GroupTable.has_entry(GroupID) then\n        set status := INVALID_COMMAND\n        goto generate_response\nif status == SUCCESS and not ExtensionFieldSetStructs.is_valid_format() then\n    set status := INVALID_COMMAND\n    goto generate_response\nif status == SUCCESS then\n    if SceneTable.has_scene(GroupID, SceneID) then\n        // Existing scene will be replaced\n    else if not SceneTable.has_capacity_for_fabric(current_fabric) then\n        set status := RESOURCE_EXHAUSTED\n        goto generate_response\nif status == SUCCESS then\n    set new_scene_entry := create_scene_entry_from_command_fields(command_data)\n    for each ext_field_set in new_scene_entry.ExtensionFieldSetStructs do\n        if not endpoint.has_cluster(ext_field_set.ClusterID) then\n            remove ext_field_set from new_scene_entry.ExtensionFieldSetStructs\n        else\n            for each attr_value_pair in ext_field_set.AttributeValuePairs do\n                if not endpoint.cluster(ext_field_set.ClusterID).has_attribute(attr_value_pair.AttributeID) then\n                    remove attr_value_pair from ext_field_set.AttributeValuePairs\n    // Handle duplicate ClusterIDs: last one in list is recorded\n    // Handle duplicate AttributeIDs within ExtensionFieldSet: last one is recorded\n    SceneTable.add_or_replace_scene(new_scene_entry)\n    set SceneTable.entry(GroupID, SceneID).SceneTransitionTime := TransitionTime\ngenerate_response:\nif command_received_as_unicast then\n    call generate_AddSceneResponse(status, GroupID, SceneID)"
          },
          {
            "id": "0x00",
            "name": "AddSceneResponse",
            "direction": "client ⇐ server",
            "response": "N",
            "access": null,
            "conformance": "M",
            "summary": "Generated in response to an AddScene command, indicating the status of the operation and the group/scene identifiers involved.",
            "timing": null,
            "fields": [
              {
                "id": "0",
                "name": "Status",
                "type": "status",
                "constraint": "desc",
                "quality": null,
                "default": null,
                "conformance": "M",
                "summary": "Indicates the status of the AddScene command receipt."
              },
              {
                "id": "1",
                "name": "GroupID",
                "type": "group-id",
                "constraint": "all",
                "quality": null,
                "default": null,
                "conformance": "M",
                "summary": "Set to the GroupID field of the received AddScene command."
              },
              {
                "id": "2",
                "name": "SceneID",
                "type": "uint8",
                "constraint": "max 254",
                "quality": null,
                "default": null,
                "conformance": "M",
                "summary": "Set to the SceneID field of the received AddScene command."
              }
            ],
            "effect_on_receipt": "This command is generated in response to a received AddScene command."
          },
          {
            "id": "0x01",
            "name": "ViewScene",
            "direction": "client ⇒ server",
            "response": "ViewSceneResponse",
            "access": "F O",
            "conformance": "M",
            "summary": "Allows a client to request details of a specific scene from the server's Scene Table.",
            "timing": null,
            "fields": [
              {
                "id": "0",
                "name": "GroupID",
                "type": "group-id",
                "constraint": "all",
                "quality": null,
                "default": null,
                "conformance": "M",
                "summary": "Indicates the group identifier in the Group Table."
              },
              {
                "id": "1",
                "name": "SceneID",
                "type": "uint8",
                "constraint": "max 254",
                "quality": null,
                "default": null,
                "conformance": "M",
                "summary": "Indicates the scene identifier in the Scene Table."
              }
            ],
            "effect_on_receipt": "set status := SUCCESS\nset scene_entry := null\nif GroupID != 0 then\n    if not endpoint.GroupTable.has_entry(GroupID) then\n        set status := INVALID_COMMAND\n        goto generate_response\nif status == SUCCESS then\n    if not SceneTable.has_scene(GroupID, SceneID) then\n        set status := NOT_FOUND\n        goto generate_response\nif status == SUCCESS then\n    set scene_entry := SceneTable.retrieve_scene(GroupID, SceneID)\ngenerate_response:\nif command_received_as_unicast then\n    call generate_ViewSceneResponse(status, GroupID, SceneID, scene_entry.TransitionTime, scene_entry.SceneName, scene_entry.ExtensionFieldSetStructs)"
          },
          {
            "id": "0x01",
            "name": "ViewSceneResponse",
            "direction": "client ⇐ server",
