        StateTransition(endpoint, 'DelayedOff', 'DelayedOff'),
        TimerTick(endpoint),
        TimerTickDelayedOffDecrement(endpoint, off_wait_time_after)
    ]->
    [
        ServerState(endpoint, 'DelayedOff'),
        !FeatureConfig(endpoint, 'LT', 'true'),
        Out(<'TimerTick_Internal', SUCCESS>),
        !Server(endpoint)
    ]

// When OffWaitTime reaches 0, delayed-off behavior terminates
// Guard: OnOff == FALSE and OffWaitTime == 1 and OffWaitTime != 0xFFFF and OnTime != 0xFFFF
// Guard: OnOff == FALSE
// Guard: OffWaitTime == 1
rule Timer_DelayedOff_to_BaseOff_T29:
    [
        ServerState(endpoint, 'DelayedOff'),
        !FeatureConfig(endpoint, 'LT', 'true'),
        In(<'TimerTick_Internal', endpoint>),
        !Server(endpoint)
    ]
    --[
        Timer(endpoint),
        StateTransition(endpoint, 'DelayedOff', 'BaseOff'),
        TimerTick(endpoint),
        TimerTickDelayedOffExpired(endpoint)
    ]->
    [
        ServerState(endpoint, 'BaseOff'),
        !FeatureConfig(endpoint, 'LT', 'true'),
        Out(<'TimerTick_Internal', SUCCESS>),
        !Server(endpoint)
    ]

// ============================================================================
// Verification Lemmas
// ============================================================================

// Basic reachability - server can initialize
lemma server_init_reachable:
    exists-trace
    "Ex endpoint #i. ServerInit(endpoint)@i"


// Reachability: Base state with OnOff == FALSE and no active timed-on or delayed-off behavior
lemma state_BaseOff_reachable:
    exists-trace
    "Ex endpoint from_state #i. StateTransition(endpoint, from_state, 'BaseOff')@i"


// Reachability: Base state with OnOff == TRUE and no active timed-on or delayed-off behavior
lemma state_BaseOn_reachable:
    exists-trace
    "Ex endpoint from_state #i. StateTransition(endpoint, from_state, 'BaseOn')@i"


// Reachability: State where OnOff == TRUE and OnTime is being decremented periodically
lemma state_TimedOn_reachable:
    exists-trace
    "Ex endpoint from_state #i. StateTransition(endpoint, from_state, 'TimedOn')@i"


// Reachability: State where OnOff == FALSE and OffWaitTime is being decremented periodically
lemma state_DelayedOff_reachable:
    exists-trace
    "Ex endpoint from_state #i. StateTransition(endpoint, from_state, 'DelayedOff')@i"


end