theory LevelControl_Cluster_Matter_FSM begin

builtins: hashing

functions:
  b_true/0, b_false/0,
  st_Idle/0,
  st_TransitionActive/0,
  tv_zero/0,
  tv_pos/0,
  f_OO/0,
  f_LT/0,
  f_FQ/0,
  lvl_val/0,
  lvl_min/0,
  lvl_max/0,
  freq_val/0,
  St/12,
  Config/4

// Actions are declared implicitly when used in rules (in the --[ ]-> part)
// No separate actions: section is needed in Tamarin

// Unified state fact for Level Control cluster instance:
// St(tid, State,
//    Feature_OnOff_supported, Feature_Lighting_supported, Feature_Frequency_supported,
//    CurrentLevel_set, CurrentLevel, RemainingTime,
//    OnOff_present, OnOff,
//    CurrentFrequency_set, CurrentFrequency)

rule Init_Features_All:
  [ Fr(~tid) ]
--[ ClusterInit(~tid) ]->
  [ St(~tid, st_Idle,
        f_OO, f_LT, f_FQ,
        b_true, lvl_val, tv_zero,
        b_true, b_false,
        b_true, freq_val),
    !Config(~tid, f_OO, f_LT, f_FQ) ]

rule Init_Features_NoFreq:
  [ Fr(~tid) ]
--[ ClusterInit(~tid) ]->
  [ St(~tid, st_Idle,
        f_OO, f_LT, b_false,
        b_true, lvl_val, tv_zero,
        b_true, b_false,
        b_false, freq_val),
    !Config(~tid, f_OO, f_LT, b_false) ]

rule Init_Features_LightingOnly:
  [ Fr(~tid) ]
--[ ClusterInit(~tid) ]->
  [ St(~tid, st_Idle,
        b_false, f_LT, b_false,
        b_true, lvl_val, tv_zero,
        b_false, b_false,
        b_false, freq_val),
    !Config(~tid, b_false, f_LT, b_false) ]

rule Init_Features_Minimal:
  [ Fr(~tid) ]
--[ ClusterInit(~tid) ]->
  [ St(~tid, st_Idle,
        b_false, b_false, b_false,
        b_true, lvl_val, tv_zero,
        b_false, b_false,
        b_false, freq_val),
    !Config(~tid, b_false, b_false, b_false) ]

//=======================================================
// Core command skeletons (abstracted, no arithmetic)
//=======================================================

rule Cmd_MoveToLevel_Immediate_Idle:
  [ St(~tid, st_Idle, fo, fl, fq,
        cl_set, cl, rt,
        op, oo,
        cf_set, cf) ]
--[ Command(~tid, 'MoveToLevel'),
    StateTransition(~tid, st_Idle, st_Idle) ]->
  [ St(~tid, st_Idle, fo, fl, fq,
        cl_set, lvl_val, tv_zero,
        op, oo,
        cf_set, cf) ]

