          {
            "id": "0x03",
            "name": "RemoveAllScenes",
            "direction": "client ⇒ server",
            "response": "RemoveAllScenesResponse",
            "access": "F M",
            "conformance": "M",
            "summary": "Allows a client to remove all scenes associated with a specific group identifier from the server's Scene Table.",
            "timing": null,
            "fields": [
              {
                "id": "0",
                "name": "GroupID",
                "type": "group-id",
                "constraint": "all",
                "quality": null,
                "default": null,
                "conformance": "M",
                "summary": "Indicates the group identifier in the Group Table."
              }
            ],
            "effect_on_receipt": "set status := SUCCESS\nif GroupID != 0 then\n    if not endpoint.GroupTable.has_entry(GroupID) then\n        set status := INVALID_COMMAND\n        goto generate_response\nif status == SUCCESS then\n    SceneTable.remove_all_scenes_for_group(GroupID)\ngenerate_response:\nif command_received_as_unicast then\n    call generate_RemoveAllScenesResponse(status, GroupID)"
          },
          {
            "id": "0x03",
            "name": "RemoveAllScenesResponse",
            "direction": "client ⇐ server",
            "response": "N",
            "access": null,
            "conformance": "M",
            "summary": "Generated in response to a RemoveAllScenes command, indicating the status of the operation and the group identifier involved.",
            "timing": null,
            "fields": [
              {
                "id": "0",
                "name": "Status",
                "type": "status",
                "constraint": "desc",
                "quality": null,
                "default": null,
                "conformance": "M",
                "summary": "Indicates the status of the RemoveAllScenes command receipt."
              },
              {
                "id": "1",
                "name": "GroupID",
                "type": "group-id",
                "constraint": "all",
                "quality": null,
                "default": null,
                "conformance": "M",
                "summary": "Set to the GroupID field of the received RemoveAllScenes command."
              }
            ],
            "effect_on_receipt": "This command is generated in response to a received RemoveAllScenes command."
          },
          {
            "id": "0x04",
            "name": "StoreScene",
            "direction": "client ⇒ server",
            "response": "StoreSceneResponse",
            "access": "F M",
            "conformance": "M",
            "summary": "Allows a client to store the current state of the endpoint's clusters as a new or existing scene in the Scene Table.",
            "timing": null,
            "fields": [
              {
                "id": "0",
                "name": "GroupID",
                "type": "group-id",
                "constraint": "all",
                "quality": null,
                "default": null,
                "conformance": "M",
                "summary": "Indicates the group identifier in the Group Table."
              },
              {
                "id": "1",
                "name": "SceneID",
                "type": "uint8",
                "constraint": "max 254",
                "quality": null,
                "default": null,
                "conformance": "M",
                "summary": "Indicates the scene identifier in the Scene Table."
              }
            ],
            "effect_on_receipt": "set status := SUCCESS\nif GroupID != 0 then\n    if not endpoint.GroupTable.has_entry(GroupID) then\n        set status := INVALID_COMMAND\n        goto generate_response\nif status == SUCCESS then\n    if SceneTable.has_scene(GroupID, SceneID) then\n        // Existing scene will be updated\n    else if not SceneTable.has_capacity_for_fabric(current_fabric) then\n        set status := RESOURCE_EXHAUSTED\n        goto generate_response\nif status == SUCCESS then\n    set current_extension_field_sets := get_current_state_extension_field_sets(endpoint)\n    if SceneTable.has_scene(GroupID, SceneID) then\n        set scene_entry := SceneTable.get_scene(GroupID, SceneID)\n        set scene_entry.ExtensionFieldSets := current_extension_field_sets\n        SceneTable.update_scene(scene_entry)\n    else\n        set new_scene_entry := create_scene_entry(GroupID, SceneID)\n        set new_scene_entry.SceneTransitionTime := 0\n        set new_scene_entry.SceneName := \"\"\n        set new_scene_entry.ExtensionFieldSets := current_extension_field_sets\n        SceneTable.add_scene(new_scene_entry)\ngenerate_response:\nif command_received_as_unicast then\n    call generate_StoreSceneResponse(status, GroupID, SceneID)\n// Note: If a scene to be stored requires a TransitionTime field and/or a SceneName field, these must be set up by a prior AddScene command."
          },
          {
            "id": "0x04",
            "name": "StoreSceneResponse",
            "direction": "client ⇐ server",
            "response": "N",
            "access": null,
            "conformance": "M",
            "summary": "Generated in response to a StoreScene command, indicating the status of the operation and the group/scene identifiers involved.",
            "timing": null,
            "fields": [
              {
                "id": "0",
                "name": "Status",
                "type": "status",
                "constraint": "desc",
                "quality": null,
                "default": null,
                "conformance": "M",
                "summary": "Indicates the status of the StoreScene command receipt."
              },
              {
                "id": "1",
                "name": "GroupID",
                "type": "group-id",
                "constraint": "all",
                "quality": null,
                "default": null,
                "conformance": "M",
                "summary": "Set to the GroupID field of the received StoreScene command."
              },
              {
                "id": "2",
                "name": "SceneID",
                "type": "uint8",
                "constraint": "max 254",
                "quality": null,
                "default": null,
                "conformance": "M",
                "summary": "Set to the SceneID field of the received StoreScene command."
              }
            ],
            "effect_on_receipt": "This command is generated in response to a received StoreScene command."
          },
          {
            "id": "0x05",
            "name": "RecallScene",
            "direction": "client ⇒ server",
            "response": "Y",
            "access": "F O",
            "conformance": "M",
            "summary": "Allows a client to recall a previously stored scene, applying its saved state to the endpoint's clusters.",
            "timing": null,
            "fields": [
              {
                "id": "0",
                "name": "GroupID",
                "type": "group-id",
                "constraint": "all",
                "quality": null,
                "default": null,
                "conformance": "M",
                "summary": "Indicates the group identifier in the Group Table."
              },
              {
                "id": "1",
                "name": "SceneID",
                "type": "uint8",
                "constraint": "max 254",
                "quality": null,
                "default": null,
                "conformance": "M",
                "summary": "Indicates the scene identifier in the Scene Table."
              },
              {
                "id": "2",
                "name": "TransitionTime",
                "type": "uint32",
                "constraint": "max 60000000",
                "quality": "X",
                "default": null,
                "conformance": "O",
                "summary": "Indicates the transition time of the scene, measured in milliseconds. If present and non-null, this value overrides the SceneTransitionTime from the Scene Table entry."
              }
            ],
            "effect_on_receipt": "set status := SUCCESS\nif GroupID != 0 then\n    if not endpoint.GroupTable.has_entry(GroupID) then\n        set status := INVALID_COMMAND\n        goto generate_response\nif status == SUCCESS then\n    if not SceneTable.has_scene(GroupID, SceneID) then\n        set status := NOT_FOUND\n        goto generate_response\nif status == SUCCESS then\n    set scene_entry := SceneTable.retrieve_scene(GroupID, SceneID)\n    for each cluster on endpoint do\n        set cluster_ext_fields := scene_entry.get_extension_field_sets_for_cluster(cluster.ID)\n        if cluster_ext_fields exists then\n            for each attr_value_pair in cluster_ext_fields do\n                if cluster.has_attribute(attr_value_pair.AttributeID) then\n                    set cluster.attribute(attr_value_pair.AttributeID) := attr_value_pair.Value\n                // else skip unknown or missing attribute\n        else\n            // cluster state remains unchanged\n    set transition_time := if command.TransitionTime is present and not null then command.TransitionTime else scene_entry.SceneTransitionTime\n    // Perform gradual transition from old to new cluster state over transition_time (implementation-defined algorithm)\ngenerate_response:\nif command_received_as_unicast then\n    call generate_response_with_status(status)"
          },
          {
            "id": "0x06",
            "name": "GetSceneMembership",
            "direction": "client ⇒ server",
            "response": "GetSceneMembershipResponse",
            "access": "F O",
            "conformance": "M",
            "summary": "Used to query the scene identifiers currently in use within a specified group, for the endpoint that implements this cluster.",
            "timing": null,
            "fields": [
              {
                "id": "0",
                "name": "GroupID",
                "type": "group-id",
                "constraint": "all",
                "quality": null,
                "default": null,
                "conformance": "M",
                "summary": "Indicates the group identifier in the Group Table."
              }
            ],
            "effect_on_receipt": "set status := SUCCESS\nif GroupID != 0 then\n    if not endpoint.GroupTable.has_entry(GroupID) then\n        set status := INVALID_COMMAND\n        goto generate_response\ngenerate_response:\nif command_received_as_unicast then\n    set scene_list := if status == SUCCESS then SceneTable.get_scene_ids_for_group(GroupID) else null\n    call generate_GetSceneMembershipResponse(status, SceneTable.remaining_capacity_for_fabric(current_fabric), GroupID, scene_list)"
          },
          {
            "id": "0x06",
            "name": "GetSceneMembershipResponse",
            "direction": "client ⇐ server",
            "response": "N",
            "access": null,
            "conformance": "M",
            "summary": "Generated in response to a GetSceneMembership command, providing the status, remaining scene capacity, group identifier, and a list of scene IDs for the group.",
            "timing": null,
            "fields": [
              {
                "id": "0",
                "name": "Status",
                "type": "status",
                "constraint": "desc",
                "quality": null,
                "default": null,
                "conformance": "M",
                "summary": "Indicates the status of the GetSceneMembership command receipt."
              },
              {
                "id": "1",
                "name": "Capacity",
                "type": "uint8",
                "constraint": "all",
                "quality": "X",
                "default": null,
                "conformance": "M",
                "summary": "Contains the remaining capacity of the Scene Table for all groups for the accessing fabric. Values: 0 (no further scenes), 0 < Capacity < 0xFE (number of scenes that may be added), 0xFE (at least 1 further scene, exact number unknown), null (unknown if any further scenes may be added)."
              },
              {
                "id": "2",
                "name": "GroupID",
                "type": "group-id",
                "constraint": "all",
                "quality": null,
                "default": null,
                "conformance": "M",
                "summary": "Set to the GroupID field of the received GetSceneMembership command."
              },
              {
                "id": "3",
                "name": "SceneList",
                "type": "list[uint8]",
                "constraint": null,
                "quality": null,
                "default": null,
                "conformance": "Status==Success",
                "summary": "If Status is SUCCESS, contains the identifiers of all scenes in the Scene Table with the corresponding Group ID; otherwise, omitted."
              }
            ],
            "effect_on_receipt": "This command is generated in response to a received GetSceneMembership command."
          },
          {
            "id": "0x40",
            "name": "CopyScene",
            "direction": "client ⇒ server",
            "response": "CopySceneResponse",
            "access": "F M",
            "conformance": "O",
            "summary": "Allows a client to efficiently copy scenes from one group/scene identifier pair to another. It can copy a single scene or all scenes from a source group.",
            "timing": null,
            "fields": [
              {
                "id": "0",
                "name": "Mode",
                "type": "CopyModeBitmap",
                "constraint": "desc",
                "quality": null,
                "default": null,
                "conformance": "M",
                "summary": "Contains information on how the scene copy is to proceed. The CopyAllScenes bit indicates whether all scenes are to be copied (1) or a single scene (0). If CopyAllScenes is 1, SceneIdentifierFrom and SceneIdentifierTo fields are ignored."
              },
              {
                "id": "1",
                "name": "GroupIdentifierFrom",
                "type": "group-id",
                "constraint": "all",
                "quality": null,
                "default": null,
                "conformance": "M",
                "summary": "Indicates the identifier of the group from which the scene is to be copied. Together with SceneIdentifierFrom, uniquely identifies the source scene."
              },
              {
                "id": "2",
                "name": "SceneIdentifierFrom",
                "type": "uint8",
                "constraint": "max 254",
                "quality": null,
                "default": null,
                "conformance": "M",
                "summary": "Indicates the identifier of the scene from which the scene is to be copied. Together with GroupIdentifierFrom, uniquely identifies the source scene. Ignored if CopyAllScenes bit in Mode is 1."
              },
              {
                "id": "3",
                "name": "GroupIdentifierTo",
                "type": "group-id",
                "constraint": "all",
                "quality": null,
                "default": null,
                "conformance": "M",
                "summary": "Indicates the identifier of the group to which the scene is to be copied. Together with SceneIdentifierTo, uniquely identifies the target scene."
              },
              {
                "id": "4",
                "name": "SceneIdentifierTo",
                "type": "uint8",
                "constraint": "max 254",
                "quality": null,
                "default": null,
                "conformance": "M",
                "summary": "Indicates the identifier of the scene to which the scene is to be copied. Together with GroupIdentifierTo, uniquely identifies the target scene. Ignored if CopyAllScenes bit in Mode is 1."
              }
            ],
            "effect_on_receipt": "set status := SUCCESS\nif (GroupIdentifierFrom != 0 and not endpoint.GroupTable.has_entry(GroupIdentifierFrom)) or \\\n   (GroupIdentifierTo != 0 and not endpoint.GroupTable.has_entry(GroupIdentifierTo)) then\n    set status := INVALID_COMMAND\n    goto generate_response\nif status == SUCCESS and Mode.CopyAllScenes == 0 then\n    if not SceneTable.has_scene(GroupIdentifierFrom, SceneIdentifierFrom) then\n        set status := NOT_FOUND\n        goto generate_response\nif status == SUCCESS then\n    if Mode.CopyAllScenes == 1 then\n        set scenes_to_copy := SceneTable.get_scenes_by_group(GroupIdentifierFrom)\n        for each scene in scenes_to_copy do\n            if not SceneTable.has_capacity_for_fabric(current_fabric, GroupIdentifierTo, scene.SceneID) then\n                set status := RESOURCE_EXHAUSTED\n                goto generate_response // Keep already copied scenes\n            SceneTable.copy_scene(scene, GroupIdentifierTo, scene.SceneID) // SceneID remains same\n    else // Mode.CopyAllScenes == 0\n        set source_scene_entry := SceneTable.get_scene(GroupIdentifierFrom, SceneIdentifierFrom)\n        if not SceneTable.has_capacity_for_fabric(current_fabric, GroupIdentifierTo, SceneIdentifierTo) then\n            set status := RESOURCE_EXHAUSTED\n            goto generate_response\n        SceneTable.copy_scene(source_scene_entry, GroupIdentifierTo, SceneIdentifierTo)\n    // If a scene already exists under the same group/scene identifier pair, it SHALL be replaced.\ngenerate_response:\nif command_received_as_unicast then\n    call generate_CopySceneResponse(status, GroupIdentifierFrom, SceneIdentifierFrom)"
          },
          {
            "id": "0x40",
            "name": "CopySceneResponse",
            "direction": "client ⇐ server",
            "response": "N",
            "access": null,
            "conformance": "CopyScene",
            "summary": "Generated in response to a CopyScene command, indicating the status of the operation and the source group/scene identifiers.",
            "timing": null,
            "fields": [
              {
                "id": "0",
                "name": "Status",
                "type": "status",
                "constraint": "desc",
                "quality": null,
                "default": null,
                "conformance": "M",
                "summary": "Indicates the status of the CopyScene command receipt."
              },
              {
                "id": "1",
                "name": "GroupIdentifierFrom",
                "type": "group-id",
                "constraint": "all",
                "quality": null,
                "default": null,
                "conformance": "M",
                "summary": "Set to the GroupIdentifierFrom field of the received CopyScene command."
              },
              {
                "id": "2",
                "name": "SceneIdentifierFrom",
                "type": "uint8",
                "constraint": "max 254",
                "quality": null,
                "default": null,
                "conformance": "M",
                "summary": "Set to the SceneIdentifierFrom field of the received CopyScene command."
              }
            ],
            "effect_on_receipt": "This command is generated in response to a received CopyScene command."
          }
        ],
