// Logout when no active account; succeeds with no further effect
rule Logout_NoActiveAccount_to_NoActiveAccount_T22:
    [
        ServerState(endpoint, 'NoActiveAccount'),
        In(<'Logout_Request', endpoint, node>),
        !Server(endpoint)
