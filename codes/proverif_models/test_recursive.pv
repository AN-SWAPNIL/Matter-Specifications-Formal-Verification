(* Test recursive process - CORRECT VERSION *)

type state.
const s1: state.
const s2: state.

free c: channel.
free c_state: channel [private].

let P() =
    in(c_state, x: state);
    in(c, y: state);
    if x = s1 then
        out(c_state, s2)
    else
        out(c_state, s1).

process
    out(c_state, s1);
    !P()
