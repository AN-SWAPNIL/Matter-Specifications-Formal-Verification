theory Account_Login_Cluster
begin

/*
 * Tamarin Protocol Security Model for Account Login Cluster
 * Generated from Enhanced FSM JSON (v2.0)
 * Generated: 2025-12-16T17:15:10.388793
 * 
 * Cluster ID: 0x050E
 * Revision: 2
 * 
 * Model Statistics:
 * - States: 3
 * - Transitions: 24
 * - Action Facts: 38
 * - Security Properties: 6
 * 
 * This model supports security analysis with:
 * - Parameterized action facts for precise tracing
 * - Message passing (In/Out) for protocol modeling
 * - Fresh value generation for cryptographic material
 * - Verifiable security lemmas
 */

builtins: hashing, symmetric-encryption

// ============================================================================
// Functions
// ============================================================================

// Boolean and null constants
functions: true/0, false/0, null/0

// Empty value marker
functions: empty/0

// Response status
functions: SUCCESS/0, FAILURE/0

// ============================================================================
// Restrictions
// ============================================================================

// Equality check
restriction Equality:
    "All x y #i. Eq(x, y)@i ==> x = y"

// Inequality check  
restriction Inequality:
    "All x y #i. Neq(x, y)@i ==> not(x = y)"

// Once restriction for unique events
restriction Once:
    "All x #i #j. Once(x)@i & Once(x)@j ==> #i = #j"


// ============================================================================
// Initialization
// ============================================================================

rule Server_Init:
    [ Fr(~endpoint_id) ]
    --[ ServerInit(~endpoint_id), Once(<'server_init', ~endpoint_id>) ]->
    [
        !Server(~endpoint_id),
        ServerState(~endpoint_id, 'NoActiveAccount'),
        RateLimitCounter(~endpoint_id, 'zero')
    ]


// ============================================================================
// Fresh Value Generation
// ============================================================================

rule Create_TempAccountIdentifier:
    let temp_id = h(<~account, ~nonce>)
    in
    [ Fr(~account), Fr(~nonce), Fr(~setup_pin), Fr(~validity) ]
    --[ 
        TempIdCreated(temp_id, ~account),
        AccountRegistered(~account, temp_id, ~setup_pin)
    ]->
    [
        !AccountMapping(temp_id, ~account, ~setup_pin, ~validity),
        Out(temp_id)  // Attacker can observe temp_id
    ]

rule TempId_Expires:
    [ !AccountMapping(temp_id, account, setup_pin, validity) ]
    --[ TempIdExpired(temp_id) ]->
    [ !AccountMapping_Expired(temp_id, account, setup_pin) ]


// ============================================================================

// Protocol Transitions

// ============================================================================

// GetSetupPIN rejected due to rate limiting; empty PIN returned
rule GetSetupPIN_NoActiveAccount_to_RateLimited_T1:
    let
        scope = ~scope
    in
    [
        ServerState(endpoint, 'NoActiveAccount'),
        In(<'GetSetupPIN_Request', endpoint, temp_id>),
        Fr(~scope),
        !Server(endpoint)
    ]
    --[
        GetSetupPIN(endpoint),
        StateTransition(endpoint, 'NoActiveAccount', 'RateLimited'),
        GetSetupPINReceived(endpoint, temp_id),
        RateLimitCheck(endpoint, scope),
        RateLimitExceeded(endpoint, scope),
        EmptyPINReturned(endpoint, temp_id)
    ]->
    [
        ServerState(endpoint, 'RateLimited'),
        Out(<'GetSetupPIN_Response', empty>),
        !Server(endpoint)
    ]

// GetSetupPIN succeeds with non-empty PIN: rate limit OK, temp_id valid, and account matches active account
rule GetSetupPIN_NoActiveAccount_to_NoActiveAccount_T2:
    let
        setup_pin = ~setup_pin
        scope = ~scope
    in
    [
        ServerState(endpoint, 'NoActiveAccount'),
        In(<'GetSetupPIN_Request', endpoint, temp_id>),
        Fr(~setup_pin),
        Fr(~scope),
        !Server(endpoint)
    ]
    --[
        GetSetupPIN(endpoint),
        StateTransition(endpoint, 'NoActiveAccount', 'NoActiveAccount'),
        GetSetupPINReceived(endpoint, temp_id),
        RateLimitCheck(endpoint, scope),
        RateLimitOK(endpoint, scope),
        AccountLookupSuccess(temp_id, account),
        ActiveAccountRead(endpoint, account),
        AccountMatch(temp_id, account),
        TempIdValidated(temp_id),
        SetupPINGenerated(account, setup_pin),
        SetupPINReturned(endpoint, temp_id, setup_pin)
    ]->
    [
        ServerState(endpoint, 'NoActiveAccount'),
        Out(<'GetSetupPIN_Response', setup_pin>),
        !Server(endpoint)
    ]

// GetSetupPIN returns empty PIN when no account is found for temp_id
rule GetSetupPIN_NoActiveAccount_to_NoActiveAccount_T3:
