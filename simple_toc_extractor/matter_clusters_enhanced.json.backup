                "type": "string",
                "constraint": "max 16",
                "quality": null,
                "default": null,
                "conformance": "desc",
                "summary": "If Status is SUCCESS, copied from the Scene Table entry; otherwise, omitted."
              },
              {
                "id": "5",
                "name": "ExtensionFieldSetStructs",
                "type": "list[ExtensionFieldSetStruct]",
                "constraint": null,
                "quality": null,
                "default": null,
                "conformance": "desc",
                "summary": "If Status is SUCCESS, copied from the Scene Table entry; otherwise, omitted. The order of attributes within the ExtensionFieldSetStruct MAY differ in implementation-defined ways from any potential order given in a prior AddScene."
              }
            ],
            "effect_on_receipt": "This command is generated in response to a received ViewScene command."
          },
          {
            "id": "0x02",
            "name": "RemoveScene",
            "direction": "client ⇒ server",
            "response": "RemoveSceneResponse",
            "access": "F M",
            "conformance": "M",
            "summary": "Allows a client to remove a specific scene from the server's Scene Table.",
            "timing": null,
            "fields": [
              {
