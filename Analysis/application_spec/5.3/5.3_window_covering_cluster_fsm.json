    "safety_critical_elements": [
      {
        "element_type": "state",
        "element_id": "Moving_Closing",
        "safety_concern": "Motorized closing motion can entrap persons, animals, or objects between the covering and the frame. No mandatory obstacle detection response is defined beyond the SafetyStatus.ObstacleDetected bit.",
        "mitigation_in_spec": "SafetyStatus.ObstacleDetected bit (bit 5) exists but is optional (O conformance). No mandatory abort behavior is specified when ObstacleDetected is set."
      },
      {
        "element_type": "attribute",
        "element_id": "SafetyStatus.RemoteLockout (bit 0)",
        "safety_concern": "RemoteLockout bit indicates authorization or time/date range lockout, but the exact command rejection mechanism and error code when this bit is set are not specified in the cluster spec. An attacker who cannot set this bit via another path could potentially bypass lockout by exploiting the undefined behavior.",
        "mitigation_in_spec": "NONE — bit is defined as informational but no SHALL-level command rejection tied to it is specified in the cluster spec."
      },
      {
        "element_type": "state",
        "element_id": "CalibrationMode_Idle",
        "safety_concern": "In calibration mode, the window covering may move beyond normal operational limits as part of self-calibration. The extent of movement and any physical end-stop handling are vendor-specific with no normative constraints.",
        "mitigation_in_spec": "NONE — calibration behavior is fully vendor-specific; spec only states mode entry/exit rules."
      },
      {
        "element_type": "transition",
        "element_id": "T033",
        "safety_concern": "Entering MaintenanceMode requires only M-level (Manage) privilege. If an attacker gains Manage access, they can disable all physical movement capability of the covering, preventing automation-controlled opening/closing (e.g., blocking emergency exit scenarios where automated blinds must open).",
        "mitigation_in_spec": "Mode attribute write requires M privilege (RW VM). Physical access control to the fabric/endpoint is the primary mitigation."
      },
      {
        "element_type": "attribute",
        "element_id": "Mode (0x0017)",
        "safety_concern": "The Mode attribute has RW VM access (Write requires Manage privilege). A node with Manage access can simultaneously set CalibrationMode and MaintenanceMode bits or configure MotorDirectionReversed, directly affecting physical actuator behavior and potentially disorienting safety systems relying on known movement direction.",
        "mitigation_in_spec": "CONSTRAINT_ERROR returned for unsupported bits. No additional write validation is mandated."
      }
    ],

    "spec_gaps": [
      {
        "location": "Section 5.3.5.4 'SafetyStatusBitmap Type'",
        "gap_type": "undefined_behavior",
        "description": "SafetyStatus.RemoteLockout (bit 0) is described as causing movement commands to be 'ignored (locked out)' but no normative SHALL-level command handling or error code is specified in the cluster when this bit is set. The cluster commands section (5.3.7) contains no reference to RemoteLockout checks.",
        "security_impact": "An authorized operator may not receive a clear error response when commands are blocked by RemoteLockout, and implementations may vary in whether they reject or silently drop commands, masking lockout conditions from clients."
      },
      {
        "location": "Section 5.3.7.1 / 5.3.7.2",
        "gap_type": "undefined_behavior",
        "description": "No behavior is defined for UpOrOpen or DownOrClose received while the device is already Moving_Opening or Moving_Closing in the same direction (e.g., UpOrOpen while Moving_Opening). The spec only specifies the target attribute updates, not whether the motor is restarted, ignored, or direction-reversed.",
        "security_impact": "Inconsistent implementations may allow command flooding to destabilize motor control or cause unexpected re-initialization of position tracking."
      },
      {
        "location": "Section 5.3.6.13.2 'CalibrationMode Bit'",
        "gap_type": "weak_normative",
        "description": "Exit from CalibrationMode is vendor-specific ('device must perform its calibration routine, either as a self-calibration or assisted by external tool(s)'). There is no SHALL-level timeout, maximum calibration duration, or forced exit mechanism defined.",
        "security_impact": "An attacker with Manage access could set CalibrationMode=1 and leave the device permanently in calibration mode since CalibrationMode=0 write is rejected. No watchdog or forced exit is mandated."
      },
      {
        "location": "Section 5.3.6.13.3 'MaintenanceMode Bit'",
        "gap_type": "weak_normative",
        "description": "Setting ConfigStatus.Operational to 0 during maintenance mode uses 'should' (lowercase, non-normative) rather than SHALL. Implementations may legitimately leave ConfigStatus.Operational=1 while in maintenance mode, misleading clients about device availability.",
        "security_impact": "Clients relying on ConfigStatus.Operational to determine if the device is controllable may incorrectly send movement commands, receiving BUSY responses with no clear cause."
      },
      {
        "location": "Section 5.3.7.4 / 5.3.7.5",
        "gap_type": "weak_normative",
        "description": "GoToLiftPercentage on a tilt-only device: 'the command SHOULD be ignored and a UNSUPPORTED_COMMAND status SHOULD be returned'. Both the ignore and the status return use SHOULD rather than SHALL. For GoToTiltPercentage on a lift-only device, no symmetric rule is stated at all.",
        "security_impact": "Ambiguous behavior on feature mismatch allows varied implementations. A malicious client could probe feature support by sending cross-feature commands and observing varied responses, inferring device capabilities."
      },
      {
        "location": "Section 5.3.6 (Attributes)",
        "gap_type": "missing_constraint",
        "description": "No events are defined in the Window Covering cluster. There is no standardized notification mechanism when OperationalStatus, SafetyStatus, or Mode attributes change. Clients must poll these attributes to detect state changes.",
        "security_impact": "Without events, safety-critical state changes (e.g., SafetyStatus.ObstacleDetected becoming set, or device entering MaintenanceMode) are not proactively reported. Polling introduces latency in safety response."
      },
      {
        "location": "Section 5.3.5.4 'SafetyStatusBitmap Type'",
        "gap_type": "missing_constraint",
        "description": "No normative behavior is defined for any of the 12 SafetyStatus bits except as informational indicators. There is no SHALL-level requirement to halt or reject movement commands when ThermalProtection, MotorJammed, HardwareFailure, or ObstacleDetected bits are set.",
        "security_impact": "A device with a jammed motor or detected obstacle may continue to accept movement commands (provided other mode conditions are met), potentially causing physical damage or injury."
      },
      {
        "location": "Section 5.3.6.13 'Mode Attribute'",
        "gap_type": "ambiguous",
        "description": "The spec does not define whether CalibrationMode and MaintenanceMode can be set simultaneously. Writing both bits in a single Mode attribute write is not prohibited, and the resulting behavior is undefined.",
        "security_impact": "Simultaneous MaintenanceMode and CalibrationMode could create an inconsistent state where the device is in maintenance (blocking movement) yet in calibration (expecting movement). Vendor-specific handling creates interoperability fragility."
      }
    ],

