// Startup/Power-Cycle Transitions

// ============================================================================

// On power-up, if StartUpCurrentLevel is null, restore previous CurrentLevel
// Guard: startup_current_level_is_null == TRUE
// Guard: StartUpCurrentLevel == null
rule Startup_OffState_to_OffState_T_Startup_RestorePrevious:
    [
        !Server(endpoint),
        ServerState(endpoint, 'OffState'),
        PowerCycle(endpoint),
        !FeatureConfig(endpoint, 'LT', 'true'),
        !AttrState(endpoint, 'StartUpCurrentLevel', 'null'),
        In(previous_level)
    ]
    --[
        Startup(endpoint),
        StateTransition(endpoint, 'OffState', 'OffState'),
        StartupOccurred(endpoint),
        StartupCurrentLevelRestoredPrevious(endpoint, previous_level)
    ]->
    [
        ServerState(endpoint, 'OffState'),
        !Server(endpoint),
        !FeatureConfig(endpoint, 'LT', 'true')
    ]

// On power-up, if StartUpCurrentLevel is 0, set CurrentLevel to device min level
// Guard: startup_current_level_value == 0
// Guard: StartUpCurrentLevel == 0
rule Startup_OffState_to_OffState_T_Startup_ForceMin:
    [
        !Server(endpoint),
        ServerState(endpoint, 'OffState'),
        PowerCycle(endpoint),
        !FeatureConfig(endpoint, 'LT', 'true'),
        !AttrState(endpoint, 'StartUpCurrentLevel', '0'),
        In(device_min_level)
    ]
    --[
        Startup(endpoint),
        StateTransition(endpoint, 'OffState', 'OffState'),
        StartupOccurred(endpoint),
        StartupCurrentLevelForcedMin(endpoint, device_min_level)
    ]->
    [
        ServerState(endpoint, 'OffState'),
        !Server(endpoint),
        !FeatureConfig(endpoint, 'LT', 'true')
    ]

// On power-up, if StartUpCurrentLevel is a non-zero value, set CurrentLevel to that value
// Guard: startup_current_level_is_null == FALSE && startup_current_level_value != 0
// Guard: StartUpCurrentLevel != null
// Guard: StartUpCurrentLevel != 0
rule Startup_OffState_to_OffState_T_Startup_ForceValue:
    [
        !Server(endpoint),
        ServerState(endpoint, 'OffState'),
        PowerCycle(endpoint),
        !FeatureConfig(endpoint, 'LT', 'true'),
        !AttrState(endpoint, 'StartUpCurrentLevel', 'null'),
        !AttrState(endpoint, 'StartUpCurrentLevel', '0'),
        In(startup_level)
    ]
    --[
        Startup(endpoint),
        StateTransition(endpoint, 'OffState', 'OffState'),
        StartupOccurred(endpoint),
        StartupCurrentLevelForcedValue(endpoint, startup_level)
    ]->
    [
        ServerState(endpoint, 'OffState'),
        !Server(endpoint),
        !FeatureConfig(endpoint, 'LT', 'true')
    ]

