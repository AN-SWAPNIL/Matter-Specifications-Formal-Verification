          {
            "id": "0x0005",
            "name": "Scenes Cluster",
            "description": "A server cluster that, if implemented on the same endpoint, requires the OnOff attribute to be part of its ExtensionFieldSetStruct for scene table extensions."
          },
          {
            "id": null,
            "name": "MoveToLevel(WithOnOff) command",
            "description": "A command (likely from the Level Control cluster) that, when received, can cause the GlobalSceneControl attribute to be set to TRUE."
          },
          {
            "id": null,
            "name": "RecallScene command",
            "description": "A command (likely from the Scenes Cluster) that, when received, can cause the GlobalSceneControl attribute to be set to TRUE."
          },
          {
            "id": null,
            "name": "StartUpOnOffEnum",
            "description": "An enumeration type that defines the specific startup behaviors for the StartUpOnOff attribute."
          },
          {
            "id": null,
            "name": "OffOnly feature",
            "description": "A feature that, if supported, causes an UNSUPPORTED_COMMAND failure status response upon receipt of On or Toggle commands."
          },
          {
            "id": null,
            "name": "Interaction Model",
            "description": "Core specification for command invocation and status responses, such as UNSUPPORTED_COMMAND, which is sent when a command is not supported due to feature configuration."
          },
          {
            "id": null,
            "name": "EffectIdentifierEnum",
            "description": "An enumeration type that defines the various fading effects available for the OffWithEffect command, not defined within this section."
