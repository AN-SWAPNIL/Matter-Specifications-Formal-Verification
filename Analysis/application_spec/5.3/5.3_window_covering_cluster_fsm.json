{
  "cluster_fsm": {
    "cluster_name": "Window Covering",
    "cluster_id": "0x0102",
    "pics_code": "WNCV",
    "spec_reference": "Matter 1.5 Application Cluster Specification, Section 5.3, Pages 477-493",
    "revision": 7,

    "features": [
      {
        "bit": 0,
        "code": "LF",
        "name": "Lift",
        "conformance": "O.a+",
        "description": "Lift control and behavior for lifting/sliding window coverings. At least one of LF or TL must be supported.",
        "affects_states": ["Moving_Opening", "Moving_Closing", "Stopped_Operational"],
        "affects_transitions": ["T001", "T005", "T009", "T010", "T012", "T013", "T014", "T015", "T016", "T017", "T018", "T019", "T021", "T023"]
      },
      {
        "bit": 1,
        "code": "TL",
        "name": "Tilt",
        "conformance": "O.a+",
        "description": "Tilt control and behavior for tilting window coverings. At least one of LF or TL must be supported.",
        "affects_states": ["Moving_Opening", "Moving_Closing", "Stopped_Operational"],
        "affects_transitions": ["T001", "T005", "T009", "T010", "T012", "T013", "T014", "T020", "T021", "T022", "T023", "T024", "T025", "T026"]
      },
      {
        "bit": 2,
        "code": "PA_LF",
        "name": "PositionAwareLift",
        "conformance": "[LF]",
        "description": "Position aware lift control is supported. Enables TargetPositionLiftPercent100ths and CurrentPositionLiftPercent100ths attributes.",
        "affects_states": ["Moving_Opening", "Moving_Closing", "Stopped_Operational"],
        "affects_transitions": ["T001", "T005", "T009", "T010", "T012", "T013", "T014", "T015", "T016", "T017", "T018"]
      },
      {
        "bit": 4,
        "code": "PA_TL",
        "name": "PositionAwareTilt",
        "conformance": "[TL]",
        "description": "Position aware tilt control is supported. Enables TargetPositionTiltPercent100ths and CurrentPositionTiltPercent100ths attributes.",
        "affects_states": ["Moving_Opening", "Moving_Closing", "Stopped_Operational"],
        "affects_transitions": ["T001", "T005", "T009", "T010", "T012", "T013", "T014", "T020", "T021", "T022", "T023", "T024"]
      }
    ],

    "dependencies": [],

    "states": [
      {
        "name": "Stopped_Operational",
        "description": "Window covering is operational, stationary, and not in any special mode. This is the normal resting state.",
        "is_initial": true,
        "invariants": [
          "OperationalStatus.Global == 00b",
          "Mode.MaintenanceMode == 0",
          "Mode.CalibrationMode == 0",
          "ConfigStatus.Operational == 1"
        ],
        "state_attributes": {
          "OperationalStatus.Global": "00b (not moving)",
          "OperationalStatus.Lift": "00b (not moving) [LF]",
          "OperationalStatus.Tilt": "00b (not moving) [TL]",
          "Mode.MaintenanceMode": "0",
          "Mode.CalibrationMode": "0",
          "ConfigStatus.Operational": "1"
        },
        "feature_requirements": [],
        "safety_implications": "No active motion. SafetyStatus bits may be non-zero indicating latched safety conditions preventing future movement."
      },
      {
        "name": "Moving_Opening",
        "description": "Window covering is physically moving towards the open position (0.00% for lift/tilt). OperationalStatus reflects current direction.",
        "is_initial": false,
        "invariants": [
          "OperationalStatus.Global == 01b",
          "Mode.MaintenanceMode == 0"
        ],
        "state_attributes": {
          "OperationalStatus.Global": "01b (opening)",
          "OperationalStatus.Lift": "01b (opening) [LF]",
          "OperationalStatus.Tilt": "01b (opening) [TL]",
          "TargetPositionLiftPercent100ths": "set to target (0 for UpOrOpen) [PA_LF]",
          "TargetPositionTiltPercent100ths": "set to target (0 for UpOrOpen) [PA_TL]"
        },
        "feature_requirements": [],
        "safety_implications": "Motorized movement active. Obstacle detection (SafetyStatus.ObstacleDetected) and thermal protection (SafetyStatus.ThermalProtection) are relevant safety concerns during motion."
      },
      {
        "name": "Moving_Closing",
        "description": "Window covering is physically moving towards the closed position (100.00% for lift/tilt). OperationalStatus reflects current direction.",
        "is_initial": false,
        "invariants": [
          "OperationalStatus.Global == 10b",
          "Mode.MaintenanceMode == 0"
        ],
        "state_attributes": {
          "OperationalStatus.Global": "10b (closing)",
          "OperationalStatus.Lift": "10b (closing) [LF]",
          "OperationalStatus.Tilt": "10b (closing) [TL]",
          "TargetPositionLiftPercent100ths": "set to target (10000 for DownOrClose) [PA_LF]",
          "TargetPositionTiltPercent100ths": "set to target (10000 for DownOrClose) [PA_TL]"
        },
        "feature_requirements": [],
        "safety_implications": "Motorized movement active. Obstacle detection and thermal protection are relevant. Closing motion can entrap objects or persons."
      },
      {
        "name": "CalibrationMode_Idle",
        "description": "Window covering is in calibration mode (Mode.CalibrationMode = 1) and stationary. Movement commands may trigger self-calibration before execution.",
        "is_initial": false,
        "invariants": [
          "Mode.CalibrationMode == 1",
          "OperationalStatus.Global == 00b"
        ],
        "state_attributes": {
          "Mode.CalibrationMode": "1",
          "OperationalStatus.Global": "00b (not moving)",
          "ConfigStatus.Operational": "0 or 1 (vendor-specific during calibration)"
        },
        "feature_requirements": [],
        "safety_implications": "Calibration mode may allow motor movement outside normal operational bounds. Writing CalibrationMode=0 directly while in this state is forbidden (returns FAILURE); exit requires completing the calibration routine."
      },
      {
        "name": "MaintenanceMode",
        "description": "Window covering is in maintenance mode (Mode.MaintenanceMode = 1). All movement commands and local inputs are blocked. Device is not operational.",
        "is_initial": false,
        "invariants": [
          "Mode.MaintenanceMode == 1",
          "ConfigStatus.Operational == 0"
        ],
        "state_attributes": {
          "Mode.MaintenanceMode": "1",
          "OperationalStatus.Global": "00b (not moving)",
          "ConfigStatus.Operational": "0 (should be set to not operational)"
        },
        "feature_requirements": [],
        "safety_implications": "Device is physically disabled for maintenance. All remote and local movement disabled. ConfigStatus.Operational should reflect non-operational status to inform clients."
      }
    ],

    "transitions": [
      {
        "id": "T001",
        "from_state": "Stopped_Operational",
        "to_state": "Moving_Opening",
        "trigger": {
          "type": "command",
          "name": "UpOrOpen",
          "command_id": "0x00"
        },
        "guard_condition": "Mode.MaintenanceMode == 0 && Mode.CalibrationMode == 0",
        "actions": [
          "TargetPositionLiftPercent100ths := 0 [guard: Feature_PA_LF == true]",
          "TargetPositionTiltPercent100ths := 0 [guard: Feature_PA_TL == true]",
          "OperationalStatus.Global := 01b",
          "OperationalStatus.Lift := 01b [guard: Feature_LF == true]",
          "OperationalStatus.Tilt := 01b [guard: Feature_TL == true]"
        ],
        "access_required": "O",
        "timed_required": false,
        "timing_constraint": null,
        "error_responses": [],
        "spec_reference": "Section 5.3.7.1 'UpOrOpen Command'"
      },
      {
        "id": "T002",
