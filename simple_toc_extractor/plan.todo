            "access": "M",
            "conformance": "M",
            "summary": "The GetGroupMembershipResponse command is sent by the Groups cluster server in response to a GetGroupMembership command.",
            "timing": null,
            "fields": [
              {
                "id": "0",
                "name": "Capacity",
                "type": "uint8",
                "constraint": "all",
                "quality": "X",
                "default": null,
                "conformance": "M",
                "summary": "This field SHALL contain the remaining capacity of the Group Table of the node. The following values apply: • 0 - No further groups MAY be added. • 0 < Capacity < 0xFE - Capacity holds the number of groups that MAY be added. • 0xFE - At least 1 further group MAY be added (exact number is unknown). • null - It is unknown if any further groups MAY be added."
