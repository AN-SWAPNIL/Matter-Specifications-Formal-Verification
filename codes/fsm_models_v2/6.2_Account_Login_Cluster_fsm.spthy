        ServerState(endpoint, 'NoActiveAccount'),
        Out(<'Logout_Response', SUCCESS>),
        !Server(endpoint)
    ]

// Logout with node parameter; clears active account and emits LoggedOut with node
rule Logout_ActiveAccount_to_NoActiveAccount_T23:
