  // Rate-limited transition time specified or not
  rl_spec/0,    // RateLimitedTransitionTimeSpecified == true
  rl_nospec/0,  // RateLimitedTransitionTimeSpecified == false

  // Result level classification relative to MinLevel
  res_at_min/0,    // resulting/final level == DeviceMinLevel
  res_above_min/0, // resulting/final level > DeviceMinLevel

  // Frequency support classification for requested frequency
  fq_supported/0,
  fq_notsupported/0,

  // LastCommandHadOnOffLinkage flag
