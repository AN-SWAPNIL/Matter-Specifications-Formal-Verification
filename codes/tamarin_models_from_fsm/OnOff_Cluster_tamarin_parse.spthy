//========================================
// SECTION 9: Command Rules - OnWithTimedOff (LT only, abstract parameters)
//========================================

// Off_Idle + OnWithTimedOff, LT enabled, AcceptOnlyWhenOn == 1, OnOff == FALSE -> discard
// Abstracted as a self-loop with no state change.
rule Cmd_OnWithTimedOff_Discard_WhenOff:
  [ St(~tid, st_OffIdle, b_false, OT, OW, GSC, SU, PO),
    !Config(~tid, f_LT, DF, OFFONLY) ]
--[ Command(~tid, 'OnWithTimedOff'),
   StateTransition(~tid, st_OffIdle, st_OffIdle) ]->
  [ St(~tid, st_OffIdle, b_false, OT, OW, GSC, SU, PO) ]

rule Cmd_OnWithTimedOff_Discard_WhenOff_noOFFONLY:
  [ St(~tid, st_OffIdle, b_false, OT, OW, GSC, SU, PO),
    !Config(~tid, f_LT, DF, f_noOFFONLY) ]
--[ Command(~tid, 'OnWithTimedOff'),
   StateTransition(~tid, st_OffIdle, st_OffIdle) ]->
  [ St(~tid, st_OffIdle, b_false, OT, OW, GSC, SU, PO) ]

// Off_Idle + OnWithTimedOff, AcceptOnlyWhenOn == 0, start Timed_On (abstract timers)
rule Cmd_OnWithTimedOff_From_OffIdle_To_TimedOn:
  [ St(~tid, st_OffIdle, b_false, OT, OW, GSC, SU, PO),
    !Config(~tid, f_LT, DF, OFFONLY) ]
--[ Command(~tid, 'OnWithTimedOff'),
   StateTransition(~tid, st_OffIdle, st_TimedOn) ]->
  [ St(~tid, st_TimedOn, b_true, tv_high, tv_high, GSC, SU, PO) ]

rule Cmd_OnWithTimedOff_From_OffIdle_To_TimedOn_noOFFONLY:
  [ St(~tid, st_OffIdle, b_false, OT, OW, GSC, SU, PO),
    !Config(~tid, f_LT, DF, f_noOFFONLY) ]
--[ Command(~tid, 'OnWithTimedOff'),
   StateTransition(~tid, st_OffIdle, st_TimedOn) ]->
  [ St(~tid, st_TimedOn, b_true, tv_high, tv_high, GSC, SU, PO) ]

// Off_Idle + OnWithTimedOff, AcceptOnlyWhenOn == 0, remain/enter Delayed_Off (OffWaitTime > 0)
rule Cmd_OnWithTimedOff_From_OffIdle_To_DelayedOff:
  [ St(~tid, st_OffIdle, b_false, OT, tv_high, GSC, SU, PO),
    !Config(~tid, f_LT, DF, OFFONLY) ]
--[ Command(~tid, 'OnWithTimedOff'),
   StateTransition(~tid, st_OffIdle, st_DelayedOff) ]->
  [ St(~tid, st_DelayedOff, b_false, tv_zero, tv_high, GSC, SU, PO) ]

rule Cmd_OnWithTimedOff_From_OffIdle_To_DelayedOff_noOFFONLY:
  [ St(~tid, st_OffIdle, b_false, OT, tv_high, GSC, SU, PO),
    !Config(~tid, f_LT, DF, f_noOFFONLY) ]
--[ Command(~tid, 'OnWithTimedOff'),
   StateTransition(~tid, st_OffIdle, st_DelayedOff) ]->
  [ St(~tid, st_DelayedOff, b_false, tv_zero, tv_high, GSC, SU, PO) ]

// On_Idle + OnWithTimedOff -> Timed_On (extend or keep OnTime, update OffWaitTime)
rule Cmd_OnWithTimedOff_From_OnIdle_To_TimedOn:
  [ St(~tid, st_OnIdle, b_true, OT, OW, GSC, SU, PO),
    !Config(~tid, f_LT, DF, OFFONLY) ]
--[ Command(~tid, 'OnWithTimedOff'),
   StateTransition(~tid, st_OnIdle, st_TimedOn) ]->
  [ St(~tid, st_TimedOn, b_true, tv_high, tv_high, GSC, SU, PO) ]

rule Cmd_OnWithTimedOff_From_OnIdle_To_TimedOn_noOFFONLY:
  [ St(~tid, st_OnIdle, b_true, OT, OW, GSC, SU, PO),
    !Config(~tid, f_LT, DF, f_noOFFONLY) ]
--[ Command(~tid, 'OnWithTimedOff'),
   StateTransition(~tid, st_OnIdle, st_TimedOn) ]->
  [ St(~tid, st_TimedOn, b_true, tv_high, tv_high, GSC, SU, PO) ]

// Timed_On + OnWithTimedOff -> Timed_On (update timers)
rule Cmd_OnWithTimedOff_From_TimedOn:
  [ St(~tid, st_TimedOn, b_true, OT, OW, GSC, SU, PO),
    !Config(~tid, f_LT, DF, OFFONLY) ]
--[ Command(~tid, 'OnWithTimedOff'),
   StateTransition(~tid, st_TimedOn, st_TimedOn) ]->
  [ St(~tid, st_TimedOn, b_true, tv_high, tv_high, GSC, SU, PO) ]

rule Cmd_OnWithTimedOff_From_TimedOn_noOFFONLY:
  [ St(~tid, st_TimedOn, b_true, OT, OW, GSC, SU, PO),
    !Config(~tid, f_LT, DF, f_noOFFONLY) ]
--[ Command(~tid, 'OnWithTimedOff'),
   StateTransition(~tid, st_TimedOn, st_TimedOn) ]->
  [ St(~tid, st_TimedOn, b_true, tv_high, tv_high, GSC, SU, PO) ]

// Delayed_Off + OnWithTimedOff, shorten OffWaitTime (OffWaitTimeField < OffWaitTime)
// Abstract: OffWaitTime is tv_high, and we move it to tv_low to represent shorter delay.
rule Cmd_OnWithTimedOff_From_DelayedOff_Shorter:
  [ St(~tid, st_DelayedOff, b_false, OT, tv_high, GSC, SU, PO),
    !Config(~tid, f_LT, DF, OFFONLY) ]
--[ Command(~tid, 'OnWithTimedOff'),
   StateTransition(~tid, st_DelayedOff, st_DelayedOff) ]->
  [ St(~tid, st_DelayedOff, b_false, tv_zero, tv_low, GSC, SU, PO) ]

rule Cmd_OnWithTimedOff_From_DelayedOff_Shorter_noOFFONLY:
  [ St(~tid, st_DelayedOff, b_false, OT, tv_high, GSC, SU, PO),
    !Config(~tid, f_LT, DF, f_noOFFONLY) ]
--[ Command(~tid, 'OnWithTimedOff'),
   StateTransition(~tid, st_DelayedOff, st_DelayedOff) ]->
  [ St(~tid, st_DelayedOff, b_false, tv_zero, tv_low, GSC, SU, PO) ]

// Delayed_Off + OnWithTimedOff, keep existing smaller OffWaitTime (OffWaitTimeField >= OffWaitTime)
// Abstract: OffWaitTime already tv_low; we keep it.
rule Cmd_OnWithTimedOff_From_DelayedOff_Keep:
  [ St(~tid, st_DelayedOff, b_false, OT, tv_low, GSC, SU, PO),
    !Config(~tid, f_LT, DF, OFFONLY) ]
--[ Command(~tid, 'OnWithTimedOff'),
   StateTransition(~tid, st_DelayedOff, st_DelayedOff) ]->
  [ St(~tid, st_DelayedOff, b_false, tv_zero, tv_low, GSC, SU, PO) ]

rule Cmd_OnWithTimedOff_From_DelayedOff_Keep_noOFFONLY:
  [ St(~tid, st_DelayedOff, b_false, OT, tv_low, GSC, SU, PO),
    !Config(~tid, f_LT, DF, f_noOFFONLY) ]
--[ Command(~tid, 'OnWithTimedOff'),
   StateTransition(~tid, st_DelayedOff, st_DelayedOff) ]->
  [ St(~tid, st_DelayedOff, b_false, tv_zero, tv_low, GSC, SU, PO) ]


//========================================
// SECTION 10: Timer Rules - OnWithTimedOff_timer_tick
//========================================

// Timed_On timer tick, OnTime >= 2 (tv_high -> tv_low)
rule TimerTick_TimedOn_Decrement_High:
  [ St(~tid, st_TimedOn, b_true, tv_high, OW, GSC, SU, PO),
    !Config(~tid, f_LT, DF, OFFONLY) ]
--[ TimerTick(~tid), StateTransition(~tid, st_TimedOn, st_TimedOn) ]->
  [ St(~tid, st_TimedOn, b_true, tv_low, OW, GSC, SU, PO) ]

rule TimerTick_TimedOn_Decrement_High_noOFFONLY:
  [ St(~tid, st_TimedOn, b_true, tv_high, OW, GSC, SU, PO),
    !Config(~tid, f_LT, DF, f_noOFFONLY) ]
--[ TimerTick(~tid), StateTransition(~tid, st_TimedOn, st_TimedOn) ]->
  [ St(~tid, st_TimedOn, b_true, tv_low, OW, GSC, SU, PO) ]

// Timed_On timer tick, OnTime == 1 (tv_low -> expire)
rule TimerTick_TimedOn_Expire_Low:
  [ St(~tid, st_TimedOn, b_true, tv_low, OW, GSC, SU, PO),
    !Config(~tid, f_LT, DF, OFFONLY) ]
--[ TimerTick(~tid), StateTransition(~tid, st_TimedOn, st_OffIdle) ]->
  [ St(~tid, st_OffIdle, b_false, tv_zero, tv_zero, GSC, SU, PO) ]

rule TimerTick_TimedOn_Expire_Low_noOFFONLY:
  [ St(~tid, st_TimedOn, b_true, tv_low, OW, GSC, SU, PO),
    !Config(~tid, f_LT, DF, f_noOFFONLY) ]
--[ TimerTick(~tid), StateTransition(~tid, st_TimedOn, st_OffIdle) ]->
  [ St(~tid, st_OffIdle, b_false, tv_zero, tv_zero, GSC, SU, PO) ]

// Delayed_Off timer tick, OffWaitTime >= 2 (tv_high -> tv_low)
rule TimerTick_DelayedOff_Decrement_High:
  [ St(~tid, st_DelayedOff, b_false, OT, tv_high, GSC, SU, PO),
    !Config(~tid, f_LT, DF, OFFONLY) ]
--[ TimerTick(~tid), StateTransition(~tid, st_DelayedOff, st_DelayedOff) ]->
  [ St(~tid, st_DelayedOff, b_false, OT, tv_low, GSC, SU, PO) ]

rule TimerTick_DelayedOff_Decrement_High_noOFFONLY:
  [ St(~tid, st_DelayedOff, b_false, OT, tv_high, GSC, SU, PO),
    !Config(~tid, f_LT, DF, f_noOFFONLY) ]
--[ TimerTick(~tid), StateTransition(~tid, st_DelayedOff, st_DelayedOff) ]->
  [ St(~tid, st_DelayedOff, b_false, OT, tv_low, GSC, SU, PO) ]

// Delayed_Off timer tick, OffWaitTime == 1 (tv_low -> Off_Idle)
rule TimerTick_DelayedOff_Expire_Low:
  [ St(~tid, st_DelayedOff, b_false, OT, tv_low, GSC, SU, PO),
    !Config(~tid, f_LT, DF, OFFONLY) ]
--[ TimerTick(~tid), StateTransition(~tid, st_DelayedOff, st_OffIdle) ]->
  [ St(~tid, st_OffIdle, b_false, tv_zero, tv_zero, GSC, SU, PO) ]

rule TimerTick_DelayedOff_Expire_Low_noOFFONLY:
  [ St(~tid, st_DelayedOff, b_false, OT, tv_low, GSC, SU, PO),
    !Config(~tid, f_LT, DF, f_noOFFONLY) ]
--[ TimerTick(~tid), StateTransition(~tid, st_DelayedOff, st_OffIdle) ]->
  [ St(~tid, st_OffIdle, b_false, tv_zero, tv_zero, GSC, SU, PO) ]


//========================================
// SECTION 11: Startup Rules (LT only)
// OFFONLY does not affect Startup; model both OFFONLY values
//========================================

// Startup, StartUpOnOff is null, PreviousOnOff == TRUE
rule Startup_LT_Null_PrevOn:
  [ St(~tid, st_OffIdle, b_false, OT, OW, GSC, su_null, po_true),
    !Config(~tid, f_LT, DF, OFFONLY) ]
--[ Command(~tid, 'Startup'),
   StateTransition(~tid, st_OffIdle, st_OnIdle) ]->
  [ St(~tid, st_OnIdle, b_true, OT, OW, GSC, su_null, po_true) ]

rule Startup_LT_Null_PrevOn_noOFFONLY:
  [ St(~tid, st_OffIdle, b_false, OT, OW, GSC, su_null, po_true),
    !Config(~tid, f_LT, DF, f_noOFFONLY) ]
--[ Command(~tid, 'Startup'),
   StateTransition(~tid, st_OffIdle, st_OnIdle) ]->
  [ St(~tid, st_OnIdle, b_true, OT, OW, GSC, su_null, po_true) ]

// Startup, StartUpOnOff is null, PreviousOnOff == FALSE
rule Startup_LT_Null_PrevOff:
  [ St(~tid, st_OffIdle, b_false, OT, OW, GSC, su_null, po_false),
    !Config(~tid, f_LT, DF, OFFONLY) ]
--[ Command(~tid, 'Startup'),
   StateTransition(~tid, st_OffIdle, st_OffIdle) ]->
  [ St(~tid, st_OffIdle, b_false, OT, OW, GSC, su_null, po_false) ]

rule Startup_LT_Null_PrevOff_noOFFONLY:
  [ St(~tid, st_OffIdle, b_false, OT, OW, GSC, su_null, po_false),
    !Config(~tid, f_LT, DF, f_noOFFONLY) ]
--[ Command(~tid, 'Startup'),
   StateTransition(~tid, st_OffIdle, st_OffIdle) ]->
  [ St(~tid, st_OffIdle, b_false, OT, OW, GSC, su_null, po_false) ]

// Startup, StartUpOnOff == Off
rule Startup_LT_Off:
  [ St(~tid, st_OffIdle, OnOff, OT, OW, GSC, su_Off, PO),
    !Config(~tid, f_LT, DF, OFFONLY) ]
--[ Command(~tid, 'Startup'),
   StateTransition(~tid, st_OffIdle, st_OffIdle) ]->
  [ St(~tid, st_OffIdle, b_false, OT, OW, GSC, su_Off, PO) ]

rule Startup_LT_Off_noOFFONLY:
  [ St(~tid, st_OffIdle, OnOff, OT, OW, GSC, su_Off, PO),
    !Config(~tid, f_LT, DF, f_noOFFONLY) ]
--[ Command(~tid, 'Startup'),
   StateTransition(~tid, st_OffIdle, st_OffIdle) ]->
  [ St(~tid, st_OffIdle, b_false, OT, OW, GSC, su_Off, PO) ]

// Startup, StartUpOnOff == On
rule Startup_LT_On:
  [ St(~tid, st_OffIdle, OnOff, OT, OW, GSC, su_On, PO),
    !Config(~tid, f_LT, DF, OFFONLY) ]
--[ Command(~tid, 'Startup'),
   StateTransition(~tid, st_OffIdle, st_OnIdle) ]->
  [ St(~tid, st_OnIdle, b_true, OT, OW, GSC, su_On, PO) ]

rule Startup_LT_On_noOFFONLY:
  [ St(~tid, st_OffIdle, OnOff, OT, OW, GSC, su_On, PO),
    !Config(~tid, f_LT, DF, f_noOFFONLY) ]
--[ Command(~tid, 'Startup'),
   StateTransition(~tid, st_OffIdle, st_OnIdle) ]->
  [ St(~tid, st_OnIdle, b_true, OT, OW, GSC, su_On, PO) ]

// Startup, StartUpOnOff == Toggle, PreviousOnOff == FALSE
rule Startup_LT_Toggle_PrevOff:
  [ St(~tid, st_OffIdle, OnOff, OT, OW, GSC, su_Toggle, po_false),
    !Config(~tid, f_LT, DF, OFFONLY) ]
--[ Command(~tid, 'Startup'),
   StateTransition(~tid, st_OffIdle, st_OnIdle) ]->
  [ St(~tid, st_OnIdle, b_true, OT, OW, GSC, su_Toggle, po_false) ]

rule Startup_LT_Toggle_PrevOff_noOFFONLY:
  [ St(~tid, st_OffIdle, OnOff, OT, OW, GSC, su_Toggle, po_false),
    !Config(~tid, f_LT, DF, f_noOFFONLY) ]
--[ Command(~tid, 'Startup'),
   StateTransition(~tid, st_OffIdle, st_OnIdle) ]->
  [ St(~tid, st_OnIdle, b_true, OT, OW, GSC, su_Toggle, po_false) ]

// Startup, StartUpOnOff == Toggle, PreviousOnOff == TRUE
rule Startup_LT_Toggle_PrevOn:
  [ St(~tid, st_OffIdle, OnOff, OT, OW, GSC, su_Toggle, po_true),
    !Config(~tid, f_LT, DF, OFFONLY) ]
--[ Command(~tid, 'Startup'),
   StateTransition(~tid, st_OffIdle, st_OffIdle) ]->
  [ St(~tid, st_OffIdle, b_false, OT, OW, GSC, su_Toggle, po_true) ]

rule Startup_LT_Toggle_PrevOn_noOFFONLY:
  [ St(~tid, st_OffIdle, OnOff, OT, OW, GSC, su_Toggle, po_true),
    !Config(~tid, f_LT, DF, f_noOFFONLY) ]
--[ Command(~tid, 'Startup'),
   StateTransition(~tid, st_OffIdle, st_OffIdle) ]->
  [ St(~tid, st_OffIdle, b_false, OT, OW, GSC, su_Toggle, po_true) ]


//========================================
// SECTION 12: Restrictions
//========================================

restriction unique_init:
  "All tid #i #j. ClusterInit(tid)@i & ClusterInit(tid)@j ==> #i = #j"


//========================================
// SECTION 13: Source Lemma
//========================================

lemma sources [sources]:
  "All tid s1 s2 #i.
     StateTransition(tid, s1, s2)@i
   ==> Ex #j. ClusterInit(tid)@j & #j < #i"


//========================================
// SECTION 14: Simple Reachability Lemmas
//========================================

lemma exec_On_exists:
  exists-trace
  "Ex tid #i. Command(tid, 'On')@i"

lemma exec_Off_exists:
  exists-trace
  "Ex tid #i. Command(tid, 'Off')@i"

lemma state_OnIdle_reachable:
  exists-trace
  "Ex tid OT OW GSC SU PO #i.
     St(tid, st_OnIdle, b_true, OT, OW, GSC, SU, PO)@i"

end