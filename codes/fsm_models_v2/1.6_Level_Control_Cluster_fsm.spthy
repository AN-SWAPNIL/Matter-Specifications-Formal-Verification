    ]->
    [
        ServerState(endpoint, 'OffState'),
        !FeatureConfig(endpoint, 'LT', 'true'),
        !FeatureConfig(endpoint, 'OO', 'true'),
        Out(<'MoveToLevel_Response', SUCCESS>),
        !Server(endpoint)
    ]

