          {
            "id": null,
            "name": "FeatureMap attribute",
            "description": "An attribute whose bit 0 (GN Feature) is referenced by the NameSupport attribute, indicating feature support."
          },
          {
            "id": null,
            "name": "GN Feature",
            "description": "The GroupNames feature, identified by 'GN' and corresponding to bit 0 of the FeatureMap attribute."
          },
          {
            "id": null,
            "name": "Identify Cluster",
            "description": "Provides identifying functionality, which is a condition for the AddGroupIfIdentifying command."
          },
          {
            "id": null,
            "name": "Scenes Management Cluster",
            "description": "If supported on the same endpoint, scenes associated with a group are removed when the group is removed (RemoveGroup, RemoveAllGroups)."
          },
          {
            "id": null,
            "name": "Zigbee",
            "description": "Mentioned as a protocol context for payload length constraints in GetGroupMembershipResponse."
          }
        ],
        "events": []
      },
      "metadata": {
        "source_pages": "35-43",
        "extraction_method": "enhanced_section_based_dynamic",
        "section_number": "1.3",
        "category": "General",
