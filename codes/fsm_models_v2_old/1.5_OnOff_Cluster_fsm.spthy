    ]

// Periodic timer during TimedOn decrements OnTime while still positive
// Guard: OnOff == TRUE and OnTime > 0 and OnTime != 0xFFFF and OffWaitTime != 0xFFFF
// Guard: OnOff == TRUE
// Guard: OnTime > 0
rule Timer_TimedOn_to_TimedOn_T26:
    [
        ServerState(endpoint, 'TimedOn'),
        !FeatureConfig(endpoint, 'LT', 'true'),
        In(<'TimerTick_Internal', endpoint>),
        In(on_time_after),
        !Server(endpoint)
    ]
    --[
        Timer(endpoint),
        StateTransition(endpoint, 'TimedOn', 'TimedOn'),
        TimerTick(endpoint),
        TimerTickTimedOnDecrement(endpoint, on_time_after)
    ]->
    [
        ServerState(endpoint, 'TimedOn'),
        !FeatureConfig(endpoint, 'LT', 'true'),
        Out(<'TimerTick_Internal', SUCCESS>),
        !Server(endpoint)
    ]

// When OnTime reaches 0, device turns off and OffWaitTime set to 0
// Guard: OnOff == TRUE and OnTime == 1 and OnTime != 0xFFFF and OffWaitTime != 0xFFFF
// Guard: OnOff == TRUE
// Guard: OnTime == 1
rule Timer_TimedOn_to_BaseOff_T27:
    [
        ServerState(endpoint, 'TimedOn'),
        !FeatureConfig(endpoint, 'LT', 'true'),
        In(<'TimerTick_Internal', endpoint>),
        !Server(endpoint)
    ]
    --[
        Timer(endpoint),
        StateTransition(endpoint, 'TimedOn', 'BaseOff'),
        TimerTick(endpoint),
        TimerTickTimedOnExpired(endpoint)
    ]->
    [
        ServerState(endpoint, 'BaseOff'),
        !FeatureConfig(endpoint, 'LT', 'true'),
        Out(<'TimerTick_Internal', SUCCESS>),
        !Server(endpoint)
    ]

// Periodic timer during DelayedOff decrements OffWaitTime while still positive
// Guard: OnOff == FALSE and OffWaitTime > 0 and OffWaitTime != 0xFFFF and OnTime != 0xFFFF
// Guard: OnOff == FALSE
// Guard: OffWaitTime > 0
rule Timer_DelayedOff_to_DelayedOff_T28:
    [
        ServerState(endpoint, 'DelayedOff'),
        !FeatureConfig(endpoint, 'LT', 'true'),
        In(<'TimerTick_Internal', endpoint>),
        In(off_wait_time_after),
        !Server(endpoint)
    ]
    --[
